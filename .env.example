# ── Supabase (proyecto compartido con la app: lslzhgmoaxgkcjeweqaz) ──────────
# Cliente público con RLS: auth de visitantes, comentarios del blog y
# descargas gateadas (FormLeadMagnetPDF). La captura de leads YA NO usa esto.
PUBLIC_SUPABASE_URL=https://lslzhgmoaxgkcjeweqaz.supabase.co
PUBLIC_SUPABASE_KEY=<anon key>

# ── Motor de Crecimiento (captura de leads → app) ────────────────────────────
# Astro SSG inlinea las PUBLIC_* en BUILD: sin estas dos vars seteadas en el
# proyecto Vercel (sigmetria-hys) ANTES de buildear, todo submit del form falla.

# URL base de la app Sigmetría (sin slash final)
PUBLIC_APP_URL=https://app.sigmetria.com.ar

# Clave pública de captura del tenant casa (seed de public.growth_keys,
# migración 20260822000001 del repo app). Es pública por diseño: viaja en el
# header X-Growth-Key desde el browser.
PUBLIC_GROWTH_KEY=gk_911fa3446b48eaf277ad2e0284536223d3156589
