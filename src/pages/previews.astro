---
/**
 * /previews — listado privado de posts en borrador y programados.
 * No está en el nav ni en el sitemap. Solo quienes conocen la URL lo pueden ver.
 * Útil para revisar contenido antes de que llegue su fecha de publicación.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import { blogPosts } from '../data/blog-posts';

const today = new Date();

const borradores = blogPosts.filter(p => p.oculto);
const programados = blogPosts.filter(p => !p.oculto && new Date(p.fecha) > today);

function diasRestantes(fecha: string) {
  const diff = new Date(fecha).getTime() - today.getTime();
  return Math.ceil(diff / (1000 * 60 * 60 * 24));
}
---

<BaseLayout
  title="Vista previa de borradores — SIGMETRÍA HyS"
  description="Listado interno de posts en borrador y programados."
  noindex={true}
>
  <section class="page-hero" style="padding-bottom:32px">
    <div class="page-hero-inner">
      <div class="preview-badge">Uso interno · No indexado</div>
      <h1>BORRADORES Y POSTS<br><em>PROGRAMADOS</em></h1>
      <p>Esta página no está en el nav ni en el sitemap. Solo vos podés verla.</p>
    </div>
  </section>

  <section class="content-section" style="background:var(--blanco);padding:40px 24px 80px">
    <div style="max-width:860px;margin:0 auto">

      {programados.length > 0 && (
        <div class="group">
          <h2 class="group-title">Programados ({programados.length})</h2>
          <p class="group-desc">Se publicarán automáticamente cuando Vercel rebuilde después de su fecha.</p>
          <div class="post-list">
            {programados.map(p => (
              <div class="post-row">
                <div class="post-info">
                  <a href={`/blog/${p.slug}/`} target="_blank" rel="noopener" class="post-title">{p.titulo}</a>
                  <span class="post-meta">{p.categoria} · {p.fecha}</span>
                </div>
                <span class="badge badge-programado">en {diasRestantes(p.fecha)} días</span>
              </div>
            ))}
          </div>
        </div>
      )}

      {borradores.length > 0 && (
        <div class="group">
          <h2 class="group-title">Borradores ocultos ({borradores.length})</h2>
          <p class="group-desc">Tienen <code>oculto: true</code> — no se publican por fecha. Para publicar, quitá el flag en blog-posts.ts.</p>
          <div class="post-list">
            {borradores.map(p => (
              <div class="post-row">
                <div class="post-info">
                  <a href={`/blog/${p.slug}/`} target="_blank" rel="noopener" class="post-title">{p.titulo}</a>
                  <span class="post-meta">{p.categoria} · {p.fecha}</span>
                </div>
                <span class="badge badge-oculto">oculto</span>
              </div>
            ))}
          </div>
        </div>
      )}

      {programados.length === 0 && borradores.length === 0 && (
        <p style="color:var(--gris-3);font-size:15px">No hay posts en borrador ni programados.</p>
      )}

    </div>
  </section>
</BaseLayout>

<style>
.page-hero-inner { max-width: 860px; }
.preview-badge {
  display: inline-block;
  font-family: 'Montserrat', sans-serif;
  font-size: .58rem;
  font-weight: 700;
  letter-spacing: 2.5px;
  text-transform: uppercase;
  color: #B45309;
  border: 1px solid rgba(180,83,9,.35);
  border-radius: 100px;
  padding: 4px 12px;
  margin-bottom: 16px;
}
.page-hero h1 {
  font-size: clamp(1.5rem, 3.5vw, 2.2rem);
  line-height: 1.1;
  margin-bottom: 12px;
  color: var(--gris-1);
}
.page-hero h1 em { font-style: normal; color: #2E7D33; }
.page-hero p { font-size: .9rem; font-weight: 300; color: var(--gris-3); }

.group { margin-bottom: 48px; }
.group-title {
  font-family: 'Montserrat', sans-serif;
  font-size: .75rem;
  font-weight: 800;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: var(--gris-1);
  margin-bottom: 6px;
}
.group-desc {
  font-size: 13px;
  font-weight: 300;
  color: var(--gris-3);
  margin-bottom: 16px;
}
.group-desc code {
  font-size: 12px;
  background: var(--gris-bg);
  padding: 1px 6px;
  border-radius: 4px;
  border: 1px solid var(--borde);
}

.post-list { display: flex; flex-direction: column; gap: 12px; }
.post-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
  background: var(--gris-bg);
  border: 1px solid var(--borde);
  border-radius: 8px;
  padding: 14px 18px;
}
.post-info { display: flex; flex-direction: column; gap: 4px; min-width: 0; }
.post-title {
  font-size: 14px;
  font-weight: 600;
  color: var(--gris-1);
  text-decoration: none;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.post-title:hover { color: #2E7D33; text-decoration: underline; }
.post-meta { font-size: 12px; font-weight: 300; color: var(--gris-3); }

.badge {
  font-family: 'Montserrat', sans-serif;
  font-size: .6rem;
  font-weight: 700;
  letter-spacing: 1px;
  text-transform: uppercase;
  padding: 4px 10px;
  border-radius: 100px;
  white-space: nowrap;
  flex-shrink: 0;
}
.badge-programado { background: #FEF3C7; color: #92400E; border: 1px solid #FDE68A; }
.badge-oculto     { background: #F3F4F6; color: #6B7280; border: 1px solid #E5E7EB; }

@media (max-width: 520px) {
  .post-row { flex-direction: column; align-items: flex-start; gap: 8px; }
  .post-title { white-space: normal; }
}
</style>
