---
import BaseLayout from '../layouts/BaseLayout.astro';
import { TRIAL_URL } from '../config/site';
---

<BaseLayout
  title="Plataforma SaaS de Gestión HyS — Onboarding en 30 días | SIGMETRÍA HyS"
  description="Planificá, ejecutá, controlá y medí tu gestión HyS en una sola plataforma. Vencimientos automáticos, desvíos con trazabilidad, capacitaciones digitales y KPIs en tiempo real."
>

  <section class="page-hero">
    <div class="page-hero-inner">
      <nav aria-label="Breadcrumb" class="breadcrumb">
        <a href="/">Inicio</a><span>/</span>
        <span>Plataforma</span>
      </nav>
      <div class="page-hero-badge">SaaS · Onboarding en 30 días · Sin Excel</div>
      <h1>TODO TU HYS<br><em>EN UN SISTEMA</em></h1>
      <p class="hero-sub">Planificá, ejecutá, controlá y medí tu sistema de gestión HyS completo. Si mañana renunciás, el sistema sigue funcionando.</p>
      <div class="hero-ctas">
        <a href={TRIAL_URL} class="btn-primary">Probá gratis</a>
        <a href="/plataforma/demo/" class="btn-outline">Ver demo / consulta</a>
      </div>
    </div>
  </section>

  <!-- Galería de producto: capturas reales del app (LIFT claridad / MECLABS valor) -->
  <section class="plat-showcase" aria-label="Capturas de la plataforma">
    <div class="plat-showcase-inner">
      <figure class="plat-shot plat-shot--wide">
        <img src="/producto/dashboard.jpeg" alt="Dashboard ejecutivo de HyS con KPIs en tiempo real" loading="lazy" width="1440" height="900" />
        <figcaption>Dashboard ejecutivo en tiempo real</figcaption>
      </figure>
      <figure class="plat-shot">
        <img src="/producto/agenda.jpeg" alt="Agenda de gestiones planificadas y ejecutadas" loading="lazy" width="1440" height="900" />
        <figcaption>Agenda de gestiones por responsable</figcaption>
      </figure>
      <figure class="plat-shot">
        <img src="/producto/cartera.jpeg" alt="Cartera de empresas y establecimientos" loading="lazy" width="1440" height="900" />
        <figcaption>Cartera de clientes y establecimientos</figcaption>
      </figure>
    </div>
  </section>

  <style>
    .plat-showcase { padding: 8px 24px 8px; }
    .plat-showcase-inner { max-width: 1080px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 22px; }
    .plat-shot { margin: 0; }
    .plat-shot--wide { grid-column: 1 / -1; }
    .plat-shot img { width: 100%; height: auto; display: block; border-radius: 12px; border: 1px solid var(--borde, #e3e6ea); box-shadow: 0 12px 40px rgba(0,0,0,.12); }
    .plat-shot figcaption { text-align: center; font-size: .82rem; color: var(--gris-3, #667); margin-top: 9px; }
    @media (max-width: 800px) { .plat-showcase-inner { grid-template-columns: 1fr; gap: 18px; } }
  </style>

  <section class="content-section">
    <div class="content-inner">

      <div class="modulos-grid">
        <div class="modulo-card">
          <span class="modulo-icon">📂</span>
          <h2>Gestión documental y vencimientos</h2>
          <p>Todos los documentos con estado, fecha de vencimiento y alerta automática. Nunca más un documento vencido en una auditoría.</p>
        </div>
        <div class="modulo-card">
          <span class="modulo-icon">⚠️</span>
          <h2>Seguimiento de desvíos con trazabilidad</h2>
          <p>Desde la apertura del desvío hasta el cierre con evidencia. Responsable asignado, fecha límite y estado en tiempo real.</p>
        </div>
        <div class="modulo-card">
          <span class="modulo-icon">🎓</span>
          <h2>Capacitaciones digitales con evidencias</h2>
          <p>Registro de asistencia, firma digital y constancias automáticas. Las evidencias quedan en el sistema, accesibles para cualquier auditoría.</p>
        </div>
        <div class="modulo-card">
          <span class="modulo-icon">📊</span>
          <h2>Matriz de riesgos dinámica</h2>
          <p>La matriz se actualiza cuando cambian los controles o las condiciones. No es un Excel estático — es un tablero vivo.</p>
        </div>
        <div class="modulo-card">
          <span class="modulo-icon">📱</span>
          <h2>App de campo para operarios</h2>
          <p>Checklist, registro fotográfico, firma y reporte de desvíos desde el celular. Sin papel, sin demoras.</p>
        </div>
        <div class="modulo-card">
          <span class="modulo-icon">📈</span>
          <h2>KPIs y reportes para dirección</h2>
          <p>Dashboard ejecutivo con los indicadores que le interesan a tu jefe. Listo para presentar en la revisión por la dirección.</p>
        </div>
      </div>

      <!-- Precios resumidos -->
      <div class="precios-preview">
        <div class="precios-preview-header">
          <h2>PLANES Y <em>PRECIOS</em></h2>
          <p>Sin permanencia mínima. Pagos por transferencia. IVA 21% discriminado.</p>
          <p class="pp-founder">🔥 <strong>Programa Fundadores:</strong> −20% de por vida para los primeros 8 de cada plan. <a href="/fundadores/">Ver programa →</a></p>
        </div>
        <div class="precios-preview-grid">
          <div class="pp-card">
            <span class="pp-nombre">Trial</span>
            <span class="pp-precio">Gratis</span>
            <span class="pp-detalle">1 mes · 2 empresas</span>
          </div>
          <div class="pp-card">
            <span class="pp-nombre">Prof. Inicial</span>
            <span class="pp-precio">$24.000<small>/mes</small></span>
            <span class="pp-detalle">10 empresas · 40 establec.</span>
          </div>
          <div class="pp-card pp-card-destacado">
            <span class="pp-badge">Más elegido</span>
            <span class="pp-nombre">Consultora Chica</span>
            <span class="pp-precio">$115.000<small>/mes</small></span>
            <span class="pp-detalle">5 colaboradores · 30 empresas</span>
          </div>
          <div class="pp-card">
            <span class="pp-nombre">Consultora Grande</span>
            <span class="pp-precio">$430.000<small>/mes</small></span>
            <span class="pp-detalle">20 colaboradores · 120 empresas</span>
          </div>
        </div>
        <a href="/precios/" class="precios-preview-cta">Ver los 7 planes y comparar →</a>
      </div>

      <div class="cta-banner">
        <h2>DEMO <em>PERSONALIZADA</em></h2>
        <p>Te mostramos la plataforma con datos de una empresa similar a la tuya. En 30 minutos sabés si sirve o no — sin compromiso.</p>
        <div class="cta-actions">
          <a href="/plataforma/demo/" class="btn-primary">Solicitar demo</a>
          <a href="https://wa.me/5491123496789" class="btn-outline" target="_blank" rel="noopener">WhatsApp</a>
        </div>
      </div>

    </div>
  </section>

</BaseLayout>

<style>
.hero-sub { font-size: 15px; font-weight: 300; color: var(--gris-2); line-height: 1.8; max-width: 560px; margin: 12px 0 24px; }
.hero-ctas { display: flex; gap: 12px; flex-wrap: wrap; }
.modulos-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16px;
  margin-bottom: 48px;
}
.modulo-card {
  padding: 24px 20px;
  background: var(--blanco);
  border: 1px solid var(--borde);
  border-radius: 10px;
  transition: all .2s;
}
.modulo-card:hover { border-color: var(--verde-borde); box-shadow: 0 6px 20px rgba(0,0,0,.06); }
.modulo-icon { font-size: 1.8rem; display: block; margin-bottom: 12px; }
.modulo-card h2 { font-family: 'Montserrat', sans-serif; font-size: 13px; font-weight: 700; text-transform: uppercase; letter-spacing: .5px; color: var(--gris-1); margin-bottom: 8px; }
.modulo-card p { font-size: 13px; font-weight: 300; color: var(--gris-2); line-height: 1.7; margin: 0; }
@media (max-width: 900px) { .modulos-grid { grid-template-columns: repeat(2, 1fr); } }
@media (max-width: 600px) { .modulos-grid { grid-template-columns: 1fr; } }

/* Precios preview */
.precios-preview {
  background: var(--blanco);
  border: 1px solid var(--borde);
  border-radius: 12px;
  padding: 32px 28px;
  margin-bottom: 32px;
}
.precios-preview-header { margin-bottom: 24px; }
.precios-preview-header h2 {
  font-family: 'Montserrat', sans-serif;
  font-size: 1rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: .5px;
  color: var(--gris-1);
  margin: 0 0 6px;
}
.precios-preview-header h2 em { color: var(--verde); font-style: normal; }
.precios-preview-header p { font-size: 13px; font-weight: 300; color: var(--gris-2); margin: 0; }
.pp-founder {
  margin-top: 8px !important; font-weight: 400 !important;
  background: #FFF4E5; color: #B45309 !important; border: 1px solid #FCD9A8;
  border-radius: 8px; padding: 6px 12px; display: inline-block;
}
.pp-founder a { color: #92400E; font-weight: 700; text-decoration: underline; }

.precios-preview-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12px;
  margin-bottom: 20px;
}
.pp-card {
  border: 1.5px solid var(--borde);
  border-radius: 8px;
  padding: 16px;
  display: flex;
  flex-direction: column;
  gap: 4px;
  position: relative;
  transition: border-color .2s, box-shadow .2s;
}
.pp-card:hover { border-color: var(--verde-borde); box-shadow: 0 4px 14px rgba(0,0,0,.06); }
.pp-card-destacado { border-color: var(--verde); }
.pp-badge {
  position: absolute;
  top: -10px; left: 12px;
  background: var(--verde);
  color: #fff;
  font-family: 'Montserrat', sans-serif;
  font-size: .55rem;
  font-weight: 700;
  letter-spacing: .5px;
  text-transform: uppercase;
  padding: 3px 8px;
  border-radius: 10px;
}
.pp-nombre {
  font-family: 'Montserrat', sans-serif;
  font-size: .72rem;
  font-weight: 700;
  color: var(--gris-1);
  text-transform: uppercase;
  letter-spacing: .3px;
}
.pp-precio {
  font-family: 'Montserrat', sans-serif;
  font-size: 1.2rem;
  font-weight: 800;
  color: var(--gris-1);
  line-height: 1;
  margin-top: 4px;
}
.pp-precio small { font-size: .65rem; font-weight: 400; color: var(--gris-2); margin-left: 2px; }
.pp-detalle { font-size: 11px; color: var(--gris-2); font-weight: 300; }

.precios-preview-cta {
  display: inline-block;
  font-family: 'Montserrat', sans-serif;
  font-size: .75rem;
  font-weight: 700;
  color: var(--verde);
  text-decoration: none;
  letter-spacing: .3px;
  transition: color .2s;
}
.precios-preview-cta:hover { color: var(--verde-dark); }

@media (max-width: 900px) { .precios-preview-grid { grid-template-columns: repeat(2, 1fr); } }
@media (max-width: 600px) { .precios-preview-grid { grid-template-columns: 1fr; } }
</style>
