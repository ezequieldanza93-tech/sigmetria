---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Accedé a tu cuenta — SIGMETRÍA HyS"
  description="Ingresá con tu email. Si tenés cuenta te pedimos tu contraseña; si es tu primera vez te mandamos un link."
  canonical="https://www.sigmetria.com.ar/acceso/"
  noindex={true}
>
  <section class="acceso-wrap">
    <div class="acceso-card">

      <!-- Paso 1: email (estado inicial) -->
      <div id="ac-email-step">
        <div class="ac-icon" aria-hidden="true">
          <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#2E7D33" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
            <polyline points="22,6 12,13 2,6"/>
          </svg>
        </div>
        <h1 class="ac-title">Ingresá a Sigmetría</h1>
        <p class="ac-sub">Escribí tu email y te decimos el siguiente paso.</p>

        <form id="ac-email-form" novalidate>
          <div class="ac-field">
            <label for="ac-email-input">Email</label>
            <input id="ac-email-input" type="email" name="email" required autocomplete="email" placeholder="tu@email.com" />
          </div>
          <p class="ac-error" id="ac-email-error" role="alert" style="display:none"></p>
          <button type="submit" class="ac-btn">Continuar →</button>
        </form>
      </div>

      <!-- Paso 2A: contraseña (cuenta existente) -->
      <div id="ac-password-step" style="display:none">
        <div class="ac-icon" aria-hidden="true">
          <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#2E7D33" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
            <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
          </svg>
        </div>
        <h1 class="ac-title">¡Hola de nuevo!</h1>
        <div class="ac-email-chip">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
            <polyline points="22,6 12,13 2,6"/>
          </svg>
          <span id="ac-email-display"></span>
          <button class="ac-chip-close" id="ac-change-email-btn" type="button" title="Cambiar email" aria-label="Cambiar email">✕</button>
        </div>

        <form id="ac-password-form" novalidate>
          <div class="ac-field">
            <label for="ac-password-input">Contraseña</label>
            <div class="ac-input-wrap">
              <input id="ac-password-input" type="password" name="password" required autocomplete="current-password" placeholder="Tu contraseña" />
              <button type="button" class="ac-pw-toggle" id="ac-pw-toggle" aria-label="Mostrar contraseña" aria-pressed="false">
                <!-- Ojo abierto: visible cuando la contraseña está oculta (click → mostrar) -->
                <svg id="ac-eye-open" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/>
                  <circle cx="12" cy="12" r="3"/>
                </svg>
                <!-- Ojo tachado: visible cuando la contraseña está revelada (click → ocultar) -->
                <svg id="ac-eye-off" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="display:none">
                  <path d="M9.88 9.88a3 3 0 1 0 4.24 4.24"/>
                  <path d="M10.73 5.08A10.43 10.43 0 0 1 12 5c7 0 10 7 10 7a13.16 13.16 0 0 1-1.67 2.68"/>
                  <path d="M6.61 6.61A13.526 13.526 0 0 0 2 12s3 7 10 7a9.74 9.74 0 0 0 5.39-1.61"/>
                  <line x1="2" x2="22" y1="2" y2="22"/>
                </svg>
              </button>
            </div>
          </div>
          <p class="ac-error" id="ac-password-error" role="alert" style="display:none"></p>
          <button type="submit" class="ac-btn">Iniciar sesión</button>
        </form>

        <p class="ac-hint">
          <button class="ac-link-btn" id="ac-forgot-btn" type="button">¿Olvidaste tu contraseña?</button>
          Te mandamos un link.
        </p>
      </div>

      <!-- Loading -->
      <div id="ac-loading-step" style="display:none">
        <div class="ac-spinner-wrap">
          <span class="ac-spinner" aria-hidden="true"></span>
          <p>Un momento…</p>
        </div>
      </div>

      <!-- Magic link enviado (cuenta nueva + recuperar contraseña) -->
      <div id="ac-magic-sent-step" style="display:none">
        <div class="ac-success-icon" aria-hidden="true">📬</div>
        <h1 class="ac-title">Revisá tu casilla</h1>
        <p class="ac-sub">
          Te enviamos un link a <strong id="ac-sent-email"></strong>.
          Hacé clic en él para acceder.
        </p>
        <p class="ac-hint">
          ¿No lo encontrás? Revisá spam o
          <button class="ac-link-btn" id="ac-resend-btn" type="button">reenvialo</button>.
        </p>
        <p class="ac-hint" style="margin-top:6px">
          <button class="ac-link-btn" id="ac-back-email-btn" type="button">Cambiar email</button>
        </p>
      </div>

      <!-- Ya logueado -->
      <div id="ac-logged-step" style="display:none">
        <div class="ac-success-icon" aria-hidden="true">👋</div>
        <h1 class="ac-title">Ya estás adentro</h1>
        <p class="ac-sub" id="ac-logged-msg">Estás autenticado.</p>
        <a href="/blog/" class="ac-btn ac-btn-link">Ir al blog →</a>
        <p class="ac-hint">
          ¿No sos vos?
          <button class="ac-link-btn" id="ac-signout-btn" type="button">Cerrar sesión</button>
        </p>
      </div>

    </div>
  </section>
</BaseLayout>

<style>
.acceso-wrap {
  min-height: 80vh;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 120px 20px 80px;
  background: var(--gris-bg, #F9FAFB);
}
.acceso-card {
  background: var(--blanco, #fff);
  border: 1px solid var(--borde, #E5E7EB);
  border-radius: 16px;
  padding: 48px 40px;
  max-width: 420px;
  width: 100%;
  box-shadow: 0 4px 24px rgba(0,0,0,.06);
  text-align: center;
}
.ac-icon {
  width: 56px;
  height: 56px;
  background: #E8F5E9;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 20px;
}
.ac-title {
  font-family: 'Montserrat', sans-serif;
  font-size: 1.35rem;
  font-weight: 800;
  color: var(--gris-1, #1A1A1A);
  margin-bottom: 8px;
}
.ac-sub {
  font-size: .95rem;
  font-weight: 300;
  color: var(--gris-2, #555);
  line-height: 1.6;
  margin-bottom: 24px;
}
.ac-email-chip {
  display: inline-flex;
  align-items: center;
  gap: 7px;
  background: #E8F5E9;
  border: 1px solid #C8E6C9;
  border-radius: 24px;
  padding: 7px 14px;
  margin-bottom: 22px;
  max-width: 100%;
  color: var(--gris-2, #555);
}
.ac-email-chip span {
  font-size: 13px;
  font-weight: 500;
  color: var(--gris-1, #1A1A1A);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 220px;
}
.ac-chip-close {
  background: none;
  border: none;
  color: var(--gris-3, #9CA3AF);
  cursor: pointer;
  font-size: 13px;
  padding: 0;
  line-height: 1;
  flex-shrink: 0;
}
.ac-chip-close:hover { color: var(--gris-1, #1A1A1A); }
.ac-field {
  display: flex;
  flex-direction: column;
  gap: 6px;
  text-align: left;
  margin-bottom: 14px;
}
.ac-field label {
  font-size: 12px;
  font-weight: 600;
  color: var(--gris-2);
  letter-spacing: .4px;
}
.ac-field input {
  background: var(--blanco);
  border: 1px solid var(--borde);
  border-radius: 8px;
  padding: 11px 14px;
  font-family: 'Poppins', sans-serif;
  font-size: 14px;
  font-weight: 300;
  color: var(--gris-1);
  outline: none;
  transition: border-color .2s;
  width: 100%;
  box-sizing: border-box;
}
.ac-field input:focus { border-color: #2E7D33; }
.ac-field input:focus-visible { outline: 2px solid #2E7D33; outline-offset: 2px; }
.ac-input-wrap { position: relative; }
.ac-input-wrap input { padding-right: 44px; }
.ac-pw-toggle {
  position: absolute;
  right: 6px;
  top: 50%;
  transform: translateY(-50%);
  display: flex;
  align-items: center;
  justify-content: center;
  background: none;
  border: none;
  padding: 6px;
  border-radius: 6px;
  cursor: pointer;
  color: var(--gris-3, #9CA3AF);
  transition: color .2s;
}
.ac-pw-toggle:hover { color: var(--gris-1, #1A1A1A); }
.ac-pw-toggle:focus-visible { outline: 2px solid #2E7D33; outline-offset: 1px; }
.ac-error {
  font-size: 12px;
  color: var(--rojo, #D32F2F);
  margin-bottom: 10px;
  text-align: left;
}
.ac-btn {
  display: block;
  width: 100%;
  padding: 13px 20px;
  background: #2E7D33;
  color: #fff;
  border: none;
  border-radius: 10px;
  font-family: 'Montserrat', sans-serif;
  font-weight: 700;
  font-size: .85rem;
  letter-spacing: .5px;
  text-transform: uppercase;
  cursor: pointer;
  transition: background .2s;
  text-decoration: none;
  text-align: center;
}
.ac-btn:hover { background: #1B5E20; }
.ac-btn:focus-visible { outline: 2px solid #2E7D33; outline-offset: 3px; }
.ac-btn-link {
  display: block;
  width: 100%;
  padding: 13px 20px;
  background: transparent;
  color: #2E7D33;
  border: 2px solid #2E7D33;
  border-radius: 10px;
  font-family: 'Montserrat', sans-serif;
  font-weight: 700;
  font-size: .85rem;
  letter-spacing: .5px;
  text-transform: uppercase;
  cursor: pointer;
  transition: background .2s;
  text-decoration: none;
  text-align: center;
}
.ac-btn-link:hover { background: #E8F5E9; }
.ac-hint {
  font-size: 12px;
  font-weight: 300;
  color: var(--gris-3, #9CA3AF);
  margin-top: 16px;
  line-height: 1.6;
}
.ac-link-btn {
  color: #2E7D33;
  font-weight: 500;
  background: none;
  border: none;
  cursor: pointer;
  font-size: inherit;
  padding: 0;
  font-family: inherit;
  text-decoration: underline;
}
.ac-link-btn:hover { color: #1B5E20; }
.ac-spinner-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12px;
  padding: 20px 0;
  color: var(--gris-3);
  font-size: 14px;
  font-weight: 300;
}
.ac-spinner {
  display: inline-block;
  width: 24px;
  height: 24px;
  border: 3px solid rgba(46,125,51,.2);
  border-top-color: #2E7D33;
  border-radius: 50%;
  animation: spin .7s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }
.ac-success-icon { font-size: 2.5rem; margin-bottom: 12px; display: block; }

@media (max-width: 480px) {
  .acceso-card { padding: 32px 20px; }
}
</style>

<script>
  import { createClient } from '@supabase/supabase-js';

  const supabase = createClient(
    import.meta.env.PUBLIC_SUPABASE_URL,
    import.meta.env.PUBLIC_SUPABASE_KEY,
    { auth: { flowType: 'implicit' } }
  );

  const EMAIL_RE = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
  let currentEmail = '';

  const emailStep    = document.getElementById('ac-email-step')!;
  const passwordStep = document.getElementById('ac-password-step')!;
  const loadingStep  = document.getElementById('ac-loading-step')!;
  const magicSentStep = document.getElementById('ac-magic-sent-step')!;
  const loggedStep   = document.getElementById('ac-logged-step')!;

  const ALL_STEPS = [emailStep, passwordStep, loadingStep, magicSentStep, loggedStep];
  function show(el: HTMLElement) {
    ALL_STEPS.forEach(s => { s.style.display = 'none'; });
    el.style.display = 'block';
  }

  function getNextParam(): string {
    return new URLSearchParams(window.location.search).get('next') ?? '/blog/';
  }

  async function handleSession(session: any) {
    const email = session.user.email ?? '';
    const nombre = session.user.user_metadata?.full_name
      ?? session.user.user_metadata?.name
      ?? null;
    localStorage.setItem('sigm_email', email);
    await supabase.rpc('upsert_web_profile', { p_email: email, p_nombre: nombre });
    const { data: profile } = await supabase
      .from('web_profiles')
      .select('onboarding_completado')
      .eq('auth_user_id', session.user.id)
      .maybeSingle();
    const next = getNextParam();
    window.location.href = !profile?.onboarding_completado
      ? `/bienvenida/?next=${encodeURIComponent(next)}`
      : next;
  }

  async function sendMagicLink(email: string): Promise<string | null> {
    const next = getNextParam();
    const redirectTo = `${window.location.origin}/acceso/?next=${encodeURIComponent(next)}`;
    const { error } = await supabase.auth.signInWithOtp({ email, options: { emailRedirectTo: redirectTo } });
    if (!error) return null;
    const isRateLimit = error.status === 429 || error.message?.toLowerCase().includes('rate');
    return isRateLimit
      ? 'Límite de envíos alcanzado. Esperá unos minutos y volvé a intentarlo.'
      : `Error al enviar: ${error.message}`;
  }

  // Pre-fill email from localStorage
  const saved = localStorage.getItem('sigm_email');
  if (saved) {
    const emailInput = document.getElementById('ac-email-input') as HTMLInputElement;
    if (emailInput) emailInput.value = saved;
  }

  // onAuthStateChange
  supabase.auth.onAuthStateChange(async (event, session) => {
    if (event === 'INITIAL_SESSION') {
      if (session) {
        // Si venimos de un redirect OAuth (token en el hash) → procesar como login nuevo
        if (window.location.hash.includes('access_token')) {
          await handleSession(session);
        } else {
          const loggedMsg = document.getElementById('ac-logged-msg')!;
          loggedMsg.textContent = `Autenticado como ${session.user.email}.`;
          show(loggedStep);
        }
      }
      // sin sesión → email-step ya visible por defecto
    } else if (event === 'SIGNED_IN' && session) {
      await handleSession(session);
    }
  });

  // ── Paso 1: email → Continuar ────────────────────────────────────────────────
  const emailForm  = document.getElementById('ac-email-form') as HTMLFormElement;
  const emailError = document.getElementById('ac-email-error')!;
  const emailDisplay = document.getElementById('ac-email-display')!;
  const sentEmail    = document.getElementById('ac-sent-email')!;

  emailForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const emailInput = document.getElementById('ac-email-input') as HTMLInputElement;
    const email = emailInput.value.trim();

    if (!EMAIL_RE.test(email)) {
      emailError.textContent = 'Ingresá un email válido.';
      emailError.style.display = 'block';
      return;
    }

    emailError.style.display = 'none';
    currentEmail = email;
    show(loadingStep);

    // Timeout de 8s: si supabase-js reintenta con backoff no quedamos colgados
    let exists: boolean | null = null;
    let checkFailed = false;
    try {
      const rpcPromise = supabase.rpc('check_email_registered', { p_email: email });
      const timeoutPromise = new Promise<never>((_, rej) => setTimeout(() => rej(new Error('timeout')), 8000));
      const { data, error: checkError } = await Promise.race([rpcPromise, timeoutPromise]) as any;
      if (checkError) throw checkError;
      exists = data as boolean;
    } catch (_) {
      checkFailed = true;
    }

    if (checkFailed) {
      show(emailStep);
      emailError.textContent = 'No se pudo conectar con el servidor. Intentá de nuevo.';
      emailError.style.display = 'block';
      return;
    }

    if (exists) {
      // Cuenta existente → mostrar password step
      emailDisplay.textContent = email;
      show(passwordStep);
      (document.getElementById('ac-password-input') as HTMLInputElement)?.focus();
    } else {
      // Sin cuenta → crear + enviar magic link
      const errMsg = await sendMagicLink(email);
      if (errMsg) {
        show(emailStep);
        emailError.textContent = errMsg;
        emailError.style.display = 'block';
        return;
      }
      localStorage.setItem('sigm_email', email);
      sentEmail.textContent = email;
      show(magicSentStep);
    }
  });

  // ── Paso 2A: password → Iniciar sesión ───────────────────────────────────────
  const passwordForm  = document.getElementById('ac-password-form') as HTMLFormElement;
  const passwordError = document.getElementById('ac-password-error')!;

  passwordForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const pwInput = document.getElementById('ac-password-input') as HTMLInputElement;
    const password = pwInput.value;

    if (!password) {
      passwordError.textContent = 'Ingresá tu contraseña.';
      passwordError.style.display = 'block';
      return;
    }

    passwordError.style.display = 'none';
    show(loadingStep);

    const { error } = await supabase.auth.signInWithPassword({ email: currentEmail, password });

    if (error) {
      show(passwordStep);
      passwordError.textContent = 'Contraseña incorrecta.';
      passwordError.style.display = 'block';
      return;
    }
    // SIGNED_IN dispara y redirige vía handleSession
  });

  // ── Mostrar / ocultar contraseña ─────────────────────────────────────────────
  const pwToggleBtn = document.getElementById('ac-pw-toggle');
  const pwField     = document.getElementById('ac-password-input') as HTMLInputElement;
  const eyeOpen     = document.getElementById('ac-eye-open')!;
  const eyeOff      = document.getElementById('ac-eye-off')!;

  function setPwVisible(visible: boolean) {
    if (!pwToggleBtn || !pwField) return;
    pwField.type = visible ? 'text' : 'password';
    pwToggleBtn.setAttribute('aria-pressed', String(visible));
    pwToggleBtn.setAttribute('aria-label', visible ? 'Ocultar contraseña' : 'Mostrar contraseña');
    eyeOpen.style.display = visible ? 'none' : 'block';
    eyeOff.style.display  = visible ? 'block' : 'none';
  }

  pwToggleBtn?.addEventListener('click', () => {
    setPwVisible(pwField.type === 'password');
    pwField.focus();
  });

  // ── Olvidé mi contraseña ─────────────────────────────────────────────────────
  document.getElementById('ac-forgot-btn')?.addEventListener('click', async () => {
    show(loadingStep);
    const errMsg = await sendMagicLink(currentEmail);
    if (errMsg) {
      show(passwordStep);
      passwordError.textContent = errMsg;
      passwordError.style.display = 'block';
      return;
    }
    sentEmail.textContent = currentEmail;
    show(magicSentStep);
  });

  // ── Cambiar email (desde password step) ─────────────────────────────────────
  document.getElementById('ac-change-email-btn')?.addEventListener('click', () => {
    setPwVisible(false);
    show(emailStep);
  });

  // ── Reenviar desde magic-sent-step ───────────────────────────────────────────
  document.getElementById('ac-resend-btn')?.addEventListener('click', async () => {
    show(loadingStep);
    await sendMagicLink(currentEmail); // silencioso si falla (ya está en el estado correcto)
    sentEmail.textContent = currentEmail;
    show(magicSentStep);
  });

  // ── Cambiar email desde magic-sent-step ─────────────────────────────────────
  document.getElementById('ac-back-email-btn')?.addEventListener('click', () => {
    show(emailStep);
  });

  // ── Cerrar sesión ────────────────────────────────────────────────────────────
  document.getElementById('ac-signout-btn')?.addEventListener('click', async () => {
    await supabase.auth.signOut();
    localStorage.removeItem('sigm_email');
    show(emailStep);
  });
</script>
