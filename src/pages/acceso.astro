---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Accedé a tu cuenta — SIGMETRÍA HyS"
  description="Ingresá con email y contraseña. Si es tu primera vez, accedé con link de email."
  canonical="https://sigmetriahys.com/acceso/"
>
  <section class="acceso-wrap">
    <div class="acceso-card">

      <!-- Estado: login email + password (PRINCIPAL) -->
      <div id="ac-login-state">
        <div class="ac-icon" aria-hidden="true">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#2E7D33" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
            <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
          </svg>
        </div>
        <h1 class="ac-title">Accedé a tu cuenta</h1>
        <p class="ac-sub">Ingresá con tu email y contraseña.</p>

        <form id="ac-login-form" novalidate>
          <div class="ac-field">
            <label for="ac-email">Email</label>
            <input id="ac-email" type="email" name="email" required autocomplete="email" placeholder="tu@email.com" />
          </div>
          <div class="ac-field">
            <label for="ac-password">Contraseña</label>
            <input id="ac-password" type="password" name="password" required autocomplete="current-password" placeholder="Tu contraseña" />
          </div>
          <p class="ac-error" id="ac-login-error" role="alert" style="display:none"></p>
          <button type="submit" class="ac-btn" id="ac-login-btn">Iniciar sesión</button>
        </form>

        <p class="ac-hint">
          ¿Primera vez o no recordás tu contraseña?
          <button class="ac-link-btn" id="ac-to-magic-btn">Accedé con link al email</button>
        </p>
      </div>

      <!-- Estado: magic link (primera vez / recuperar acceso) -->
      <div id="ac-magic-state" style="display:none">
        <div class="ac-icon" aria-hidden="true">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#2E7D33" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
            <polyline points="22,6 12,13 2,6"/>
          </svg>
        </div>
        <h2 class="ac-title">Accedé con link al email</h2>
        <p class="ac-sub">Si es tu primera vez o no recordás tu contraseña, te mandamos un link instantáneo. Sin contraseña.</p>

        <form id="ac-magic-form" novalidate>
          <div class="ac-field">
            <label for="ac-magic-email">Email</label>
            <input id="ac-magic-email" type="email" name="email" required autocomplete="email" placeholder="tu@email.com" />
          </div>
          <p class="ac-error" id="ac-magic-error" role="alert" style="display:none"></p>
          <button type="submit" class="ac-btn" id="ac-magic-btn">Enviar link de acceso</button>
        </form>

        <p class="ac-hint">
          ¿Ya tenés contraseña?
          <button class="ac-link-btn" id="ac-to-login-btn">Iniciá sesión</button>
        </p>
      </div>

      <!-- Estado: loading -->
      <div id="ac-loading-state" style="display:none">
        <div class="ac-spinner-wrap">
          <span class="ac-spinner" aria-hidden="true"></span>
          <p>Un momento…</p>
        </div>
      </div>

      <!-- Estado: link enviado -->
      <div id="ac-success-state" style="display:none">
        <div class="ac-success-icon" aria-hidden="true">✅</div>
        <h2 class="ac-title">¡Listo! Revisá tu casilla</h2>
        <p class="ac-sub">
          Te enviamos un link de acceso a <strong id="ac-email-confirm"></strong>.
          Hacé clic en el link del email para ingresar.
        </p>
        <p class="ac-hint">No lo encontrás? Revisá en spam o <button class="ac-link-btn" id="ac-retry-btn">volvé a intentarlo</button>.</p>
      </div>

      <!-- Estado: ya logueado -->
      <div id="ac-logged-state" style="display:none">
        <div class="ac-success-icon" aria-hidden="true">👋</div>
        <h2 class="ac-title">Ya estás adentro</h2>
        <p class="ac-sub" id="ac-logged-msg">Estás autenticado.</p>
        <a href="/blog/" class="ac-btn ac-btn-outline">Ir al blog</a>
        <p class="ac-hint">
          ¿No sos vos? <button class="ac-link-btn" id="ac-signout-btn">Cerrar sesión</button>
        </p>
      </div>

    </div>
  </section>
</BaseLayout>

<style>
.acceso-wrap {
  min-height: 80vh;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 120px 20px 80px;
  background: var(--gris-bg, #F9FAFB);
}
.acceso-card {
  background: var(--blanco, #fff);
  border: 1px solid var(--borde, #E5E7EB);
  border-radius: 16px;
  padding: 48px 40px;
  max-width: 420px;
  width: 100%;
  box-shadow: 0 4px 24px rgba(0,0,0,.06);
  text-align: center;
}
.ac-icon {
  width: 56px;
  height: 56px;
  background: #E8F5E9;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 20px;
}
.ac-title {
  font-family: 'Montserrat', sans-serif;
  font-size: 1.35rem;
  font-weight: 800;
  color: var(--gris-1, #1A1A1A);
  margin-bottom: 8px;
}
.ac-sub {
  font-size: .95rem;
  font-weight: 300;
  color: var(--gris-2, #555);
  line-height: 1.6;
  margin-bottom: 24px;
}
.ac-field {
  display: flex;
  flex-direction: column;
  gap: 6px;
  text-align: left;
  margin-bottom: 14px;
}
.ac-field label {
  font-size: 12px;
  font-weight: 600;
  color: var(--gris-2);
  letter-spacing: .4px;
}
.ac-field input {
  background: var(--blanco);
  border: 1px solid var(--borde);
  border-radius: 8px;
  padding: 11px 14px;
  font-family: 'Poppins', sans-serif;
  font-size: 14px;
  font-weight: 300;
  color: var(--gris-1);
  outline: none;
  transition: border-color .2s;
  width: 100%;
  box-sizing: border-box;
}
.ac-field input:focus { border-color: #2E7D33; }
.ac-field input:focus-visible { outline: 2px solid #2E7D33; outline-offset: 2px; }
.ac-error {
  font-size: 12px;
  color: var(--rojo, #D32F2F);
  margin-bottom: 10px;
  text-align: left;
}
.ac-btn {
  display: block;
  width: 100%;
  padding: 13px 20px;
  background: #2E7D33;
  color: #fff;
  border: none;
  border-radius: 10px;
  font-family: 'Montserrat', sans-serif;
  font-weight: 700;
  font-size: .85rem;
  letter-spacing: .5px;
  text-transform: uppercase;
  cursor: pointer;
  transition: background .2s;
  text-decoration: none;
  text-align: center;
}
.ac-btn:hover { background: #1B5E20; }
.ac-btn:focus-visible { outline: 2px solid #2E7D33; outline-offset: 3px; }
.ac-btn-outline {
  background: transparent;
  color: #2E7D33;
  border: 2px solid #2E7D33;
}
.ac-btn-outline:hover { background: #E8F5E9; }
.ac-hint {
  font-size: 12px;
  font-weight: 300;
  color: var(--gris-3, #9CA3AF);
  margin-top: 16px;
  line-height: 1.6;
}
.ac-hint a, .ac-link-btn {
  color: #2E7D33;
  font-weight: 500;
  background: none;
  border: none;
  cursor: pointer;
  font-size: inherit;
  padding: 0;
  text-decoration: underline;
}
.ac-link-btn:hover { color: #1B5E20; }
.ac-spinner-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12px;
  padding: 20px 0;
  color: var(--gris-3);
  font-size: 14px;
  font-weight: 300;
}
.ac-spinner {
  display: inline-block;
  width: 24px;
  height: 24px;
  border: 3px solid rgba(46,125,51,.2);
  border-top-color: #2E7D33;
  border-radius: 50%;
  animation: spin .7s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }
.ac-success-icon { font-size: 2.5rem; margin-bottom: 12px; }

@media (max-width: 480px) {
  .acceso-card { padding: 32px 20px; }
}
</style>

<script>
  import { createClient } from '@supabase/supabase-js';

  const supabase = createClient(
    import.meta.env.PUBLIC_SUPABASE_URL,
    import.meta.env.PUBLIC_SUPABASE_KEY
  );

  const EMAIL_RE = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

  const loginState   = document.getElementById('ac-login-state')!;
  const magicState   = document.getElementById('ac-magic-state')!;
  const loadingState = document.getElementById('ac-loading-state')!;
  const successState = document.getElementById('ac-success-state')!;
  const loggedState  = document.getElementById('ac-logged-state')!;
  const loggedMsg    = document.getElementById('ac-logged-msg')!;
  const emailConfirm = document.getElementById('ac-email-confirm')!;

  const ALL_STATES = [loginState, magicState, loadingState, successState, loggedState];
  function show(el: HTMLElement) {
    ALL_STATES.forEach(s => s.style.display = 'none');
    el.style.display = 'block';
  }

  function getNextParam(): string {
    return new URLSearchParams(window.location.search).get('next') ?? '/blog/';
  }

  async function handleSession(session: any) {
    const email = session.user.email ?? '';
    await supabase.rpc('upsert_web_profile', { p_email: email });
    const { data: profile } = await supabase
      .from('web_profiles')
      .select('onboarding_completado')
      .eq('auth_user_id', session.user.id)
      .maybeSingle();
    const next = getNextParam();
    window.location.href = !profile?.onboarding_completado
      ? `/bienvenida/?next=${encodeURIComponent(next)}`
      : next;
  }

  // INITIAL_SESSION: si ya estaba logueado → "Ya estás adentro"
  // SIGNED_IN: retorno del magic link o login exitoso → redirigir
  const saved = localStorage.getItem('sigm_email');
  if (saved) {
    const emailEl = document.getElementById('ac-email') as HTMLInputElement;
    const magicEl = document.getElementById('ac-magic-email') as HTMLInputElement;
    if (emailEl) emailEl.value = saved;
    if (magicEl) magicEl.value = saved;
  }

  supabase.auth.onAuthStateChange(async (event, session) => {
    if (event === 'INITIAL_SESSION') {
      if (session) {
        loggedMsg.textContent = `Autenticado como ${session.user.email}.`;
        show(loggedState);
      }
      // sin sesión: el login form ya está visible (por defecto)
    } else if (event === 'SIGNED_IN' && session) {
      await handleSession(session);
    }
  });

  // ── Login con email + contraseña ─────────────────────────────────────────
  const loginForm  = document.getElementById('ac-login-form') as HTMLFormElement;
  const loginError = document.getElementById('ac-login-error')!;

  loginForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const email    = (document.getElementById('ac-email') as HTMLInputElement).value.trim();
    const password = (document.getElementById('ac-password') as HTMLInputElement).value;

    if (!EMAIL_RE.test(email) || !password) {
      loginError.textContent = 'Completá email y contraseña.';
      loginError.style.display = 'block';
      return;
    }

    loginError.style.display = 'none';
    show(loadingState);

    const { error } = await supabase.auth.signInWithPassword({ email, password });

    if (error) {
      show(loginState);
      const isCredentials = error.message?.toLowerCase().includes('invalid') || error.status === 400;
      loginError.textContent = isCredentials
        ? 'Email o contraseña incorrectos. Si es tu primera vez, accedé con link al email.'
        : `Error: ${error.message}`;
      loginError.style.display = 'block';
      return;
    }

    localStorage.setItem('sigm_email', email);
    // onAuthStateChange SIGNED_IN se dispara y redirige
  });

  // ── Magic link (primera vez / recuperar acceso) ──────────────────────────
  const magicForm  = document.getElementById('ac-magic-form') as HTMLFormElement;
  const magicError = document.getElementById('ac-magic-error')!;

  magicForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const email = (document.getElementById('ac-magic-email') as HTMLInputElement).value.trim();

    if (!EMAIL_RE.test(email)) {
      magicError.textContent = 'Ingresá un email válido.';
      magicError.style.display = 'block';
      return;
    }

    magicError.style.display = 'none';
    show(loadingState);

    const next = getNextParam();
    const redirectTo = `${window.location.origin}/acceso/?next=${encodeURIComponent(next)}`;
    const { error } = await supabase.auth.signInWithOtp({ email, options: { emailRedirectTo: redirectTo } });

    if (error) {
      show(magicState);
      const isRateLimit = error.status === 429 || error.message?.toLowerCase().includes('rate');
      magicError.textContent = isRateLimit
        ? 'Límite de envíos alcanzado. Esperá unos minutos y volvé a intentarlo.'
        : `Error: ${error.message}`;
      magicError.style.display = 'block';
      return;
    }

    localStorage.setItem('sigm_email', email);
    emailConfirm.textContent = email;
    show(successState);
  });

  // ── Toggles entre estados ────────────────────────────────────────────────
  document.getElementById('ac-to-magic-btn')?.addEventListener('click', () => {
    loginError.style.display = 'none';
    const email = (document.getElementById('ac-email') as HTMLInputElement)?.value;
    const magicEl = document.getElementById('ac-magic-email') as HTMLInputElement;
    if (email && magicEl) magicEl.value = email;
    show(magicState);
  });

  document.getElementById('ac-to-login-btn')?.addEventListener('click', () => {
    magicError.style.display = 'none';
    const email = (document.getElementById('ac-magic-email') as HTMLInputElement)?.value;
    const loginEl = document.getElementById('ac-email') as HTMLInputElement;
    if (email && loginEl) loginEl.value = email;
    show(loginState);
  });

  document.getElementById('ac-retry-btn')?.addEventListener('click', () => show(magicState));

  document.getElementById('ac-signout-btn')?.addEventListener('click', async () => {
    await supabase.auth.signOut();
    localStorage.removeItem('sigm_email');
    show(loginState);
  });
</script>
