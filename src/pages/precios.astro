---
import BaseLayout from '../layouts/BaseLayout.astro';
import { APP_URL, onboardingUrl } from '../config/site';

const planes = [
  { slug: 'trial',                nombre: 'Trial',                short: 'Trial' },
  { slug: 'profesional-inicial',  nombre: 'Profesional\nInicial',  short: 'Prof. Inicial' },
  { slug: 'profesional-avanzado', nombre: 'Profesional\nAvanzado', short: 'Prof. Avanzado' },
  { slug: 'consultora-chica',     nombre: 'Consultora\nChica',     short: 'C. Chica' },
  { slug: 'consultora-media',     nombre: 'Consultora\nMedia',     short: 'C. Media' },
  { slug: 'consultora-grande',    nombre: 'Consultora\nGrande',    short: 'C. Grande' },
  { slug: 'empresa',              nombre: 'Empresa',              short: 'Empresa' },
];

type Cell = string | boolean;

interface FeatureRow {
  label: string;
  values: Cell[]; // [trial, inicial, avanzado, chica, media, grande, empresa]
}
interface FeatureGroup {
  group: string;
  rows: FeatureRow[];
}

// Programa Fundadores
const FOUNDER_DISCOUNT = 20;  // % de descuento de por vida
const FOUNDER_CUPOS = 8;      // cupos totales por plan

interface Plan {
  mensual: number | null;
  anual_mes: number | null;
  porUsuario: number | null;
  colab: number | null;
  empresas: number | null;          // null = ilimitadas
  establecimientos: number | null;  // null = ilimitados
  gratis: boolean;
  empresa: boolean;
  founders: number | null;          // cupos Fundador disponibles — fallback estático
}

const precios: Plan[] = [
  { mensual: null,   anual_mes: null,   porUsuario: null,  colab: null, empresas: 2,    establecimientos: 5,    gratis: true,  empresa: false, founders: null },
  { mensual: 24000,  anual_mes: 19200,  porUsuario: 24000, colab: 1,    empresas: 10,   establecimientos: 40,   gratis: false, empresa: false, founders: 5 },
  { mensual: 33600,  anual_mes: 26880,  porUsuario: 33600, colab: 1,    empresas: 20,   establecimientos: 80,   gratis: false, empresa: false, founders: 6 },
  { mensual: 115000, anual_mes: 92000,  porUsuario: 23000, colab: 5,    empresas: 30,   establecimientos: 60,   gratis: false, empresa: false, founders: 4 },
  { mensual: 228000, anual_mes: 182400, porUsuario: 22800, colab: 10,   empresas: 60,   establecimientos: 120,  gratis: false, empresa: false, founders: 5 },
  { mensual: 430000, anual_mes: 344000, porUsuario: 21500, colab: 20,   empresas: 120,  establecimientos: 240,  gratis: false, empresa: false, founders: 6 },
  { mensual: null,   anual_mes: null,   porUsuario: null,  colab: null, empresas: null, establecimientos: null, gratis: false, empresa: true,  founders: null },
];

// Cupos en vivo desde el endpoint de la app (con fallback a datos estáticos)
interface CuposPlan {
  slug: string;
  cupos_disponibles: number;
}
let cuposVivo: CuposPlan[] = [];
try {
  const res = await fetch(`${APP_URL}/api/fundadores/cupos`, {
    headers: { 'Accept': 'application/json' },
  });
  if (res.ok) {
    const data = await res.json() as { planes: CuposPlan[] };
    cuposVivo = data.planes ?? [];
  }
} catch {
  // Fallback silencioso: se usan los datos estáticos de `precios`
}

// Helper para obtener cupos de un plan (prioriza datos vivos, cae en estático)
function getCupos(slug: string, staticFounders: number | null): number | null {
  const vivo = cuposVivo.find(p => p.slug === slug);
  if (vivo !== undefined) return vivo.cupos_disponibles;
  return staticFounders;
}

function fmt(n: number) {
  return n.toLocaleString('es-AR');
}
function perEmpresa(p: Plan): string {
  if (!p.mensual || !p.empresas) return '—';
  return '$' + fmt(Math.round(p.mensual / p.empresas));
}
function perEstablec(p: Plan): string {
  if (!p.mensual || !p.establecimientos) return '—';
  return '$' + fmt(Math.round(p.mensual / p.establecimientos));
}
// Estimado de precio de lista al segundo año (+30% por nuevas funcionalidades, luego ajusta por IPC)
const AJUSTE_ANIO_2 = 0.30;
function perAnio2(p: Plan): string {
  if (p.empresa) return 'A consultar';
  if (p.gratis || !p.mensual) return '—';
  return '$' + fmt(Math.round(p.mensual * (1 + AJUSTE_ANIO_2)));
}

const features: FeatureGroup[] = [
  {
    group: 'Precio',
    rows: [
      { label: 'Precio mensual (neto + IVA 21%) — año 1', values: ['Gratis', '$24.000', '$33.600', '$115.000', '$228.000', '$430.000', 'A consultar'] },
      { label: 'Precio anual mensualizado (−20%)', values: ['—',      '$19.200', '$26.880', '$92.000',  '$182.400', '$344.000', 'A consultar'] },
      { label: 'Precio por empresa / mes',          values: precios.map(perEmpresa) },
      { label: 'Precio por establecimiento / mes',  values: precios.map(perEstablec) },
      { label: 'Período de prueba gratuita',        values: ['1 mes', '1 mes', '1 mes', '1 mes', '1 mes', '1 mes', '1 mes'] },
    ],
  },
  {
    group: 'Límites',
    rows: [
      { label: 'Empresas cliente',        values: ['2',   '10',         '20',         '30',         '60',         '120',        'Ilimitadas'] },
      { label: 'Establecimientos',        values: ['5',   '40',         '80',         '60',         '120',        '240',        'Ilimitados'] },
      { label: 'Gestiones registradas',   values: ['200', 'Ilimitadas', 'Ilimitadas', 'Ilimitadas', 'Ilimitadas', 'Ilimitadas', 'Ilimitadas'] },
      { label: 'Colaboradores en equipo', values: [false, false,        false,        'Hasta 5',    'Hasta 10',   'Hasta 20',   'Ilimitados'] },
    ],
  },
  {
    group: 'Módulos de la plataforma',
    rows: [
      { label: 'Gestión documental y vencimientos',       values: [true,  true,  true,  true,  true,  true,  true] },
      { label: 'Seguimiento de desvíos con trazabilidad', values: [true,  true,  true,  true,  true,  true,  true] },
      { label: 'Capacitaciones digitales con evidencias', values: [true,  true,  true,  true,  true,  true,  true] },
      { label: 'Matriz de riesgos dinámica',              values: [true,  true,  true,  true,  true,  true,  true] },
      { label: 'App de campo para operarios',             values: [false, true,  true,  true,  true,  true,  true] },
      { label: 'KPIs y reportes ejecutivos',              values: [true,  true,  true,  true,  true,  true,  true] },
      { label: 'Exportación de datos (PDF / Excel)',      values: [false, true,  true,  true,  true,  true,  true] },
    ],
  },
  {
    group: 'Equipo y colaboración',
    rows: [
      { label: 'Múltiples usuarios / colaboradores', values: [false, false, false, true, true, true, true] },
      { label: 'Roles y permisos diferenciados',     values: [false, false, false, true, true, true, true] },
      { label: 'Add-on seat extra',                  values: [false, false, false, '$23.000/seat', '$22.800/seat', '$21.500/seat', 'A consultar'] },
    ],
  },
  {
    group: 'Soporte y onboarding',
    rows: [
      { label: 'Soporte por WhatsApp',             values: [true,  true,  true,  true,  true,  true,  true] },
      { label: 'Documentación y autoservicio',     values: [true,  true,  true,  true,  true,  true,  true] },
      { label: 'Onboarding guiado (videollamada)', values: [false, false, false, true,  true,  true,  true] },
      { label: 'Onboarding personalizado in situ', values: [false, false, false, false, false, false, true] },
      { label: 'SLA de soporte prioritario',       values: [false, false, false, false, false, false, true] },
      { label: 'Capacitación del equipo incluida', values: [false, false, false, false, false, false, true] },
    ],
  },
];

const destacado = [false, false, false, true, false, false, false];

// Índices de planes: [trial, prof. inicial, prof. avanzado, consultora chica, consultora media, consultora grande, empresa]
const coreIndices = [0, 1, 3, 4]; // trial + profesional inicial + consultora chica (destacado) + consultora media
const restIndices = [2, 5, 6];    // profesional avanzado + consultora grande + empresa — detrás de "Ver todos los planes"

// CTA por plan. `dynamic: true` = el href se recalcula en el cliente en sincro con los
// toggles Mensual/Anual y Precio Fundador (ver <script> al final). El href de acá abajo
// es el estado inicial: Mensual, sin Fundador (coincide con el precio que se ve al cargar).
const ctas = [
  { label: 'Empezar gratis', href: onboardingUrl({ plan: 'trial' }),                             ext: true,  dynamic: false },
  { label: 'Elegir plan',    href: onboardingUrl({ plan: 'profesional-inicial',  ciclo: 'monthly' }), ext: true,  dynamic: true },
  { label: 'Elegir plan',    href: onboardingUrl({ plan: 'profesional-avanzado', ciclo: 'monthly' }), ext: true,  dynamic: true },
  { label: 'Elegir plan',    href: onboardingUrl({ plan: 'consultora-chica',     ciclo: 'monthly' }), ext: true,  dynamic: true },
  { label: 'Elegir plan',    href: onboardingUrl({ plan: 'consultora-media',     ciclo: 'monthly' }), ext: true,  dynamic: true },
  { label: 'Elegir plan',    href: onboardingUrl({ plan: 'consultora-grande',    ciclo: 'monthly' }), ext: true,  dynamic: true },
  { label: 'Contactar',      href: '/contacto/?s=s4&funnel=plan-empresa',                             ext: false, dynamic: false },
];
---

<BaseLayout
  title="Planes y Precios — Gestión HyS SaaS | SIGMETRÍA"
  description="Conocé los planes de SIGMETRÍA HyS: Trial gratis, Profesional (Inicial y Avanzado), Consultora (Chica, Media y Grande) y Empresa. Programa Fundadores con −20% de por vida. Tabla comparativa completa. Precios en ARS + IVA."
>

  <section class="page-hero">
    <div class="page-hero-inner">
      <nav aria-label="Breadcrumb" class="breadcrumb">
        <a href="/">Inicio</a><span>/</span>
        <a href="/plataforma/">Plataforma</a><span>/</span>
        <span>Precios</span>
      </nav>
      <div class="page-hero-badge">Pagos por transferencia · IVA 21% discriminado · Sin permanencia mínima</div>
      <h1>PLANES Y<br><em>PRECIOS</em></h1>
      <p class="hero-sub">Elegí el plan que se adapta a tu consultora. Todos incluyen 1 mes de prueba gratuita y acceso completo a la plataforma.</p>

      <div class="toggles">
        <div class="billing-toggle" id="billing-toggle">
          <button class="toggle-btn active" id="btn-mensual">Mensual</button>
          <button class="toggle-btn" id="btn-anual">
            Anual
            <span class="toggle-badge">−20%</span>
          </button>
        </div>
        <label class="founder-switch">
          <input type="checkbox" id="chk-fundador" />
          <span class="founder-switch-track"><span class="founder-switch-thumb"></span></span>
          <span class="founder-switch-text">🔥 Precio Fundador <strong>−20% extra</strong></span>
        </label>
      </div>
    </div>
  </section>

  <section class="content-section">
    <div class="content-inner">

      <!-- Tarjetas de planes: los 4 planes core, siempre visibles (Hick's Law: pocas opciones al decidir) -->
      <div class="plan-cards">
        {coreIndices.map(i => {
          const plan = planes[i];
          return (
            <div class={`plan-card ${destacado[i] ? 'plan-card-destacado' : ''}`}>
              {destacado[i] && <span class="plan-card-badge">Más elegido</span>}
              <span class="plan-card-nombre">{plan.nombre.replace('\n', ' ')}</span>
              <div class="plan-card-precio">
                {precios[i].gratis ? (
                  <span class="pc-val">Gratis</span>
                ) : precios[i].empresa ? (
                  <span class="pc-val pc-consultar">A consultar</span>
                ) : (
                  <>
                    <span
                      class="pc-val js-precio"
                      data-mensual={precios[i].mensual}
                      data-anual={precios[i].anual_mes}
                    >${fmt(precios[i].mensual!)}</span>
                    <span class="pc-periodo">/mes + IVA</span>
                    {precios[i].porUsuario && (
                      <span
                        class="pc-usuario js-peruser"
                        data-mensual={precios[i].porUsuario}
                        data-anual={Math.round(precios[i].anual_mes! / precios[i].colab!)}
                        data-colab={precios[i].colab}
                      >${fmt(precios[i].porUsuario!)} /usuario{precios[i].colab! > 1 ? ` · ${precios[i].colab} colab.` : ''}</span>
                    )}
                    <span class="pc-fundador-tag hidden">🔥 Precio Fundador</span>
                  </>
                )}
              </div>
              {(() => {
                const cupos = getCupos(plan.slug, precios[i].founders);
                return cupos !== null && cupos > 0 ? (
                  <span class="founder-cupos">🔥 Quedan {cupos} de {FOUNDER_CUPOS} cupos Fundador</span>
                ) : cupos === 0 ? (
                  <span class="founder-cupos founder-cupos-agotado">⚫ Cupos Fundador agotados</span>
                ) : null;
              })()}
              <a
                href={ctas[i].href}
                class={`pc-cta ${destacado[i] ? 'pc-cta-primary' : 'pc-cta-outline'}`}
                data-plan-slug={ctas[i].dynamic ? plan.slug : undefined}
                {...(ctas[i].ext ? { rel: 'noopener' } : {})}
              >{ctas[i].label}</a>
            </div>
          );
        })}
      </div>

      <!-- Micro-reaseguro cerca del punto de decisión (reduce ansiedad de precio) -->
      <p class="pc-reassurance">1 mes gratis · sin tarjeta · sin permanencia</p>

      <!-- Resto de los planes: colapsados por defecto (menos decisiones a la vista) -->
      <details class="plan-cards-more">
        <summary>Ver todos los planes <span class="chev">▾</span></summary>
        <div class="plan-cards plan-cards-rest">
          {restIndices.map(i => {
            const plan = planes[i];
            return (
              <div class={`plan-card ${destacado[i] ? 'plan-card-destacado' : ''}`}>
                {destacado[i] && <span class="plan-card-badge">Más elegido</span>}
                <span class="plan-card-nombre">{plan.nombre.replace('\n', ' ')}</span>
                <div class="plan-card-precio">
                  {precios[i].gratis ? (
                    <span class="pc-val">Gratis</span>
                  ) : precios[i].empresa ? (
                    <span class="pc-val pc-consultar">A consultar</span>
                  ) : (
                    <>
                      <span
                        class="pc-val js-precio"
                        data-mensual={precios[i].mensual}
                        data-anual={precios[i].anual_mes}
                      >${fmt(precios[i].mensual!)}</span>
                      <span class="pc-periodo">/mes + IVA</span>
                      {precios[i].porUsuario && (
                        <span
                          class="pc-usuario js-peruser"
                          data-mensual={precios[i].porUsuario}
                          data-anual={Math.round(precios[i].anual_mes! / precios[i].colab!)}
                          data-colab={precios[i].colab}
                        >${fmt(precios[i].porUsuario!)} /usuario{precios[i].colab! > 1 ? ` · ${precios[i].colab} colab.` : ''}</span>
                      )}
                      <span class="pc-fundador-tag hidden">🔥 Precio Fundador</span>
                    </>
                  )}
                </div>
                {(() => {
                  const cupos = getCupos(plan.slug, precios[i].founders);
                  return cupos !== null && cupos > 0 ? (
                    <span class="founder-cupos">🔥 Quedan {cupos} de {FOUNDER_CUPOS} cupos Fundador</span>
                  ) : cupos === 0 ? (
                    <span class="founder-cupos founder-cupos-agotado">⚫ Cupos Fundador agotados</span>
                  ) : null;
                })()}
                <a
                  href={ctas[i].href}
                  class={`pc-cta ${destacado[i] ? 'pc-cta-primary' : 'pc-cta-outline'}`}
                  data-plan-slug={ctas[i].dynamic ? plan.slug : undefined}
                  {...(ctas[i].ext ? { rel: 'noopener' } : {})}
                >{ctas[i].label}</a>
              </div>
            );
          })}
        </div>
      </details>

      <!-- Cómo evoluciona el precio en el año 2 — info honesta, pero sin gritar en el punto de decisión -->
      <details class="anio2-details">
        <summary>¿Cómo evoluciona el precio en el año 2? <span class="chev">▾</span></summary>
        <div class="anio2-body">
          <p>Al cumplir 12 meses, el precio de lista se actualiza una vez para reflejar las nuevas funcionalidades sumadas durante ese año (estimado <strong>+{Math.round(AJUSTE_ANIO_2 * 100)}%</strong>). A partir de ahí, vuelve a ajustarse mes a mes por IPC, igual que en el año 1. El precio <strong>Fundador queda congelado</strong> y no sufre este ajuste.</p>
          <ul class="anio2-list">
            {planes.map((plan, i) => (
              <li><span class="anio2-plan">{plan.nombre.replace('\n', ' ')}</span><span class="anio2-val">{perAnio2(precios[i])}</span></li>
            ))}
          </ul>
        </div>
      </details>

      <!-- Programa Fundadores -->
      <section class="fundadores">
        <div class="fundadores-head">
          <span class="fundadores-kicker">🔥 Programa Fundadores</span>
          <h2>SÉ DE LOS <em>PRIMEROS</em></h2>
          <p>Los <strong>primeros {FOUNDER_CUPOS}</strong> que contratan cada plan entran como <strong>Fundadores</strong>: precio congelado con descuento de por vida, meses gratis por reseña y acceso anticipado a cada mejora del sistema. Cupos limitados — cuando se agotan, no vuelven.</p>
          <p class="fundadores-tip">💡 Activá <strong>"Precio Fundador"</strong> arriba para ver cuánto pagarías como Fundador en cada plan.</p>
        </div>

        <div class="fundadores-beneficios">
          <div class="fb-card">
            <span class="fb-icon">🔒</span>
            <h3>−{FOUNDER_DISCOUNT}% de por vida</h3>
            <p>El precio Fundador no te sube nunca, aunque actualicemos la lista. Para siempre, mientras tu suscripción siga activa.</p>
          </div>
          <div class="fb-card">
            <span class="fb-icon">🎁</span>
            <h3>Meses gratis por reseña</h3>
            <ul class="fb-bonus">
              <li><strong>Reseña en video</strong> → 3 meses gratis</li>
              <li><strong>Nota en un medio / blog</strong> → 1 mes gratis</li>
              <li><strong>Reseña corta (Google / texto)</strong> → 15 días gratis</li>
            </ul>
          </div>
          <div class="fb-card">
            <span class="fb-icon">🚀</span>
            <h3>Siempre primero</h3>
            <p>Los Fundadores reciben <strong>antes que nadie</strong> cada actualización, función nueva y mejora del sistema. Y tu voz pesa en lo que construimos.</p>
          </div>
          <div class="fb-card">
            <span class="fb-icon">⏳</span>
            <h3>Cupos limitados</h3>
            <p>Solo {FOUNDER_CUPOS} lugares por plan. Mirá cuántos quedan:</p>
            <ul class="fb-cupos">
              {planes.map((plan, i) => {
                const cupos = getCupos(plan.slug, precios[i].founders);
                return cupos !== null ? (
                  <li>
                    <span class="cupo-plan">{plan.nombre.replace('\n', ' ')}</span>
                    <span class={`cupo-num ${cupos === 0 ? 'cupo-num-agotado' : ''}`}>
                      {cupos === 0 ? 'Agotado' : `${cupos}/${FOUNDER_CUPOS}`}
                    </span>
                  </li>
                ) : null;
              })}
            </ul>
          </div>
        </div>

        <div class="fundadores-cta">
          <a href="/fundadores/" class="fundadores-btn">Conocé el Programa Fundadores →</a>
        </div>

        <p class="fundadores-fine">El descuento Fundador se aplica sobre el precio de lista del plan y se mantiene mientras la suscripción siga activa. Los meses de bonus por reseña se acreditan al verificar la publicación y son acumulables.</p>
      </section>

      <!-- Tabla comparativa completa: en mobile queda colapsada (menos sobrecarga); en desktop se ve entera -->
      <details class="compare-details">
        <summary class="compare-summary">Ver comparativa completa <span class="chev">▾</span></summary>
        <h2 class="compare-title">Comparativa completa</h2>
        <div class="compare-wrap">
        <table class="compare-table">
          <thead>
            <tr>
              <th class="col-feature"></th>
              {planes.map((plan, i) => (
                <th class={`col-plan ${destacado[i] ? 'col-destacado' : ''}`}>
                  {destacado[i] && <span class="plan-badge">Más elegido</span>}
                  <span class="th-nombre">{plan.nombre.replace('\n', ' ')}</span>
                </th>
              ))}
            </tr>
          </thead>
          <tbody>
            {features.map(group => (
              <>
                <tr class="group-header">
                  <td colspan={8}>{group.group}</td>
                </tr>
                {group.rows.map(row => (
                  <tr class="feature-row">
                    <td class="feature-label">{row.label}</td>
                    {row.values.map((val, i) => (
                      <td class={`feature-cell ${destacado[i] ? 'cell-destacado' : ''}`}>
                        {val === true  && <span class="check" aria-label="Incluido">✓</span>}
                        {val === false && <span class="cross" aria-label="No incluido">✗</span>}
                        {typeof val === 'string' && val !== '—' && <span class="text-val">{val}</span>}
                        {val === '—' && <span class="dash">—</span>}
                      </td>
                    ))}
                  </tr>
                ))}
              </>
            ))}
          </tbody>
          <tfoot>
            <tr>
              <td class="col-feature"></td>
              {ctas.map((cta, i) => (
                <td class={`col-plan tfoot-cta ${destacado[i] ? 'col-destacado' : ''}`}>
                  <a
                    href={cta.href}
                    class={`th-cta ${destacado[i] ? 'th-cta-primary' : 'th-cta-outline'}`}
                    data-plan-slug={cta.dynamic ? planes[i].slug : undefined}
                    {...(cta.ext ? { rel: 'noopener' } : {})}
                  >
                    {cta.label}
                  </a>
                </td>
              ))}
            </tr>
          </tfoot>
        </table>
        </div>
      </details>

      <!-- Add-on note -->
      <div class="addon-note">
        <span class="addon-icon">➕</span>
        <p>
          ¿Necesitás más colaboradores? Podés agregar <strong>seats adicionales</strong> en los planes Consultora Chica ($23.000 neto/seat/mes), Media ($22.800 neto/seat/mes), Grande ($21.500 neto/seat/mes) y Empresa.
        </p>
      </div>

      <!-- FAQ -->
      <div class="faq-section">
        <h2 class="faq-title">Preguntas frecuentes</h2>
        <div class="faq-grid">
          <div class="faq-item">
            <h3>¿Cómo se paga?</h3>
            <p>Por transferencia bancaria: al elegir el plan te mostramos los datos para transferir. Una vez acreditado el pago <strong>activamos tu cuenta dentro de las 24 hs hábiles</strong> y retomás justo donde estabas. No se requiere tarjeta (Mercado Pago, próximamente).</p>
          </div>
          <div class="faq-item">
            <h3>¿El IVA está incluido?</h3>
