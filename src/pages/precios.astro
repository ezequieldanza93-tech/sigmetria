<script>
import { onboardingUrl } from '../config/site';

const btnMensual  = document.getElementById('btn-mensual');
const btnAnual    = document.getElementById('btn-anual');
const chkFundador = document.getElementById('chk-fundador') as HTMLInputElement | null;

let period: 'mensual' | 'anual' = 'mensual';

function fmtAR(n: number) { return n.toLocaleString('es-AR'); }

function render() {
  const founder = !!chkFundador?.checked;
  const factor = founder ? 0.8 : 1;

  document.querySelectorAll<HTMLElement>('.js-precio').forEach(el => {
    const base = Number(el.dataset[period]);
    el.textContent = '$' + fmtAR(Math.round(base * factor));
  });

  document.querySelectorAll<HTMLElement>('.js-peruser').forEach(el => {
    const base  = Number(el.dataset[period]);
    const colab = Number(el.dataset.colab);
    el.textContent = '$' + fmtAR(Math.round(base * factor)) + ' /usuario' + (colab > 1 ? ` · ${colab} colab.` : '');
  });

  document.querySelectorAll<HTMLElement>('.pc-fundador-tag').forEach(el => el.classList.toggle('hidden', !founder));

  // CRÍTICO (coherencia precio↔CTA): el link "Elegir plan" tiene que llevar EXACTAMENTE
  // el ciclo y el estado Fundador que se está mostrando en pantalla — nunca un valor fijo.
  document.querySelectorAll<HTMLAnchorElement>('[data-plan-slug]').forEach(el => {
    const plan = el.dataset.planSlug!;
    el.href = onboardingUrl({
      plan,
      ciclo: period === 'anual' ? 'annual' : 'monthly',
      fundador: founder,
    });
  });
}

function setPeriod(p: 'mensual' | 'anual') {
  period = p;
  btnMensual?.classList.toggle('active', p === 'mensual');
  btnAnual?.classList.toggle('active', p === 'anual');
  render();
}

btnMensual?.addEventListener('click', () => setPeriod('mensual'));
btnAnual?.addEventListener('click', () => setPeriod('anual'));
chkFundador?.addEventListener('change', render);
render();
</script>
