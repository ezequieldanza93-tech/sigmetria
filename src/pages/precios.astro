---
import BaseLayout from '../layouts/BaseLayout.astro';

const planes = [
  { slug: 'trial',                    nombre: 'Trial',                    short: 'Trial'   },
  { slug: 'profesional-independiente', nombre: 'Profesional\nIndependiente', short: 'Prof. Ind.' },
  { slug: 'consultora-chica',          nombre: 'Consultora\nChica',          short: 'C. Chica' },
  { slug: 'consultora-grande',         nombre: 'Consultora\nGrande',         short: 'C. Grande' },
  { slug: 'empresa',                   nombre: 'Empresa',                  short: 'Empresa' },
];

type Cell = string | boolean;

interface FeatureRow {
  label: string;
  values: [Cell, Cell, Cell, Cell, Cell]; // [trial, pi, cc, cg, empresa]
}
interface FeatureGroup {
  group: string;
  rows: FeatureRow[];
}

const features: FeatureGroup[] = [
  {
    group: 'Precio',
    rows: [
      { label: 'Precio mensual (neto + IVA 21%)',    values: ['Gratis',    '$20.000',   '$68.000',  '$114.000', 'A consultar'] },
      { label: 'Precio anual mensualizado (−20%)',   values: ['—',         '$16.000',   '$54.400',  '$91.200',  'A consultar'] },
      { label: 'Período de prueba gratuita',          values: ['14 días',  '14 días',   '14 días',  '14 días', '14 días'] },
    ],
  },
  {
    group: 'Límites',
    rows: [
      { label: 'Empresas cliente',      values: ['2',    '20',        '30',        '45',         'Ilimitadas'] },
      { label: 'Establecimientos',      values: ['5',    '40',        '80',        'Ilimitados', 'Ilimitados'] },
      { label: 'Gestiones registradas', values: ['200',  'Ilimitadas','Ilimitadas','Ilimitadas', 'Ilimitadas'] },
      { label: 'Colaboradores en equipo', values: [false, false,      'Hasta 3',  'Hasta 5',    'Ilimitados'] },
    ],
  },
  {
    group: 'Módulos de la plataforma',
    rows: [
      { label: 'Gestión documental y vencimientos',      values: [true,  true,  true,  true,  true] },
      { label: 'Seguimiento de desvíos con trazabilidad',values: [true,  true,  true,  true,  true] },
      { label: 'Capacitaciones digitales con evidencias',values: [true,  true,  true,  true,  true] },
      { label: 'Matriz de riesgos dinámica',             values: [true,  true,  true,  true,  true] },
      { label: 'App de campo para operarios',            values: [false, true,  true,  true,  true] },
      { label: 'KPIs y reportes ejecutivos',             values: [true,  true,  true,  true,  true] },
      { label: 'Exportación de datos (PDF / Excel)',     values: [false, true,  true,  true,  true] },
    ],
  },
  {
    group: 'Equipo y colaboración',
    rows: [
      { label: 'Múltiples usuarios / colaboradores',     values: [false, false, true,  true,  true] },
      { label: 'Roles y permisos diferenciados',         values: [false, false, true,  true,  true] },
      { label: 'Add-on seat extra (+$22.700 neto/mes)',  values: [false, false, true,  true,  true] },
    ],
  },
  {
    group: 'Soporte y onboarding',
    rows: [
      { label: 'Soporte por WhatsApp',              values: [true,  true,  true,  true,  true] },
      { label: 'Documentación y autoservicio',      values: [true,  true,  true,  true,  true] },
      { label: 'Onboarding guiado (videollamada)',  values: [false, false, true,  true,  true] },
      { label: 'Onboarding personalizado in situ',  values: [false, false, false, false, true] },
      { label: 'SLA de soporte prioritario',        values: [false, false, false, false, true] },
      { label: 'Capacitación del equipo incluida',  values: [false, false, false, false, true] },
    ],
  },
];

const precios = [
  { mensual: null,    anual_mes: null,   gratis: true,  empresa: false },
  { mensual: 20000,   anual_mes: 16000,  gratis: false, empresa: false },
  { mensual: 68000,   anual_mes: 54400,  gratis: false, empresa: false },
  { mensual: 114000,  anual_mes: 91200,  gratis: false, empresa: false },
  { mensual: null,    anual_mes: null,   gratis: false, empresa: true  },
];

const destacado = [false, false, true, false, false];

const ctas = [
  { label: 'Empezar gratis',  href: 'https://sigmetria-hys.vercel.app/', ext: true  },
  { label: 'Elegir plan',     href: 'https://sigmetria-hys.vercel.app/', ext: true  },
  { label: 'Elegir plan',     href: 'https://sigmetria-hys.vercel.app/', ext: true  },
  { label: 'Elegir plan',     href: 'https://sigmetria-hys.vercel.app/', ext: true  },
  { label: 'Contactar',       href: '/contacto/?s=s4&funnel=plan-empresa', ext: false },
];

function fmt(n: number) {
  return n.toLocaleString('es-AR');
}
---

<BaseLayout
  title="Planes y Precios — Gestión HyS SaaS | SIGMETRÍA"
  description="Conocé los planes de SIGMETRÍA HyS: Trial gratis, Profesional Independiente, Consultora Chica, Consultora Grande y Empresa. Tabla comparativa completa. Precios en ARS + IVA."
>

  <section class="page-hero">
    <div class="page-hero-inner">
      <nav aria-label="Breadcrumb" class="breadcrumb">
        <a href="/">Inicio</a><span>/</span>
        <a href="/plataforma/">Plataforma</a><span>/</span>
        <span>Precios</span>
      </nav>
      <div class="page-hero-badge">Pagos por transferencia · IVA 21% discriminado · Sin permanencia mínima</div>
      <h1>PLANES Y<br><em>PRECIOS</em></h1>
      <p class="hero-sub">Elegí el plan que se adapta a tu consultora. Todos incluyen 14 días de prueba gratuita y acceso completo a la plataforma.</p>

      <div class="billing-toggle" id="billing-toggle">
        <button class="toggle-btn active" id="btn-mensual">Mensual</button>
        <button class="toggle-btn" id="btn-anual">
          Anual
          <span class="toggle-badge">−20%</span>
        </button>
      </div>
    </div>
  </section>

  <section class="content-section">
    <div class="content-inner">

      <!-- Tabla comparativa completa -->
      <div class="compare-wrap">
        <table class="compare-table">
          <thead>
            <tr>
              <th class="col-feature"></th>
              {planes.map((plan, i) => (
                <th class={`col-plan ${destacado[i] ? 'col-destacado' : ''}`}>
                  {destacado[i] && <span class="plan-badge">Más elegido</span>}
                  <span class="th-nombre">{plan.nombre.replace('\n', ' ')}</span>
                  <div class="th-precio">
                    {precios[i].gratis ? (
                      <span class="precio-val">Gratis</span>
                    ) : precios[i].empresa ? (
                      <span class="precio-val precio-consultar">A consultar</span>
                    ) : (
                      <>
                        <span class="precio-val precio-mensual-val" data-show="mensual">
                          ${fmt(precios[i].mensual!)}
                        </span>
                        <span class="precio-val precio-anual-val hidden" data-show="anual">
                          ${fmt(precios[i].anual_mes!)}
                        </span>
                        <span class="precio-periodo precio-mensual-val" data-show="mensual">/mes + IVA</span>
                        <span class="precio-periodo precio-anual-val hidden" data-show="anual">/mes + IVA</span>
                      </>
                    )}
                  </div>
                  <a
                    href={ctas[i].href}
                    class={`th-cta ${destacado[i] ? 'th-cta-primary' : 'th-cta-outline'}`}
                    {...(ctas[i].ext ? { target: '_blank', rel: 'noopener' } : {})}
                  >
                    {ctas[i].label}
                  </a>
                </th>
              ))}
            </tr>
          </thead>
          <tbody>
            {features.map(group => (
              <>
                <tr class="group-header">
                  <td colspan={6}>{group.group}</td>
                </tr>
                {group.rows.map(row => (
                  <tr class="feature-row">
                    <td class="feature-label">{row.label}</td>
                    {row.values.map((val, i) => (
                      <td class={`feature-cell ${destacado[i] ? 'cell-destacado' : ''}`}>
                        {val === true  && <span class="check" aria-label="Incluido">✓</span>}
                        {val === false && <span class="cross" aria-label="No incluido">✗</span>}
                        {typeof val === 'string' && val !== '—' && <span class="text-val">{val}</span>}
                        {val === '—' && <span class="dash">—</span>}
                      </td>
                    ))}
                  </tr>
                ))}
              </>
            ))}
          </tbody>
          <tfoot>
            <tr>
              <td class="col-feature"></td>
              {ctas.map((cta, i) => (
                <td class={`col-plan tfoot-cta ${destacado[i] ? 'col-destacado' : ''}`}>
                  <a
                    href={cta.href}
                    class={`th-cta ${destacado[i] ? 'th-cta-primary' : 'th-cta-outline'}`}
                    {...(cta.ext ? { target: '_blank', rel: 'noopener' } : {})}
                  >
                    {cta.label}
                  </a>
                </td>
              ))}
            </tr>
          </tfoot>
        </table>
      </div>

      <!-- Add-on note -->
      <div class="addon-note">
        <span class="addon-icon">➕</span>
        <p>
          ¿Necesitás más colaboradores? Podés agregar <strong>seats adicionales por $15.000 neto/mes</strong> cada uno en los planes Consultora Chica, Grande y Empresa.
        </p>
      </div>

      <!-- FAQ -->
      <div class="faq-section">
        <h2 class="faq-title">Preguntas frecuentes</h2>
        <div class="faq-grid">
          <div class="faq-item">
            <h3>¿Cómo se paga?</h3>
            <p>Por transferencia bancaria. Una vez acreditado el pago, activamos tu plan automáticamente. No se requiere tarjeta (próximamente Mercado Pago).</p>
          </div>
          <div class="faq-item">
            <h3>¿El IVA está incluido?</h3>
            <p>No. Los precios son <strong>netos</strong>. Se suma IVA 21% en la factura, siempre discriminado: neto, IVA y total por separado.</p>
          </div>
          <div class="faq-item">
            <h3>¿Qué pasa cuando vence el trial?</h3>
            <p>Tenés 7 días adicionales en modo solo lectura. Tus datos quedan intactos. Cuando contratás, retomás desde donde estabas.</p>
          </div>
          <div class="faq-item">
            <h3>¿Puedo cambiar de plan?</h3>
            <p>Sí, en cualquier momento. El upgrade es inmediato. El downgrade aplica al inicio del siguiente período.</p>
          </div>
          <div class="faq-item">
            <h3>¿Hay permanencia mínima?</h3>
            <p>No. Los planes mensuales se pueden dar de baja en cualquier momento. El anual se cobra por adelantado por 12 meses.</p>
          </div>
          <div class="faq-item">
            <h3>¿Mis datos son propios?</h3>
            <p>Completamente. Podés exportar todo en cualquier momento. No retenemos datos si cancelás.</p>
          </div>
        </div>
      </div>

      <div class="cta-banner">
        <h2>¿NO SABÉS QUÉ PLAN <em>TE CONVIENE?</em></h2>
        <p>Te ayudamos a elegir según tu cartera, equipo y necesidades. Sin compromiso.</p>
        <div class="cta-actions">
          <a href="/contacto/?s=s4&funnel=precios-ayuda" class="btn-primary">Hablar con un asesor</a>
          <a href="https://wa.me/5491123496789" class="btn-outline" target="_blank" rel="noopener">WhatsApp</a>
        </div>
      </div>

    </div>
  </section>

</BaseLayout>

<style>
.hero-sub {
  font-size: 15px; font-weight: 300; color: var(--gris-2);
  line-height: 1.8; max-width: 560px; margin: 12px 0 24px;
}

/* Toggle */
.billing-toggle {
  display: inline-flex; background: var(--borde);
  border-radius: 8px; padding: 3px; gap: 2px;
}
.toggle-btn {
  background: transparent; border: none; cursor: pointer;
  font-family: 'Montserrat', sans-serif; font-size: .78rem; font-weight: 600;
  color: var(--gris-2); padding: 7px 18px; border-radius: 6px;
  transition: all .18s; display: flex; align-items: center; gap: 6px;
}
.toggle-btn.active {
  background: #fff; color: var(--gris-1);
  box-shadow: 0 1px 4px rgba(0,0,0,.1);
}
.toggle-badge {
  background: var(--verde); color: #fff; font-size: .6rem; font-weight: 700;
  padding: 2px 6px; border-radius: 10px; letter-spacing: .3px;
}

/* Tabla */
.compare-wrap {
  overflow-x: auto;
  margin-bottom: 32px;
  border-radius: 12px;
  border: 1px solid var(--borde);
  box-shadow: 0 2px 12px rgba(0,0,0,.05);
}
.compare-table {
  width: 100%; border-collapse: collapse;
  table-layout: fixed;
  min-width: 760px;
}

/* Columnas */
.col-feature { width: 30%; }
.col-plan { width: 14%; }

/* Header */
.compare-table thead tr {
  background: var(--blanco);
  border-bottom: 2px solid var(--borde);
}
.compare-table th {
  padding: 20px 14px 16px;
  text-align: center;
  vertical-align: top;
  position: relative;
}
.compare-table th.col-feature {
  text-align: left;
}
.col-destacado {
  background: #F1FAF1;
}

.plan-badge {
  display: block;
  background: var(--verde); color: #fff;
  font-family: 'Montserrat', sans-serif; font-size: .55rem; font-weight: 700;
  letter-spacing: .5px; text-transform: uppercase;
  padding: 3px 10px; border-radius: 10px;
  margin: 0 auto 8px; width: fit-content;
}
.th-nombre {
  display: block;
  font-family: 'Montserrat', sans-serif; font-size: .72rem; font-weight: 700;
  color: var(--gris-1); text-transform: uppercase; letter-spacing: .4px;
  margin-bottom: 10px; line-height: 1.3;
}
.th-precio { margin-bottom: 12px; }
.precio-val {
  display: block;
  font-family: 'Montserrat', sans-serif; font-size: 1.25rem; font-weight: 800;
  color: var(--gris-1); line-height: 1;
}
.precio-consultar { font-size: .9rem; font-weight: 700; color: var(--gris-2); }
.precio-periodo {
  display: block; font-size: .65rem; color: var(--gris-2); font-weight: 400; margin-top: 3px;
}

.th-cta {
  display: block; text-align: center;
  padding: 8px 6px; border-radius: 6px;
  font-family: 'Montserrat', sans-serif; font-size: .65rem; font-weight: 700;
  letter-spacing: .4px; text-transform: uppercase; text-decoration: none;
  transition: all .18s;
}
.th-cta-primary { background: var(--verde); color: #fff; }
.th-cta-primary:hover { background: var(--verde-dark); }
.th-cta-outline { border: 1.5px solid var(--borde); color: var(--gris-2); }
.th-cta-outline:hover { border-color: var(--verde-borde); color: var(--verde); background: var(--verde-light); }

/* Group header */
.group-header td {
  padding: 10px 16px 6px;
  font-family: 'Montserrat', sans-serif; font-size: .58rem; font-weight: 700;
  letter-spacing: .8px; text-transform: uppercase; color: var(--verde-dark);
  background: var(--verde-light);
  border-top: 1px solid var(--verde-borde);
  border-bottom: 1px solid var(--verde-borde);
}

/* Feature rows */
.feature-row { border-bottom: 1px solid var(--borde); }
.feature-row:last-child { border-bottom: none; }
.feature-row:hover { background: #FAFAFA; }

.feature-label {
  padding: 11px 16px;
  font-size: 13px; font-weight: 400; color: var(--gris-2);
  text-align: left; line-height: 1.4;
}
.feature-cell {
  padding: 11px 14px;
  text-align: center; vertical-align: middle;
}
.cell-destacado { background: #F9FCF9; }

.check { color: #2E7D32; font-size: 1rem; font-weight: 700; }
.cross { color: #C62828; font-size: 1rem; font-weight: 700; }
.text-val { font-size: .78rem; font-weight: 600; color: var(--gris-1); }
.dash { color: var(--gris-2); font-size: .85rem; }

/* Footer */
.compare-table tfoot td {
  padding: 14px 14px;
  background: var(--blanco);
  border-top: 2px solid var(--borde);
  text-align: center;
  vertical-align: middle;
}

/* Add-on note */
.addon-note {
  display: flex; align-items: center; gap: 12px;
  background: var(--verde-light); border: 1px solid var(--verde-borde);
  border-radius: 8px; padding: 14px 20px; margin-bottom: 48px;
}
.addon-icon { font-size: 1.2rem; flex-shrink: 0; }
.addon-note p { margin: 0; font-size: 13px; color: var(--gris-2); line-height: 1.5; }

/* FAQ */
.faq-section { margin-bottom: 48px; }
.faq-title {
  font-family: 'Montserrat', sans-serif; font-size: 1rem; font-weight: 700;
  text-transform: uppercase; letter-spacing: .5px; color: var(--gris-1); margin: 0 0 24px;
}
.faq-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
.faq-item {
  padding: 20px; background: var(--blanco);
  border: 1px solid var(--borde); border-radius: 10px;
}
.faq-item h3 {
  font-family: 'Montserrat', sans-serif; font-size: .82rem; font-weight: 700;
  color: var(--gris-1); margin: 0 0 8px;
}
.faq-item p { font-size: 13px; font-weight: 300; color: var(--gris-2); line-height: 1.6; margin: 0; }

.hidden { display: none !important; }

@media (max-width: 900px) { .faq-grid { grid-template-columns: repeat(2, 1fr); } }
@media (max-width: 600px) { .faq-grid { grid-template-columns: 1fr; } }
</style>

<script>
const btnMensual = document.getElementById('btn-mensual');
const btnAnual   = document.getElementById('btn-anual');

function setPeriod(period: string) {
  const isMensual = period === 'mensual';
  btnMensual?.classList.toggle('active', isMensual);
  btnAnual?.classList.toggle('active', !isMensual);
  document.querySelectorAll<HTMLElement>('[data-show="mensual"]').forEach(el => el.classList.toggle('hidden', !isMensual));
  document.querySelectorAll<HTMLElement>('[data-show="anual"]').forEach(el => el.classList.toggle('hidden', isMensual));
}

btnMensual?.addEventListener('click', () => setPeriod('mensual'));
btnAnual?.addEventListener('click', () => setPeriod('anual'));
</script>
