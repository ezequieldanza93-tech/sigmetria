---
import BaseLayout from '../layouts/BaseLayout.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  "name": "SIGMETRÍA HyS",
  "description": "Sistema de gestión operativa basado en HyS, ISO 45001, automatización e IA. Planificamos, ejecutamos, controlamos y medimos en tiempo real — con plataforma propia y presencia en obra.",
  "url": "https://sigmetriahys.com",
  "telephone": "+5491123496789",
  "email": "ezequiel@sigmetriahys.com",
  "areaServed": ["Ciudad Autónoma de Buenos Aires", "Gran Buenos Aires", "Argentina"],
  "address": {
    "@type": "PostalAddress",
    "addressRegion": "Ciudad Autónoma de Buenos Aires",
    "addressCountry": "AR"
  },
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Servicios de Gestión HyS",
    "itemListElement": [
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Higiene y Seguridad para Construcción y Obra — CABA y GBA" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Implementación ISO 45001:2018" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Plataforma SaaS de Gestión HyS" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Mediciones Técnicas en Planta y Obra" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Capacitaciones HyS In Company" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Auditorías y Gap Analysis ISO 45001" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Mantenimiento ISO 45001 Post-Certificación" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Sistemas Enterprise y Dashboards Ejecutivos" } }
    ]
  },
  "sameAs": []
};

const servicios = [
  {
    href: '/servicios/hys-construccion-caba/',
    icon: '🏗️',
    badge: 'Decreto 911/96 · CABA · GBA',
    name: 'HyS Construcción y Obra',
    desc: 'Matriculado disponible, plan firmado y app de campo. Obra documentada en 7 días, lista para AGC, GCBA o SRT.',
    items: ['Matriculado COPIME · Ing. Industrial', 'Plan de seguridad con aviso de obra', 'App de campo para capataces', 'Control de subcontratistas', 'Visitas en obra + soporte continuo'],
  },
  {
    href: '/servicios/iso-45001/implementacion/',
    icon: '📋',
    badge: 'ISO 45001:2018 · 6 meses',
    name: 'Implementación ISO 45001',
    desc: 'Desde cero a certificado en 6 meses. Roadmap por cláusula y plataforma que sobrevive al consultor.',
    items: ['Roadmap por cláusula con avance medible', 'Gap analysis dinámico', 'Documentación adaptable con IA', 'Auditoría sombra previa a la externa', 'Plataforma SaaS post-certificación'],
  },
  {
    href: '/plataforma/',
    icon: '💻',
    badge: 'SaaS · Onboarding en 30 días',
    name: 'Plataforma SaaS HyS',
    desc: 'Planificá, ejecutá, controlá y medí tu sistema completo. Vencimientos automáticos y reportes listos para auditoría.',
    items: ['Gestión documental y vencimientos', 'Seguimiento de desvíos con trazabilidad', 'Capacitaciones digitales con evidencias', 'Matriz de riesgos dinámica', 'App de campo para operarios'],
  },
  {
    href: '/servicios/mediciones/',
    icon: '📐',
    badge: 'Protocolos SRT · CABA · GBA',
    name: 'Mediciones Técnicas',
    desc: 'Iluminación, ruido, carga térmica, puesta a tierra y ergonomía. Informes firmados y carga directa al sistema.',
    items: ['Iluminación en puestos de trabajo', 'Ruido y vibración', 'Carga térmica e índice WBGT', 'Puesta a tierra y continuidad de masas', 'Ergonomía y contaminantes'],
  },
  {
    href: '/servicios/capacitaciones/',
    icon: '🎓',
    badge: 'In company · Registro digital',
    name: 'Capacitaciones In Company',
    desc: 'Trabajo en altura, espacios confinados, riesgo eléctrico y más. Constancias digitales listas para auditoría.',
    items: ['Trabajo en altura', 'Espacios confinados', 'Riesgo eléctrico', 'Uso correcto de EPP', 'Brigada de emergencia'],
  },
  {
    href: '/servicios/auditorias/',
    icon: '🔍',
    badge: 'Gap analysis · Auditoría sombra',
    name: 'Auditorías y Gap Analysis',
    desc: 'Sabé exactamente en qué estado estás antes de la auditoría externa. Gap analysis, auditoría interna y sombra.',
    items: ['Gap analysis ISO 45001', 'Auditoría interna', 'Auditoría sombra pre-externa', 'Hallazgos con plan de acción', 'Preparación para certificadoras'],
  },
  {
    href: '/servicios/iso-45001/mantenimiento/',
    icon: '🔄',
    badge: 'Post-certificación · SaaS',
    name: 'Mantenimiento ISO 45001',
    desc: 'Mantenemos vivo tu sistema post-certificación sin que dependa de nosotros. SaaS + soporte + seguimiento.',
    items: ['SaaS post-certificación activo', 'Auditorías de seguimiento y recertificación', 'Actualización documental continua', 'No conformidades con trazabilidad', 'Soporte continuo'],
  },
  {
    href: '/enterprise/',
    icon: '🖥️',
    badge: 'Enterprise · ERP · IA',
    name: 'Enterprise + Dashboards',
    desc: 'HyS integrado a tu modelo operativo. Dashboards multi-sitio, integraciones con ERP y IA aplicada.',
    items: ['Integración SAP / Oracle / Dynamics', 'Dashboards multi-planta en tiempo real', 'KPIs consolidados por planta', 'Alertas automáticas con escalado', 'Soporte enterprise 24/7 con SLA'],
  },
];
---

<BaseLayout
  title="SIGMETRÍA HyS — Sistema de Gestión HyS | ISO 45001 · Plataforma · CABA y GBA"
  description="No somos una consultora. Somos el sistema de gestión operativa basado en HyS, ISO 45001, automatización e IA. No entregamos carpetas. Dejamos sistema."
  schema={schema}
>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-layout">
      <div class="hero-content">
        <div class="kicker kicker--left">SISTEMA · NO CONSULTORÍA</div>
        <h1 class="hero-title">HYS QUE PLANIFICA, CONTROLA Y <em>MIDE</em></h1>
        <p class="hero-sub">No somos una consultora. Somos el sistema de gestión operativa basado en HyS, ISO 45001, automatización e IA. <strong>No entregamos carpetas. Dejamos sistema.</strong></p>

        <div class="hero-badges">
          <span class="hero-badge">Sistema, no consultoría</span>
          <span class="hero-badge">ISO 45001 en 6 meses</span>
          <span class="hero-badge">Plataforma digital propia</span>
          <span class="hero-badge">CABA · GBA · Argentina</span>
        </div>

        <div class="hero-actions">
          <a href="/contacto/" class="btn-primary">Diagnóstico gratuito</a>
          <a href="/servicios/" class="btn-outline">Ver servicios</a>
        </div>
      </div>
    </div>
  </section>

  <!-- BRAND: SIG + METRÍA -->
  <section class="marca-section" aria-label="Por qué el nombre Sigmetría">
    <div class="marca-inner">
      <div class="marca-etimo">
        <div class="kicker kicker--left">El nombre explica la misión</div>
        <div class="etimo-wrap">
          <div class="etimo-bloque">
            <span class="etimo-sigla">SIG</span>
            <span class="etimo-flecha">→</span>
            <span class="etimo-def">Seguridad</span>
          </div>
          <span class="etimo-plus">+</span>
          <div class="etimo-bloque">
            <span class="etimo-sigla">METRÍA</span>
            <span class="etimo-flecha">→</span>
            <span class="etimo-def">Métricas</span>
          </div>
        </div>
        <blockquote class="marca-slogan">
          "Lo que no registrás, no lo podés medir.<br>Lo que no se mide, no se mejora."
        </blockquote>
      </div>
      <div class="marca-datos">
        <div class="marca-stat">
          <span class="stat-num">80<span class="stat-pct">%</span></span>
          <p class="stat-label">de las empresas en Argentina no tienen un registro digitalizado de sus métricas de gestión HyS.</p>
        </div>
        <p class="marca-context">Venimos a cambiar eso. No con una app predefinida que te forzamos a adoptar, sino <strong>adaptando el sistema a las necesidades reales de tu organización</strong> — con mejora continua bajo los conceptos de la ISO y métricas accionables en tiempo real.</p>
      </div>
    </div>
  </section>

  <!-- SERVICIOS -->
  <section class="sectores-section" id="servicios" aria-label="Servicios y soluciones">
    <div class="sectores-inner">
      <header class="sectores-header">
        <div class="sectores-header-left">
          <div class="kicker kicker--left">Cobertura completa</div>
          <h2 class="sectores-title">SERVICIOS Y <em>SOLUCIONES</em></h2>
        </div>
        <p class="sectores-sub">Ocho servicios especializados integrados en un solo sistema. No son servicios aislados — son partes de una plataforma.</p>
      </header>
      <div class="sectores-grid">
        {servicios.map(s => (
          <article class="sector-card">
            <div class="sector-card-top">
              <span class="sector-icon" aria-hidden="true">{s.icon}</span>
              <div class="sector-badge">{s.badge}</div>
            </div>
            <h3 class="sector-name">{s.name}</h3>
            <p class="sector-desc">{s.desc}</p>
            <ul class="sector-list" aria-label={`Detalle — ${s.name}`}>
              {s.items.map(item => <li>{item}</li>)}
            </ul>
            <a href={s.href} class="sector-cta">Ver detalle →</a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- POR QUÉ SIGMETRÍA -->
  <section class="porque-section" aria-label="Por qué elegirnos">
    <div class="porque-inner">
      <div class="porque-header">
        <div class="kicker">Nuestra diferencia</div>
        <h2 class="porque-title">¿POR QUÉ <em>SIGMETRÍA</em>?</h2>
      </div>
      <div class="porque-grid">
        <div class="porque-item">
          <div class="porque-num">01</div>
          <h3>Sistema, no consultoría</h3>
          <p>Te dejamos el sistema, no carpetas. Tu equipo lo opera sin depender de nosotros. Si el consultor se va mañana, el sistema sigue funcionando.</p>
        </div>
        <div class="porque-item">
          <div class="porque-num">02</div>
          <h3>Datos, no relato</h3>
          <p>Lo que no medís, no lo controlás. KPIs en tiempo real, dashboards accionables y reportes que le hablan al directorio — no narrativas mensuales.</p>
        </div>
        <div class="porque-item">
          <div class="porque-num">03</div>
          <h3>Velocidad real</h3>
          <p>Obra documentada en 7 días. ISO 45001 desde cero en 6 meses. Onboarding de plataforma en 30 días. Promesas con roadmap, no marketing.</p>
        </div>
        <div class="porque-item">
          <div class="porque-num">04</div>
          <h3>ROI tangible</h3>
          <p>El sistema se paga con una multa evitada, una licitación ganada o un accidente que no sucedió. Calculá el ROI con tus números antes de firmar.</p>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
/* HERO */
.hero {
  position: relative;
  z-index: 1;
  padding: 100px 51px 72px;
  background: var(--gris-bg);
  border-bottom: 1px solid var(--borde);
  overflow: hidden;
}
.hero::after {
  content: '';
  position: absolute;
  inset: 0;
  pointer-events: none;
  background-image: repeating-linear-gradient(
    60deg,
    transparent,
    transparent 40px,
    rgba(76,175,80,.03) 40px,
    rgba(76,175,80,.03) 41px
  );
}
.hero-layout {
  position: relative;
  z-index: 1;
  max-width: 860px;
}
.hero-content {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}
.hero-title {
  font-size: clamp(36px, 4.5vw, 62px);
  letter-spacing: 2px;
  color: var(--gris-1);
  margin-bottom: 16px;
  line-height: 1.05;
  animation: fadeUp .6s ease .1s both;
}
.hero-title em {
  font-style: normal;
  color: var(--verde);
}
.hero-sub {
  font-size: 15px;
  font-weight: 300;
  color: var(--gris-2);
  line-height: 1.8;
  margin-bottom: 22px;
  max-width: 560px;
  animation: fadeUp .6s ease .25s both;
}
.hero-sub strong { color: var(--gris-1); font-weight: 600; }
.hero-badges {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
  margin-bottom: 24px;
  animation: fadeUp .6s ease .35s both;
}
.hero-badge {
  background: var(--verde-light);
  border: 1px solid var(--verde-borde);
  color: var(--verde-dark);
  padding: 5px 12px;
  border-radius: 4px;
  font-family: 'Montserrat', sans-serif;
  font-size: .56rem;
  font-weight: 600;
  letter-spacing: 1px;
  text-transform: uppercase;
  display: flex;
  align-items: center;
  gap: 6px;
}
.hero-badge::before { content: '✓'; color: var(--verde); font-weight: 800; }
.hero-actions {
  display: flex;
  gap: 10px;
  flex-wrap: wrap;
  animation: fadeUp .6s ease .45s both;
}

/* SERVICIOS */
.sectores-section {
  position: relative;
  z-index: 1;
  padding: 68px 51px 72px;
  background: var(--blanco);
}
.sectores-inner { max-width: 1200px; margin: 0 auto; }
.sectores-header {
  display: flex;
  align-items: center;
  gap: 48px;
  margin-bottom: 32px;
}
.sectores-header-left { flex-shrink: 0; }
.sectores-title {
  font-size: clamp(36px, 5vw, 56px);
  letter-spacing: 2px;
  color: var(--gris-1);
  line-height: .95;
}
.sectores-title em {
  font-style: normal;
  color: var(--verde);
}
.sectores-sub {
  font-size: 14px;
  font-weight: 300;
  color: var(--gris-2);
  max-width: 380px;
  line-height: 1.75;
}
.sectores-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 14px;
}
.sector-card {
  background: var(--blanco);
  border: 1px solid var(--borde);
  border-radius: 10px;
  padding: 22px 18px 18px;
  display: flex;
  flex-direction: column;
  transition: all .25s;
  position: relative;
  overflow: hidden;
}
.sector-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 3px;
  background: var(--verde);
  transform: scaleX(0);
  transform-origin: left;
  transition: transform .3s;
}
.sector-card:hover {
  border-color: var(--verde-borde);
  transform: translateY(-4px);
  box-shadow: 0 12px 36px rgba(0,0,0,.08);
}
.sector-card:hover::before { transform: scaleX(1); }
.sector-card-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12px;
}
.sector-icon { font-size: 1.8rem; }
.sector-badge {
  font-family: 'Montserrat', sans-serif;
  font-size: .48rem;
  font-weight: 600;
  color: var(--verde-dark);
  background: var(--verde-light);
  border: 1px solid rgba(76,175,80,.2);
  padding: 3px 7px;
  border-radius: 3px;
  letter-spacing: .5px;
  text-transform: uppercase;
  text-align: right;
  line-height: 1.5;
}
.sector-name {
  font-family: 'Montserrat', sans-serif;
  font-size: 14px;
  font-weight: 700;
  letter-spacing: .5px;
  color: var(--gris-1);
  margin-bottom: 8px;
  text-transform: uppercase;
}
.sector-desc {
  font-size: 13px;
  font-weight: 300;
  color: var(--gris-2);
  line-height: 1.65;
  margin-bottom: 14px;
}
.sector-list {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 5px;
  margin-bottom: 16px;
  flex: 1;
}
.sector-list li {
  font-size: 13px;
  font-weight: 300;
  color: var(--gris-3);
  padding-left: 14px;
  position: relative;
  line-height: 1.45;
}
.sector-list li::before {
  content: '—';
  position: absolute;
  left: 0;
  color: var(--verde);
  opacity: .6;
  font-size: .65rem;
}
.sector-cta {
  font-family: 'Montserrat', sans-serif;
  font-size: .58rem;
  font-weight: 700;
  color: var(--verde);
  letter-spacing: .8px;
  text-decoration: none;
  text-transform: uppercase;
  border-top: 1px solid var(--borde);
  padding-top: 12px;
  margin-top: auto;
  transition: all .2s;
  display: flex;
  align-items: center;
  gap: 5px;
}
.sector-cta:hover { color: var(--verde-dark); gap: 9px; }

/* POR QUÉ SIGMETRÍA */
.porque-section {
  position: relative;
  z-index: 1;
  padding: 76px 51px;
  background: var(--gris-bg);
  border-top: 1px solid var(--borde);
}
.porque-inner { max-width: 1200px; margin: 0 auto; }
.porque-header { text-align: center; margin-bottom: 44px; }
.porque-title {
  font-size: clamp(36px, 5vw, 58px);
  letter-spacing: 2px;
  color: var(--gris-1);
}
.porque-title em {
  font-style: normal;
  color: var(--verde);
}
.porque-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16px;
}
.porque-item {
  padding: 24px 20px;
  background: var(--blanco);
  border: 1px solid var(--borde);
  border-radius: 8px;
  transition: all .2s;
}
.porque-item:hover {
  border-color: var(--verde-borde);
  box-shadow: 0 6px 20px rgba(0,0,0,.06);
}
.porque-num {
  font-family: 'Montserrat', sans-serif;
  font-size: 2.2rem;
  font-weight: 800;
  color: var(--verde-light);
  line-height: 1;
  margin-bottom: 12px;
  -webkit-text-stroke: 2px var(--verde-borde);
}
.porque-item h3 {
  font-family: 'Montserrat', sans-serif;
  font-size: 13px;
  font-weight: 700;
  color: var(--gris-1);
  margin-bottom: 10px;
  text-transform: uppercase;
  letter-spacing: .5px;
}
.porque-item p {
  font-size: 13px;
  font-weight: 300;
  color: var(--gris-2);
  line-height: 1.7;
}

/* MARCA: SIG + METRÍA */
.marca-section {
  position: relative;
  z-index: 1;
  padding: 64px 51px;
  background: var(--gris-1);
  border-bottom: 1px solid rgba(255,255,255,.08);
}
.marca-inner {
  max-width: 1100px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 64px;
  align-items: center;
}
.marca-etimo .kicker { color: var(--verde); }
.marca-etimo .kicker::after { background: var(--verde); }
.etimo-wrap {
  display: flex;
  align-items: center;
  gap: 20px;
  margin: 20px 0 24px;
  flex-wrap: wrap;
}
.etimo-bloque {
  display: flex;
  align-items: center;
  gap: 10px;
}
.etimo-sigla {
  font-family: 'Montserrat', sans-serif;
  font-size: clamp(22px, 3vw, 34px);
  font-weight: 800;
  color: var(--verde);
  letter-spacing: 2px;
}
.etimo-flecha {
  font-size: 1.2rem;
  color: rgba(255,255,255,.3);
}
.etimo-def {
  font-family: 'Montserrat', sans-serif;
  font-size: clamp(18px, 2.5vw, 26px);
  font-weight: 300;
  color: rgba(255,255,255,.85);
  letter-spacing: 1px;
}
.etimo-plus {
  font-size: 2rem;
  color: rgba(255,255,255,.2);
  font-weight: 300;
  line-height: 1;
}
.marca-slogan {
  font-size: 14px;
  font-weight: 300;
  color: rgba(255,255,255,.55);
  font-style: italic;
  line-height: 1.8;
  border-left: 3px solid var(--verde);
  padding-left: 16px;
  max-width: 440px;
}
.marca-stat {
  display: flex;
  align-items: baseline;
  gap: 14px;
  margin-bottom: 20px;
  padding-bottom: 20px;
  border-bottom: 1px solid rgba(255,255,255,.1);
}
.stat-num {
  font-family: 'Montserrat', sans-serif;
  font-size: clamp(48px, 6vw, 72px);
  font-weight: 800;
  color: var(--verde);
  line-height: 1;
  flex-shrink: 0;
}
.stat-pct { font-size: .6em; }
.stat-label {
  font-size: 13px;
  font-weight: 300;
  color: rgba(255,255,255,.6);
  line-height: 1.65;
}
.marca-context {
  font-size: 14px;
  font-weight: 300;
  color: rgba(255,255,255,.65);
  line-height: 1.8;
}
.marca-context strong { color: rgba(255,255,255,.9); font-weight: 600; }
@media (max-width: 900px) {
  .marca-section { padding: 52px 24px; }
  .marca-inner { grid-template-columns: 1fr; gap: 36px; }
}

/* RESPONSIVE */
@media (max-width: 1100px) {
  .sectores-grid { grid-template-columns: repeat(2, 1fr); }
  .porque-grid   { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 900px) {
  .hero { padding: 88px 24px 52px; }
  .sectores-section { padding: 52px 24px; }
  .sectores-header { flex-direction: column; align-items: flex-start; gap: 12px; }
  .porque-section   { padding: 54px 24px; }
}
@media (max-width: 600px) {
  .sectores-grid { grid-template-columns: 1fr; }
  .porque-grid   { grid-template-columns: 1fr; }
}
</style>
