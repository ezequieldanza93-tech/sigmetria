---
import BaseLayout from '../layouts/BaseLayout.astro';
import { FEATURES, TRIAL_URL, CANALES } from '../config/site';
import Icon from '../components/Icon.astro';

const garantias = [
  { icon: 'gift',            text: '1 mes gratis, sin tarjeta' },
  { icon: 'ban',              text: 'Sin permanencia — cancelás cuando quieras' },
  { icon: 'database',         text: 'Tus datos son tuyos y los exportás cuando quieras' },
  { icon: 'message-circle',   text: 'Soporte por WhatsApp' },
];

const schema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "SIGMETRÍA HyS",
  "applicationCategory": "BusinessApplication",
  "operatingSystem": "Web",
  "description": "Plataforma SaaS para gestionar Higiene y Seguridad: cargás la recorrida desde el celular, el reporte sale con un botón y ves todos tus clientes y establecimientos en una sola vista.",
  "url": "https://www.sigmetria.com.ar",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "ARS",
    "description": "1 mes de prueba gratis, sin tarjeta"
  },
  "areaServed": "Argentina",
  "sameAs": ["https://www.instagram.com/sigmetria.app"]
};

const servicios = [
  {
    href: '/servicios/hys-construccion-caba/',
    icon: 'hard-hat',
    badge: 'Decreto 911/96 · CABA · GBA',
    name: 'HyS Industrias y Construcciones',
    desc: 'Matriculado disponible, plan firmado y app de campo. Obra documentada en 7 días, lista para AGC, GCBA o SRT.',
    items: ['Matriculado COPIME · Ing. Industrial', 'Plan de seguridad con aviso de obra', 'App de campo para capataces', 'Control de subcontratistas', 'Visitas en obra + soporte continuo'],
  },
  {
    href: '/servicios/iso-45001/implementacion/',
    icon: 'clipboard-list',
    badge: 'ISO 45001:2018 · 6 meses',
    name: 'Implementación ISO 45001',
    desc: 'Desde cero a certificado en 6 meses. Roadmap por cláusula y plataforma que sobrevive al consultor.',
    items: ['Roadmap por cláusula con avance medible', 'Gap analysis dinámico', 'Documentación adaptable con IA', 'Auditoría sombra previa a la externa', 'Plataforma SaaS post-certificación'],
  },
  {
    href: '/plataforma/',
    icon: 'monitor',
    badge: 'SaaS · Onboarding en 30 días',
    name: 'Plataforma SaaS HyS',
    desc: 'Planificá, ejecutá, controlá y medí tu sistema completo. Vencimientos automáticos y reportes listos para auditoría.',
    items: ['Gestión documental y vencimientos', 'Seguimiento de desvíos con trazabilidad', 'Capacitaciones digitales con evidencias', 'Matriz de riesgos dinámica', 'App de campo para operarios'],
  },
  {
    href: '/servicios/mediciones/',
    icon: 'ruler',
    badge: 'Protocolos SRT · CABA · GBA',
    name: 'Mediciones Técnicas',
    desc: 'Iluminación, ruido, carga térmica, puesta a tierra y ergonomía. Informes firmados y carga directa al sistema.',
    items: ['Iluminación en puestos de trabajo', 'Ruido y vibración', 'Carga térmica e índice WBGT', 'Puesta a tierra y continuidad de masas', 'Ergonomía y contaminantes'],
  },
  {
    href: '/servicios/capacitaciones/',
    icon: 'graduation-cap',
    badge: 'In company · Registro digital',
    name: 'Capacitaciones In Company',
    desc: 'Trabajo en altura, espacios confinados, riesgo eléctrico y más. Constancias digitales listas para auditoría.',
    items: ['Trabajo en altura', 'Espacios confinados', 'Riesgo eléctrico', 'Uso correcto de EPP', 'Brigada de emergencia'],
  },
  {
    href: '/servicios/auditorias/',
    icon: 'search',
    badge: 'Gap analysis · Auditoría sombra',
    name: 'Auditorías y Gap Analysis',
    desc: 'Sabé exactamente en qué estado estás antes de la auditoría externa. Gap analysis, auditoría interna y sombra.',
    items: ['Gap analysis ISO 45001', 'Auditoría interna', 'Auditoría sombra pre-externa', 'Hallazgos con plan de acción', 'Preparación para certificadoras'],
  },
  {
    href: '/servicios/iso-45001/mantenimiento/',
    icon: 'refresh-cw',
    badge: 'Post-certificación · SaaS',
    name: 'Mantenimiento ISO 45001',
    desc: 'Mantenemos vivo tu sistema post-certificación sin que dependa de nosotros. SaaS + soporte + seguimiento.',
    items: ['SaaS post-certificación activo', 'Auditorías de seguimiento y recertificación', 'Actualización documental continua', 'No conformidades con trazabilidad', 'Soporte continuo'],
  },
  {
    href: '/enterprise/',
    icon: 'server',
    badge: 'Enterprise · ERP · IA',
    name: 'Enterprise + Dashboards',
    desc: 'HyS integrado a tu modelo operativo. Dashboards multi-sitio, integraciones con ERP y IA aplicada.',
    items: ['Integración SAP / Oracle / Dynamics', 'Dashboards multi-planta en tiempo real', 'KPIs consolidados por planta', 'Alertas automáticas con escalado', 'Soporte enterprise 24/7 con SLA'],
  },
];

// Módulos reales de la app (se muestran cuando FEATURES.servicios = false)
const modulos = [
  { icon: 'clipboard-list', badge: 'Grupo › categoría › gestión', name: 'Gestiones y agenda', desc: 'Planificás cada gestión por establecimiento y la ejecutás desde el celular en obra. Nada se te pasa.', items: ['Planificación por establecimiento', 'Ejecución desde el celular', 'Clasificadas por grupo y categoría', 'Agenda con recordatorios'] },
  { icon: 'camera', badge: 'Foto · responsable · plazo · cierre', name: 'Observaciones con seguimiento', desc: 'Detectás un desvío, lo registrás con foto, le ponés responsable y plazo, le hacés seguimiento y lo cerrás con otra foto.', items: ['Registro con foto en obra', 'Responsable y plazo de corrección', 'Seguimiento hasta el cierre', 'Cierre con evidencia fotográfica'] },
  { icon: 'ruler', badge: 'Protocolos SRT con PDF', name: 'Mediciones con informe automático', desc: 'Medís y cargás en el celular; cuando terminás, el informe sale solo. Se terminó el papel y el Excel.', items: ['Ruido (SRT 85/2012)', 'Iluminación (SRT 84/2012)', 'Puesta a tierra (SRT 900/2015)', 'Carga térmica (SRT 30/2023)'] },
  { icon: 'calendar-clock', badge: 'Alertas automáticas', name: 'Documentación y vencimientos', desc: 'Cargás cada vencimiento una vez y el sistema te avisa antes de que se pase. Dejá de perseguir fechas.', items: ['Documentación centralizada', 'Alertas antes del vencimiento', 'Capacitaciones y EPP', 'Legajo técnico con QR'] },
  { icon: 'triangle-alert', badge: 'IPER dinámica', name: 'Matriz de riesgos', desc: 'Tu matriz IPER viva y versionada, no un Excel muerto que el auditor te objeta.', items: ['Identificación de peligros', 'Evaluación de riesgo', 'Controles y seguimiento', 'Siempre actualizada'] },
  { icon: 'layout-dashboard', badge: 'Consultora › empresa › establecimiento', name: 'Dashboard a 3 niveles', desc: 'Todos tus clientes en una vista. Y tu cliente entra a ver su propio dashboard, gratis.', items: ['Vista por consultora, empresa y sitio', 'KPIs en tiempo real', 'Reportes listos para auditoría', 'Tu cliente lo ve gratis'] },
];
---

<BaseLayout
  title="SIGMETRÍA HyS — La app para gestionar Higiene y Seguridad | Probala gratis"
  description="Plataforma SaaS de gestión de HyS: cargás la recorrida desde el celular y el reporte sale con un botón. Probala un mes gratis, sin tarjeta."
  schema={schema}
>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-layout">
      <div class="hero-left">
        <div class="kicker kicker--left">PLATAFORMA DE GESTIÓN HyS · SaaS</div>
        <h1 class="hero-title">
          <span class="hero-hys">TODA TU<br>GESTIÓN DE HyS</span>
          <span class="hero-claim">EN UNA SOLA <em>APP</em></span>
        </h1>
        <p class="hero-sub">Cargás la recorrida desde el celular, el reporte sale con un botón y ves todos tus clientes y establecimientos en una sola vista. <strong>Probala un mes gratis, sin tarjeta.</strong></p>
        <div class="hero-actions">
          <a href={TRIAL_URL} class="btn-primary">Probá gratis</a>
          <a href="/plataforma/" class="btn-outline">Cómo funciona</a>
        </div>
      </div>
      <div class="hero-right">
        <div class="hero-card">
          <p class="hero-card-label">LA RECORRIDA, DE PUNTA A PUNTA</p>
          <div class="hero-stats">
            <div class="hero-stat">
              <span class="hero-stat-num">1<span class="hero-stat-unit">mes</span></span>
              <span class="hero-stat-text">de prueba gratis, sin tarjeta</span>
            </div>
            <div class="hero-stat">
              <span class="hero-stat-num">3<span class="hero-stat-unit">niveles</span></span>
              <span class="hero-stat-text">consultora › empresa › establecimiento</span>
            </div>
            <div class="hero-stat">
              <span class="hero-stat-num">1<span class="hero-stat-unit">clic</span></span>
              <span class="hero-stat-text">y el reporte de recorrida sale solo</span>
            </div>
          </div>
          <div class="hero-branches">
            <div class="hero-branch">
              <div class="hero-branch-head">
                <span class="hero-branch-icon">①</span>
                <span class="hero-branch-name">Planificás y ejecutás</span>
              </div>
              <ul class="hero-branch-list hero-branch-list--flow">
                <li>Planificás la gestión por establecimiento</li>
                <li>La ejecutás en obra desde el celular</li>
              </ul>
            </div>
            <div class="hero-branch">
              <div class="hero-branch-head">
                <span class="hero-branch-icon">②</span>
                <span class="hero-branch-name">Observás con foto</span>
              </div>
              <ul class="hero-branch-list hero-branch-list--flow">
                <li>Registrás el desvío con foto</li>
                <li>Asignás responsable y plazo de corrección</li>
              </ul>
            </div>
            <div class="hero-branch">
              <div class="hero-branch-head">
                <span class="hero-branch-icon">③</span>
                <span class="hero-branch-name">Seguís y cerrás</span>
              </div>
              <ul class="hero-branch-list hero-branch-list--flow">
                <li>Seguimiento hasta que se corrige</li>
                <li>Cerrás con foto: todo queda registrado</li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SHOWCASE DE PRODUCTO: mostramos el app real (MECLABS: peso 3 en claridad de valor; LIFT: claridad). -->
  <section class="showcase" aria-label="Así se ve la plataforma por dentro">
    <div class="showcase-inner">
      <div class="showcase-head">
        <span class="showcase-kicker">ASÍ SE VE POR DENTRO</span>
        <h2>El sistema, no un PDF de promesas</h2>
        <p>Dashboards en tiempo real, tus clientes en tres niveles y la agenda de gestiones — datos reales, no maquetas.</p>
      </div>
      <figure class="showcase-main">
        <img src="/producto/dashboard.jpeg" alt="Dashboard de Higiene y Seguridad con cumplimiento, días sin accidente, incidentes, inspecciones y observaciones en tiempo real" fetchpriority="high" width="1440" height="900" />
        <figcaption>Dashboard ejecutivo: cumplimiento, días sin accidente, incidentes y observaciones — en vivo.</figcaption>
      </figure>
      <div class="showcase-grid">
        <figure>
          <img src="/producto/cartera.jpeg" alt="Clientes y establecimientos por rubro y ubicación" loading="lazy" width="1440" height="900" />
          <figcaption>Todos tus clientes y establecimientos en una sola vista.</figcaption>
        </figure>
        <figure>
          <img src="/producto/agenda.jpeg" alt="Agenda de gestiones HyS planificadas y ejecutadas por responsable" loading="lazy" width="1440" height="900" />
          <figcaption>Agenda de gestiones: planificás, ejecutás y seguís por responsable.</figcaption>
        </figure>
      </div>
      <div class="showcase-cta">
        <a href={TRIAL_URL} class="btn-primary">Probá gratis — 1 mes, sin tarjeta</a>
      </div>
    </div>
  </section>

  <!-- CONFIANZA: autoridad (Cialdini) + garantías (reduce ansiedad, no hay testimonios inventados) -->
  <section class="confianza-section" aria-label="Respaldo profesional y garantías">
    <div class="confianza-inner">
      <p class="confianza-autoridad">
        <Icon name="shield-check" size={18} />
        Equipo con matrícula COPIME / CPSH · experiencia implementando ISO 45001:2018
      </p>
      <div class="confianza-grid">
        {garantias.map(g => (
          <div class="confianza-item">
            <span class="confianza-icon"><Icon name={g.icon} size={22} /></span>
            <p>{g.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- BRAND: SIG + METRÍA -->
  <section class="marca-section" aria-label="Por qué el nombre Sigmetría">
    <div class="marca-inner">
      <div class="marca-etimo">
        <div class="kicker kicker--left">El nombre explica la misión</div>
        <div class="etimo-wrap">
          <div class="etimo-bloque">
            <span class="etimo-sigla">SIG</span>
            <span class="etimo-flecha">→</span>
            <span class="etimo-def">Seguridad</span>
          </div>
          <span class="etimo-plus">+</span>
          <div class="etimo-bloque">
            <span class="etimo-sigla">METRÍA</span>
            <span class="etimo-flecha">→</span>
            <span class="etimo-def">Métricas</span>
          </div>
        </div>
        <blockquote class="marca-slogan">
          "Lo que no registrás, no lo podés medir.<br>Lo que no se mide, no se mejora."
        </blockquote>
      </div>
      <div class="marca-datos">
        <p class="marca-context">La mayoría de las empresas en Argentina todavía gestiona sus métricas de HyS en papel y Excel, sin un registro digitalizado.</p>
        <p class="marca-context">Venimos a cambiar eso. No con una app predefinida que te forzamos a adoptar, sino <strong>adaptando el sistema a las necesidades reales de tu organización</strong> — con mejora continua bajo los conceptos de la ISO y métricas accionables en tiempo real.</p>
      </div>
    </div>
  </section>

  <!-- MÓDULOS DE LA PLATAFORMA · los servicios quedan detrás del flag FEATURES.servicios -->
  <section class="sectores-section" id="servicios" aria-label="Qué hace la plataforma">
    <div class="sectores-inner">
      <header class="sectores-header">
        <h2 class="sectores-title">
          {FEATURES.servicios ? (<>SERVICIOS Y <em>SOLUCIONES</em></>) : (<>TODO TU SISTEMA DE HyS, <em>EN UNA APP</em></>)}
        </h2>
        <p class="sectores-sub">
          {FEATURES.servicios
            ? 'Ocho servicios integrados en un solo sistema — no aislados, sino partes de una plataforma.'
            : 'Cada cosa que hoy hacés en planillas sueltas, ordenada en una sola plataforma — y conectada de punta a punta.'}
        </p>
      </header>
      <div class={`sectores-grid ${FEATURES.servicios ? '' : 'sectores-grid--mod'}`}>
        {(FEATURES.servicios ? servicios : modulos).map(s => (
          <article class="sector-card">
            <div class="sector-card-top">
              <span class="sector-icon"><Icon name={s.icon} size={30} /></span>
              <div class="sector-badge">{s.badge}</div>
            </div>
            <h3 class="sector-name">{s.name}</h3>
            <p class="sector-desc">{s.desc}</p>
            <ul class="sector-list" aria-label={`Detalle — ${s.name}`}>
              {s.items.map(item => <li>{item}</li>)}
            </ul>
            {s.href && <a href={s.href} class="sector-cta">Ver detalle →</a>}
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- POR QUÉ SIGMETRÍA -->
  <section class="porque-section" aria-label="Por qué elegirnos">
    <div class="porque-inner">
      <div class="porque-header">
        <div class="kicker">Nuestra diferencia</div>
        <h2 class="porque-title">¿POR QUÉ <em>SIGMETRÍA</em>?</h2>
      </div>
      <div class="porque-grid">
        <div class="porque-item">
          <div class="porque-num">01</div>
          <h3>Sistema, no consultoría</h3>
          <p>Te dejamos el sistema, no carpetas. Tu equipo lo opera sin depender de nosotros. Si el consultor se va mañana, el sistema sigue funcionando.</p>
        </div>
        <div class="porque-item">
          <div class="porque-num">02</div>
          <h3>Datos, no relato</h3>
          <p>Lo que no medís, no lo controlás. KPIs en tiempo real, dashboards accionables y reportes que le hablan al directorio — no narrativas mensuales.</p>
        </div>
        <div class="porque-item">
          <div class="porque-num">03</div>
          <h3>Empezás hoy</h3>
          <p>Cargás tu primer cliente en minutos y la recorrida sale en un toque. Sin migración eterna ni implementación de meses: arrancás con un cliente y lo usás en serio.</p>
        </div>
        <div class="porque-item">
          <div class="porque-num">04</div>
          <h3>ROI tangible</h3>
          <p>El sistema se paga con una multa evitada, una licitación ganada o un accidente que no sucedió. Calculá el ROI con tus números antes de firmar.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CIERRE: último prompt antes del footer (recencia + Fogg: motivación alta, prompt claro) -->
  <section class="cierre-section" aria-label="Empezar ahora">
    <div class="cierre-inner">
      <h2 class="cierre-title">EMPEZÁ A MEDIR TU <em>HyS</em> HOY</h2>
      <p class="cierre-sub">Un mes de prueba gratis, sin tarjeta. Cargás tu primer cliente y la recorrida sale en un toque.</p>
      <div class="cierre-actions">
        <a href={TRIAL_URL} class="btn-primary">Probá gratis</a>
        <a href={CANALES.whatsapp} class="btn-outline" target="_blank" rel="noopener">Hablar por WhatsApp</a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
/* HERO */
.hero {
  position: relative;
  z-index: 1;
  padding: 100px 51px 64px;
  background: var(--gris-bg);
  border-bottom: 1px solid var(--borde);
  overflow: hidden;
}
.hero::before {
  content: '';
  position: absolute;
  top: 0; bottom: 0; left: 0;
  width: 3px;
  background: var(--verde);
}
.hero-layout {
  position: relative;
  z-index: 1;
  max-width: 1100px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1fr 300px;
  gap: 48px;
  align-items: center;
}
.hero-left {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}
.hero-title {
  margin-bottom: 18px;
  animation: fadeUp .6s ease .1s both;
}
.hero-hys {
  display: block;
  font-family: 'Montserrat', sans-serif;
  font-size: clamp(46px, 6vw, 82px);
  font-weight: 800;
  letter-spacing: 2px;
  color: var(--verde);
  line-height: .93;
  margin-bottom: 6px;
}
.hero-claim {
  display: block;
  font-family: 'Montserrat', sans-serif;
  font-size: clamp(15px, 1.8vw, 26px);
  font-weight: 700;
  letter-spacing: 1.5px;
  color: var(--gris-2);
  line-height: 1.2;
  text-transform: uppercase;
}
.hero-claim em {
  font-style: normal;
  color: var(--verde);
}
.hero-sub {
  font-size: 15px;
  font-weight: 300;
  color: var(--gris-2);
  line-height: 1.8;
  margin-bottom: 24px;
  max-width: 500px;
  animation: fadeUp .6s ease .25s both;
}
.hero-sub strong { color: var(--gris-1); font-weight: 600; }
.hero-actions {
  display: flex;
  gap: 10px;
  flex-wrap: wrap;
  animation: fadeUp .6s ease .35s both;
}
/* hero right card */
.hero-right { animation: fadeUp .6s ease .2s both; }
.hero-card {
  background: var(--gris-1);
  border-radius: 12px;
  padding: 26px 22px;
}
.hero-card-label {
  font-family: 'Montserrat', sans-serif;
  font-size: .46rem;
  font-weight: 700;
  color: var(--verde);
  letter-spacing: 2px;
  text-transform: uppercase;
  margin-bottom: 20px;
}
.hero-stats {
  display: flex;
  flex-direction: column;
  gap: 14px;
  margin-bottom: 20px;
  padding-bottom: 18px;
  border-bottom: 1px solid rgba(255,255,255,.08);
}
.hero-stat {
  display: flex;
  align-items: center;
  gap: 12px;
}
.hero-stat-num {
  font-family: 'Montserrat', sans-serif;
  font-size: clamp(24px, 2.5vw, 32px);
  font-weight: 800;
  color: var(--verde);
  line-height: 1;
  flex-shrink: 0;
  min-width: 58px;
}
.hero-stat-unit {
  font-size: .55em;
  font-weight: 600;
  color: rgba(76,175,80,.55);
}
.hero-stat-text {
  font-size: 12px;
  font-weight: 300;
  color: rgba(255,255,255,.72);
  line-height: 1.4;
}
.hero-branches {
  border-top: 1px solid rgba(255,255,255,.08);
  padding-top: 16px;
  display: flex;
  flex-direction: column;
}
.hero-branch {
  padding: 9px 0;
  border-bottom: 1px solid rgba(255,255,255,.05);
}
.hero-branch:last-child { border-bottom: none; padding-bottom: 0; }
.hero-branch-head {
  display: flex;
  align-items: center;
  gap: 7px;
  margin-bottom: 6px;
}
.hero-branch-icon { font-size: .85rem; line-height: 1; }
.hero-branch-name {
  font-family: 'Montserrat', sans-serif;
  font-size: .5rem;
  font-weight: 700;
  color: rgba(255,255,255,.65);
  letter-spacing: .5px;
  text-transform: uppercase;
}
.hero-branch-list {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 3px;
  padding-left: 20px;
}
.hero-branch-list li { position: relative; }
.hero-branch-list li::before {
  content: '→';
  position: absolute;
  left: -16px;
  color: var(--verde);
  font-size: .6rem;
  opacity: .45;
  top: 1px;
}
.hero-branch-list a {
  font-size: 11px;
  font-weight: 300;
  color: rgba(255,255,255,.72);
  text-decoration: none;
  transition: color .15s;
}
.hero-branch-list a:hover { color: var(--verde); }
.hero-branch-list--flow li { color: rgba(255,255,255,.5); font-size: 11px; font-weight: 300; line-height: 1.5; }

/* SERVICIOS */
.sectores-section {
  position: relative;
  z-index: 1;
  padding: 36px 51px 72px;
  background: var(--blanco);
}
.sectores-inner { max-width: 1200px; margin: 0 auto; }
.sectores-header {
  display: flex;
  align-items: center;
  gap: 32px;
  margin-bottom: 18px;
}
.sectores-title {
  font-size: clamp(20px, 2.2vw, 30px);
  letter-spacing: 1.5px;
  color: var(--gris-1);
