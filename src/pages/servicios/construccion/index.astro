---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Higiene y Seguridad en Obras de Construcción",
  "description": "Servicios de Higiene y Seguridad para la industria de la construcción en CABA y GBA. Decreto 911/96, seguridad en obra, legajo técnico y gestión ART.",
  "provider": { "@type": "ProfessionalService", "name": "SIGMETRÍA HyS", "url": "https://sigmetria.com.ar" },
  "areaServed": ["Ciudad Autónoma de Buenos Aires", "Gran Buenos Aires"]
};

const subcategorias = [
  { href: '/servicios/construccion/seguridad-en-obra/', icon: '👷', title: 'Seguridad en obra', desc: 'Programa de seguridad, visitas semanales de técnico y legajo técnico de seguridad completo.' },
  { href: '/servicios/construccion/mediciones/', icon: '📐', title: 'Mediciones en obra', desc: 'Iluminación, ruido, vibraciones, puesta a tierra y contaminantes según normativa vigente.' },
  { href: '/servicios/construccion/gestion-normativa/', icon: '📋', title: 'Gestión normativa', desc: 'RAR, RGRL, plan antisiniestral, capacitaciones y presentaciones ante ART para constructoras.' },
  { href: '/servicios/construccion/iso-45001/', icon: '🏅', title: 'ISO 45001 en obra', desc: 'Asesoría e implementación del Sistema de Gestión SST en empresas constructoras. Diagnóstico, documentación y acompañamiento hacia la certificación.' },
];
---

<BaseLayout
  title="Higiene y Seguridad en Construcción | Decreto 911/96 | SIGMETRÍA HyS"
  description="Servicios de Higiene y Seguridad para empresas constructoras en CABA y GBA. Decreto 911/96, programa de seguridad, visitas semanales y legajo técnico."
  schema={schema}
>
  <section class="page-hero">
    <nav aria-label="Breadcrumb" class="breadcrumb">
      <a href="/">Inicio</a><span>/</span>
      <a href="/servicios/">Servicios</a><span>/</span>
      <span>Construcción</span>
    </nav>
    <div class="page-hero-inner hero-split">
      <div class="hero-left">
        <div class="page-hero-badge">Decreto 911/96 · SRT</div>
        <h1>HIGIENE Y SEGURIDAD<br><em>EN CONSTRUCCIÓN</em></h1>
      </div>
      <p class="hero-right">Obras civiles, constructoras e infraestructura. Cumplimiento total del Decreto 911/96. Técnico presente en obra con visitas semanales y legajo completo.</p>
    </div>
  </section>

  <section class="content-section">
    <div class="content-inner">
      <div class="subcats-grid">
        {subcategorias.map(s => (
          <a href={s.href} class="subcat-card">
            <span class="subcat-icon" aria-hidden="true">{s.icon}</span>
            <h2 class="subcat-title">{s.title}</h2>
            <p class="subcat-desc">{s.desc}</p>
            <span class="subcat-cta">Ver detalle →</span>
          </a>
        ))}
      </div>
      <div class="cta-banner">
        <h2>¿TENÉS UNA <em>OBRA EN MARCHA</em>?</h2>
        <p>Contactanos ahora. Podemos incorporarnos a tu obra de forma inmediata con toda la documentación en regla.</p>
        <div class="cta-actions">
          <a href="https://wa.me/5491123496789" class="btn-primary" target="_blank" rel="noopener">💬 Consulta urgente</a>
          <a href="/contacto/" class="btn-outline">Formulario de contacto</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
/* ---- Hero compacto dos columnas ---- */
.page-hero { padding-top: 96px; padding-bottom: 28px; }
.hero-split {
  max-width: 1100px !important;
  display: flex;
  align-items: center;
  gap: 56px;
}
.hero-left { flex-shrink: 0; }
.page-hero h1 { font-size: clamp(28px, 3.8vw, 52px); margin-bottom: 0; }
.hero-right {
  font-size: 15px;
  font-weight: 300;
  color: var(--gris-2);
  line-height: 1.8;
  max-width: 380px;
  margin: 0;
}

/* ---- Grilla 2x2 ---- */
.subcats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16px;
  margin-bottom: 48px;
}
.subcat-card {
  background: var(--blanco);
  border: 1px solid var(--borde);
  border-radius: 12px;
  padding: 28px 24px;
  display: flex;
  flex-direction: column;
  text-decoration: none;
  transition: all .3s;
  position: relative;
  overflow: hidden;
}
.subcat-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 3px;
  background: var(--verde);
  transform: scaleX(0);
  transform-origin: left;
  transition: transform .35s;
}
.subcat-card:hover { background: var(--verde-light); border-color: var(--verde); transform: translateY(-3px); box-shadow: 0 12px 32px rgba(0,0,0,.08); }
.subcat-card:hover::before { transform: scaleX(1); }
.subcat-icon  { font-size: 2rem; margin-bottom: 12px; }
.subcat-title {
  font-family: 'Montserrat', sans-serif;
  font-size: 1rem;
  font-weight: 800;
  letter-spacing: 1px;
  text-transform: uppercase;
  color: var(--gris-1);
  margin-bottom: 8px;
}
.subcat-desc  { font-size: 13px; font-weight: 300; color: var(--gris-2); line-height: 1.7; flex: 1; margin-bottom: 16px; }
.subcat-cta {
  font-family: 'Montserrat', sans-serif;
  font-size: .6rem;
  font-weight: 600;
  color: var(--verde);
  letter-spacing: 1px;
  border-top: 1px solid var(--verde-borde);
  padding-top: 12px;
}

@media (max-width: 900px) {
  .page-hero { padding-top: 96px; padding-bottom: 20px; }
  .hero-split { flex-direction: column; align-items: flex-start; gap: 12px; }
  .hero-right { max-width: 100%; }
}
@media (max-width: 640px) {
  .subcats-grid { grid-template-columns: 1fr; }
}
</style>
