---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const tipos = [
  { icon: '🔍', titulo: 'Gap analysis ISO 45001', desc: 'Evaluación del estado actual contra los requisitos de la norma. Sabés exactamente qué falta, qué está cumplido y cuánto falta para estar listo para certificar.', cta: 'La base de cualquier implementación.' },
  { icon: '📋', titulo: 'Auditoría interna', desc: 'Auditoría formal según criterios ISO 45001. Identificamos no conformidades, oportunidades de mejora y generamos el informe listo para revisión por la dirección.', cta: 'Obligatoria para mantener la certificación.' },
  { icon: '🛡️', titulo: 'Auditoría sombra pre-externa', desc: 'Auditamos con criterio de auditor certificador antes de la auditoría externa. Si hay desvíos, los cerramos. No hay sorpresas el día de la certificación.', cta: 'El diferencial que hace la diferencia.' },
  { icon: '📊', titulo: 'Diagnóstico de HyS operativa', desc: 'Evaluación integral del sistema de gestión HyS más allá de ISO. Identificamos brechas en documentación, capacitaciones, mediciones y procesos operativos.', cta: 'Para saber dónde estás realmente.' },
];
---

<BaseLayout
  title="Auditorías HyS y Gap Analysis ISO 45001 | SIGMETRÍA HyS"
  description="Gap analysis ISO 45001, auditoría interna, auditoría sombra y diagnóstico HyS. Sabé exactamente en qué estado estás antes de la auditoría externa."
>

  <section class="page-hero">
    <div class="page-hero-inner">
      <nav aria-label="Breadcrumb" class="breadcrumb">
        <a href="/">Inicio</a><span>/</span>
        <a href="/servicios/">Servicios</a><span>/</span>
        <span>Auditorías y Gap Analysis</span>
      </nav>
      <div class="page-hero-badge">Gap analysis · Auditoría interna · Auditoría sombra</div>
      <h1>SABÉ EN QUÉ ESTADO ESTÁS<br><em>ANTES DE LA AUDITORÍA</em></h1>
      <p class="hero-sub">La auditoría externa no es el momento para descubrir los desvíos. Es el momento para confirmar que ya los cerraste.</p>
      <div class="hero-ctas">
        <a href="/contacto/" class="btn-primary">Solicitar diagnóstico gratuito</a>
        <a href="https://wa.me/5491123496789" class="btn-outline" target="_blank" rel="noopener">Consulta por WhatsApp</a>
      </div>
    </div>
  </section>

  <section class="content-section">
    <div class="content-inner">

      <div class="tipos-grid">
        {tipos.map(t => (
          <div class="tipo-card">
            <span class="tipo-icon">{t.icon}</span>
            <h2 class="tipo-titulo">{t.titulo}</h2>
            <p class="tipo-desc">{t.desc}</p>
            <p class="tipo-cta-text">{t.cta}</p>
          </div>
        ))}
      </div>

      <div class="cta-banner">
        <h2>DIAGNÓSTICO <em>INICIAL SIN CARGO</em></h2>
        <p>Te decimos en qué estado real estás — sin compromiso de contratación. Si lo que tenés ya está bien, te lo decimos nosotros.</p>
        <div class="cta-actions">
          <a href="/contacto/" class="btn-primary">Solicitar diagnóstico</a>
          <a href="https://wa.me/5491123496789" class="btn-outline" target="_blank" rel="noopener">WhatsApp</a>
        </div>
      </div>

    </div>
  </section>

</BaseLayout>

<style>
.hero-sub { font-size: 15px; font-weight: 300; color: var(--gris-2); line-height: 1.8; max-width: 560px; margin: 12px 0 24px; }
.hero-ctas { display: flex; gap: 12px; flex-wrap: wrap; }
.tipos-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16px;
  margin-bottom: 48px;
}
.tipo-card {
  padding: 28px 24px;
  background: var(--blanco);
  border: 1px solid var(--borde);
  border-radius: 10px;
  transition: all .2s;
}
.tipo-card:hover { border-color: var(--verde-borde); box-shadow: 0 6px 20px rgba(0,0,0,.06); }
.tipo-icon { font-size: 2rem; display: block; margin-bottom: 12px; }
.tipo-titulo { font-family: 'Montserrat', sans-serif; font-size: 15px; font-weight: 700; text-transform: uppercase; letter-spacing: .5px; color: var(--gris-1); margin-bottom: 10px; }
.tipo-desc { font-size: 13px; font-weight: 300; color: var(--gris-2); line-height: 1.75; margin-bottom: 14px; }
.tipo-cta-text {
  font-family: 'Montserrat', sans-serif; font-size: .58rem; font-weight: 600;
  text-transform: uppercase; letter-spacing: 1px; color: var(--verde);
  border-top: 1px solid var(--borde); padding-top: 12px; margin: 0;
}
@media (max-width: 700px) { .tipos-grid { grid-template-columns: 1fr; } }
</style>
