---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Higiene y Seguridad Laboral para Empresas Industriales",
  "description": "Servicios de Higiene y Seguridad para empresas industriales en CABA y GBA. Mediciones técnicas, gestión normativa ante SRT y ART, ISO 45001:2018.",
  "provider": {
    "@type": "ProfessionalService",
    "name": "SIGMETRÍA HyS",
    "url": "https://sigmetria.com.ar"
  },
  "areaServed": ["Ciudad Autónoma de Buenos Aires", "Gran Buenos Aires"],
  "serviceType": "Higiene y Seguridad Laboral"
};

const subcategorias = [
  {
    href: '/servicios/empresas-industriales/mediciones/',
    icon: '📐',
    title: 'Mediciones técnicas',
    desc: 'Iluminación, ruido, vibraciones, estrés térmico, contaminantes ambientales, puesta a tierra y ergonomía.',
  },
  {
    href: '/servicios/empresas-industriales/gestion-normativa/',
    icon: '📋',
    title: 'Gestión normativa',
    desc: 'RAR, RGRL, plan antisiniestral, capacitaciones, planes de emergencia y presentaciones ante ART.',
  },
  {
    href: '/servicios/empresas-industriales/iso-45001/',
    icon: '🏅',
    title: 'ISO 45001:2018',
    desc: 'Diagnóstico, implementación y acompañamiento para certificación del Sistema de Gestión de SST.',
  },
];
---

<BaseLayout
  title="Higiene y Seguridad para Empresas Industriales | SIGMETRÍA HyS"
  description="Servicios de Higiene y Seguridad Laboral para plantas industriales, manufactura y logística en CABA y GBA. Mediciones, gestión SRT/ART e ISO 45001. Profesionales matriculados."
  schema={schema}
>

  <section class="page-hero">
    <div class="page-hero-inner">
      <nav aria-label="Breadcrumb" class="breadcrumb">
        <a href="/">Inicio</a><span>/</span>
        <a href="/servicios/">Servicios</a><span>/</span>
        <span>Empresas Industriales</span>
      </nav>
      <div class="page-hero-badge">Decreto 351/79 · Resoluciones SRT</div>
      <h1>HIGIENE Y SEGURIDAD<br><em>INDUSTRIAL</em></h1>
      <p>Cobertura completa para plantas de producción, manufactura, logística y depósitos. Cumplimiento del Decreto 351/79 y todas las resoluciones SRT vigentes.</p>
    </div>
  </section>

  <section class="content-section">
    <div class="content-inner">
      <header style="text-align:center; margin-bottom:48px;">
        <div class="kicker">Nuestros servicios</div>
        <h2 style="font-size:clamp(32px,4vw,52px);letter-spacing:2px;color:var(--gris-1);">ÁREAS DE <em style="font-style:normal;color:var(--verde);">COBERTURA</em></h2>
      </header>

      <div class="subcats-grid">
        {subcategorias.map(s => (
          <a href={s.href} class="subcat-card">
            <span class="subcat-icon" aria-hidden="true">{s.icon}</span>
            <h2 class="subcat-title">{s.title}</h2>
            <p class="subcat-desc">{s.desc}</p>
            <span class="subcat-cta">Ver detalle →</span>
          </a>
        ))}
      </div>

      <div class="cta-banner">
        <h2>¿TU EMPRESA ESTÁ <em style="font-style:normal;background:linear-gradient(90deg,var(--verde),var(--verde));-webkit-background-clip:text;-webkit-text-fill-color:transparent;">AL DÍA</em>?</h2>
        <p>Consultanos sin cargo. Evaluamos el estado de cumplimiento de tu empresa y te decimos exactamente qué necesitás.</p>
        <div class="cta-actions">
          <a href="https://wa.me/5491123496789" class="btn-primary" target="_blank" rel="noopener">💬 Consulta gratuita</a>
          <a href="/contacto/" class="btn-outline">Formulario de contacto</a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
.subcats-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16px;
  margin-bottom: 60px;
}
.subcat-card {
  background:var(--blanco);
  border: 2px solid var(--verde-borde);
  border-radius: 12px;
  padding: 32px 26px;
  display: flex;
  flex-direction: column;
  text-decoration: none;
  transition: all .3s cubic-bezier(.34,1.3,.64,1);
  position: relative;
  overflow: hidden;
}
.subcat-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 2px;
  background: linear-gradient(90deg, var(--verde), var(--verde));
  transform: scaleX(0);
  transform-origin: left;
  transition: transform .35s;
}
.subcat-card:hover { background:var(--verde-light); border-color: var(--verde); transform: translateY(-5px); box-shadow: 0 20px 48px rgba(0,0,0,0.45); }
.subcat-card:hover::before { transform: scaleX(1); }
.subcat-icon  { font-size: 2.4rem; margin-bottom: 16px; }
.subcat-title {
  font-family: 'Montserrat', sans-serif;
  font-size: 1.1rem;
  font-weight: 800;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  color: var(--gris-1);
  margin-bottom: 10px;
}
.subcat-desc  { font-size: 13px; font-weight: 300; color: var(--gris-2); line-height: 1.7; flex: 1; margin-bottom: 20px; }
.subcat-cta {
  font-family: 'Montserrat', sans-serif;
  font-size: .6rem;
  font-weight: 600;
  color: var(--verde);
  letter-spacing: 1px;
  border-top: 1px solid var(--verde-borde);
  padding-top: 14px;
  transition: gap .2s;
}
@media (max-width: 800px) { .subcats-grid { grid-template-columns: 1fr; } }
</style>
