---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Higiene y Seguridad para Establecimientos Educativos y Recreativos",
  "description": "Servicios de Higiene y Seguridad para colegios, universidades, clubes y centros culturales en CABA y GBA. Ley 5920, planes de emergencia y simulacros.",
  "provider": { "@type": "ProfessionalService", "name": "SIGMETRÍA HyS", "url": "https://www.sigmetria.com.ar" },
  "areaServed": ["Ciudad Autónoma de Buenos Aires", "Gran Buenos Aires"]
};

const subcategorias = [
  { href: '/servicios/educativo-recreativo/planes-de-emergencia/', icon: '🚨', title: 'Planes de emergencia', desc: 'Plan de emergencia y evacuación, planos por planta, formación de brigadas y simulacros. Ley 5920 CABA.' },
  { href: '/servicios/educativo-recreativo/mediciones/', icon: '📐', title: 'Mediciones', desc: 'Iluminación, ruido, estrés térmico, puesta a tierra y ergonomía en aulas y espacios de trabajo.' },
  { href: '/servicios/educativo-recreativo/gestion-normativa/', icon: '📋', title: 'Gestión normativa', desc: 'RAR, RGRL, plan antisiniestral, capacitaciones y Ley de Autoprotección 5920 para CABA.' },
];
---

<BaseLayout
  title="Higiene y Seguridad para Colegios y Clubes | Ley 5920 CABA | SIGMETRÍA HyS"
  description="Servicios de Higiene y Seguridad para establecimientos educativos y recreativos en CABA. Ley 5920, planes de evacuación, simulacros y gestión ante ART."
  schema={schema}
>
  <section class="page-hero">
    <div class="page-hero-inner">
      <nav aria-label="Breadcrumb" class="breadcrumb">
        <a href="/">Inicio</a><span>/</span>
        <a href="/servicios/">Servicios</a><span>/</span>
        <span>Educativo & Recreativo</span>
      </nav>
      <div class="page-hero-badge">Ley 5920 CABA · SRT</div>
      <h1>HIGIENE Y SEGURIDAD<br><em>EDUCATIVO & RECREATIVO</em></h1>
      <p>Colegios, universidades, clubes y centros culturales. Cumplimiento de la Ley de Autoprotección 5920 y normativa vigente para establecimientos educativos en CABA.</p>
    </div>
  </section>

  <section class="content-section">
    <div class="content-inner">
      <div class="subcats-grid">
        {subcategorias.map(s => (
          <a href={s.href} class="subcat-card">
            <span class="subcat-icon" aria-hidden="true">{s.icon}</span>
            <h2 class="subcat-title">{s.title}</h2>
            <p class="subcat-desc">{s.desc}</p>
            <span class="subcat-cta">Ver detalle →</span>
          </a>
        ))}
      </div>
      <div class="cta-banner">
        <h2>¿TU ESTABLECIMIENTO <em style="font-style:normal;background:linear-gradient(90deg,var(--verde),var(--verde));-webkit-background-clip:text;-webkit-text-fill-color:transparent;">CUMPLE LA LEY 5920</em>?</h2>
        <p>La Ley de Autoprotección es obligatoria para todos los establecimientos educativos de CABA. Consultanos y regularizá tu situación.</p>
        <div class="cta-actions">
          <a href="https://wa.me/5491123496789" class="btn-primary" target="_blank" rel="noopener">💬 Consultanos</a>
          <a href="/contacto/" class="btn-outline">Formulario de contacto</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
.subcats-grid { display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-bottom:60px; }
.subcat-card { background:var(--blanco);border:2px solid var(--verde-borde);border-radius:12px;padding:32px 26px;display:flex;flex-direction:column;text-decoration:none;transition:all .3s cubic-bezier(.34,1.3,.64,1);position:relative;overflow:hidden; }
.subcat-card::before { content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,var(--verde),var(--verde));transform:scaleX(0);transform-origin:left;transition:transform .35s; }
.subcat-card:hover { background:var(--verde-light);border-color:var(--verde);transform:translateY(-5px);box-shadow:0 20px 48px rgba(0,0,0,0.45); }
.subcat-card:hover::before { transform:scaleX(1); }
.subcat-icon  { font-size:2.4rem;margin-bottom:16px; }
.subcat-title { font-family:'Montserrat',sans-serif;font-size:1.5rem;letter-spacing:2px;color:var(--gris-1);margin-bottom:10px; }
.subcat-desc  { font-size:13px;font-weight:300;color:var(--gris-2);line-height:1.7;flex:1;margin-bottom:20px; }
.subcat-cta   { font-family:'Montserrat',sans-serif;font-size:.6rem;color:var(--verde);letter-spacing:1px;border-top:1px solid var(--verde-light);padding-top:14px; }
@media(max-width:800px){ .subcats-grid{grid-template-columns:1fr;} }
</style>
