  font-size: 1.25rem;
  font-weight: 800;
  color: var(--gris-1);
  margin: 44px 0 16px;
  line-height: 1.25;
}

.article-body p {
  margin-bottom: 18px;
  font-weight: 300;
}

.article-body a {
  color: #2E7D33;
  text-decoration: underline;
  text-underline-offset: 3px;
}
.article-body a:hover { color: #1B5E20; }

/* ---- Lista ---- */
.art-list {
  margin: 0 0 24px 0;
  padding-left: 0;
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 12px;
}
