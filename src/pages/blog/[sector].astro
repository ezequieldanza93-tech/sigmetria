---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { blogPosts } from '../../data/blog-posts';

interface SectorDef {
  slug: string;
  sectorKey: string;
  label: string;
  badge: string;
  metaTitle: string;
  metaDescription: string;
  h1line1: string;
  h1line2: string;
}

export function getStaticPaths() {
  const defs: SectorDef[] = [
    {
      slug: 'empresas-industriales',
      sectorKey: 'Empresas Industriales',
      label: 'Empresas Industriales',
      badge: 'Decreto 351/79 · SRT',
      metaTitle: 'Higiene y Seguridad para Empresas Industriales | SIGMETRÍA HyS',
      metaDescription: 'Artículos prácticos de H&S para plantas industriales, manufactura y logística en CABA y GBA. Normativa Decreto 351/79, mediciones de ruido y ambiente, EPP y gestión.',
      h1line1: 'H&S PARA EMPRESAS',
      h1line2: 'INDUSTRIALES',
    },
    {
      slug: 'construccion',
      sectorKey: 'Construcción',
      label: 'Construcción',
      badge: 'Decreto 911/96 · Res. SRT',
      metaTitle: 'Seguridad en Construcción — Normativa y EPP | SIGMETRÍA HyS',
      metaDescription: 'Guías de seguridad laboral para constructoras y obras civiles en Buenos Aires. Decreto 911/96, programas de seguridad, mediciones y EPP en obra.',
      h1line1: 'SEGURIDAD EN',
      h1line2: 'CONSTRUCCIÓN',
    },
    {
      slug: 'educativo-recreativo',
      sectorKey: 'Educativo y Recreativo',
      label: 'Educativo & Recreativo',
      badge: 'Ley 5920 CABA · SRT',
      metaTitle: 'H&S en Establecimientos Educativos y Recreativos | SIGMETRÍA HyS',
      metaDescription: 'Normativa de higiene y seguridad para colegios, universidades y clubes en CABA y GBA. Ley 5920, planes de evacuación, mediciones y capacitación.',
      h1line1: 'H&S EN ESTABLECIMIENTOS',
      h1line2: 'EDUCATIVOS',
    },
    {
      slug: 'locales-comerciales',
      sectorKey: 'Comercial y Oficinas',
      label: 'Locales Comerciales',
      badge: 'SRT · ART · Ley 5920',
      metaTitle: 'Higiene y Seguridad para Locales Comerciales y Oficinas | SIGMETRÍA HyS',
      metaDescription: 'Guías de H&S para comercios, restaurantes y oficinas en CABA y GBA. Cumplimiento SRT, mediciones, planes de emergencia y EPP para el sector comercial.',
      h1line1: 'H&S PARA LOCALES',
      h1line2: 'COMERCIALES',
    },
  ];
  return defs.map(d => ({ params: { sector: d.slug }, props: d }));
}

interface Props extends SectorDef {}
const s = Astro.props;

const sectorPosts = blogPosts.filter(p => p.sectores.includes(s.sectorKey));

const categoriasOrder = [
  'Normativa General', 'Normativa CABA', 'Normativa PBA',
  'Mediciones', 'EPP', 'Gestión', 'Emergencias', 'Capacitación',
  'Seguridad', 'Medio Ambiente', 'Sector Comercial', 'Construcción',
];

const grouped = new Map<string, typeof sectorPosts>();
for (const cat of categoriasOrder) {
  const posts = sectorPosts.filter(p => p.categoria === cat);
  if (posts.length > 0) grouped.set(cat, posts);
}
for (const post of sectorPosts) {
  if (!grouped.has(post.categoria)) {
    grouped.set(post.categoria, sectorPosts.filter(p => p.categoria === post.categoria));
  }
}

const schema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: s.metaTitle,
  description: s.metaDescription,
  url: `https://sigmetria.com.ar/blog/${s.slug}/`,
};
---

<BaseLayout title={s.metaTitle} description={s.metaDescription} schema={schema}>

  <section class="page-hero">
    <nav aria-label="Breadcrumb" class="breadcrumb">
      <a href="/">Inicio</a><span>/</span>
      <a href="/blog/">Blog H&S</a><span>/</span>
      <span>{s.label}</span>
    </nav>
    <div class="page-hero-inner">
      <div class="page-hero-badge">{s.badge}</div>
      <h1>{s.h1line1}<br><em>{s.h1line2}</em></h1>
      <p>Artículos prácticos escritos por profesionales. Todo lo que necesitás saber sobre H&S en este sector — sin tecnicismos innecesarios.</p>
    </div>
  </section>

  <section class="content-section">
    <div class="content-inner">

      {sectorPosts.length === 0 ? (
        <div class="empty-sector">
          <p>Próximamente publicamos artículos para este sector.</p>
          <a href="/blog/" class="btn-outline" style="margin-top:20px;display:inline-flex;">← Ver todos los artículos</a>
        </div>
      ) : (
        Array.from(grouped.entries()).map(([categoria, posts]) => (
          <div class="blog-subseccion">
            <div class="subseccion-header">
              <span class="subseccion-kicker">{categoria}</span>
            </div>
            <div class="blog-grid">
              {posts.map(post => (
                <article class="blog-card">
                  <div class="blog-card-meta">
                    <span class="blog-tiempo">{post.tiempoLectura} lectura</span>
                  </div>
                  <h2 class="blog-card-title">
                    <a href={`/blog/${post.slug}/`}>{post.titulo}</a>
                  </h2>
                  <p class="blog-card-resumen">{post.resumen}</p>
                  <div class="blog-card-footer">
                    <div class="blog-tags">
                      {post.tags.slice(0, 3).map(tag => (
                        <span class="blog-tag">{tag}</span>
                      ))}
                    </div>
                    <a href={`/blog/${post.slug}/`} class="blog-read-more">Leer →</a>
                  </div>
                </article>
              ))}
            </div>
          </div>
        ))
      )}

      <div class="cta-banner" style="margin-top:48px;">
        <div class="kicker">¿Necesitás cumplir con H&S?</div>
        <h2>CONSULTANOS <em>SIN CARGO</em></h2>
        <p>Evaluamos el estado de tu empresa y te decimos exactamente qué necesitás. Respuesta en menos de 24 horas hábiles.</p>
        <div class="cta-actions">
          <a href={`https://wa.me/5491123496789?text=Hola%2C%20soy%20del%20sector%20${encodeURIComponent(s.label)}%20y%20necesito%20información%20sobre%20H%26S`} class="btn-primary" target="_blank" rel="noopener">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            Consultar por WhatsApp
          </a>
          <a href="/contacto/" class="btn-outline">Formulario de contacto</a>
        </div>
      </div>

    </div>
  </section>

</BaseLayout>

<style>
.blog-subseccion {
  margin-bottom: 52px;
}
.subseccion-header {
  display: flex;
  align-items: center;
  gap: 16px;
  margin-bottom: 20px;
}
.subseccion-kicker {
  font-family: 'Montserrat', sans-serif;
  font-size: .6rem;
  font-weight: 700;
  color: var(--verde-dark);
  letter-spacing: 2px;
  text-transform: uppercase;
  background: var(--verde-light);
  border: 1px solid var(--verde-borde);
  padding: 5px 14px;
  border-radius: 4px;
}
.subseccion-header::after {
  content: '';
  flex: 1;
  height: 1px;
  background: var(--borde);
}
.empty-sector {
  text-align: center;
  padding: 80px 20px;
  color: var(--gris-3);
  font-size: 14px;
  font-weight: 300;
}
</style>
