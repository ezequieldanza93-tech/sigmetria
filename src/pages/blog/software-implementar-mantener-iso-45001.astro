---
import BaseLayout from '../../layouts/BaseLayout.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": "Software para implementar y mantener viva la ISO 45001 (no solo para certificar)",
  "description": "Software para implementar ISO 45001: ordená, documentá y sostené el sistema vivo entre auditorías. Conocé cómo funciona.",
  "image": "https://sigmetriahys.com/logo-sigmetria.svg",
  "author": {
    "@type": "Organization",
    "name": "SIGMETRÍA HyS",
    "url": "https://sigmetriahys.com"
  },
  "publisher": {
    "@type": "Organization",
    "name": "SIGMETRÍA HyS",
    "logo": {
      "@type": "ImageObject",
      "url": "https://sigmetriahys.com/logo-sigmetria.svg"
    }
  },
  "datePublished": "2026-11-11",
  "dateModified":  "2026-11-11",
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "https://sigmetriahys.com/blog/software-implementar-mantener-iso-45001/"
  },
  "keywords": [
    "software iso 45001",
    "software para mantener iso 45001",
    "mantener sistema iso 45001",
    "gestión de no conformidades iso 45001",
    "seguimiento de observaciones seguridad",
    "revisión por la dirección iso 45001",
    "software gestión de seguridad e higiene"
