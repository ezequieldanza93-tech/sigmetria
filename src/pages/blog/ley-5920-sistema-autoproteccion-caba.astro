.article-body strong { color: rgba(255,255,255,.9); font-weight: 600; }
.art-list { list-style: none; display: flex; flex-direction: column; gap: 8px; padding: 0; }
.art-list li { display: flex; gap: 10px; font-size: 14px; font-weight: 300; color: rgba(255,255,255,.65); line-height: 1.7; }
.art-list li::before { content: '›'; color: var(--celeste); font-size: 1rem; flex-shrink: 0; margin-top: 1px; }
