---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { blogPosts } from '../../data/blog-posts';

const sections = [
  { id: 'cumplimiento',  label: '🏗️ Cumplimiento operativo', categorias: ['Industrias y Construcciones', 'Mediciones', 'Capacitaciones'] },
  { id: 'iso45001',      label: '📋 ISO 45001',               categorias: ['ISO 45001', 'Auditorías'] },
  { id: 'plataforma',    label: '💻 Plataforma y tecnología',  categorias: ['Plataforma HyS'] },
  { id: 'medioambiente', label: '🌿 Medio Ambiente',           categorias: ['Medio Ambiente'] },
];

const catToSectionId: Record<string, string> = {};
sections.forEach(s => s.categorias.forEach(cat => { catToSectionId[cat] = s.id; }));

// Solo se listan los posts no ocultos. Los blogs programados (calendario editorial)
// se cargan con `oculto: true` y se activan cambiando el flag cuando llega su fecha.
const visiblePosts = blogPosts.filter(p => !p.oculto);
---

<BaseLayout
  title="Blog de Higiene y Seguridad Laboral — SIGMETRÍA HyS"
  description="Artículos prácticos sobre normativa SRT, Decreto 351/79, 911/96, EPP y mediciones. Para empresas de CABA y GBA que quieren cumplir y proteger a su equipo."
>
  <section class="page-hero">
    <nav aria-label="Breadcrumb" class="breadcrumb">
      <a href="/">Inicio</a><span>/</span>
      <span>Blog</span>
    </nav>
    <div class="page-hero-inner blog-hero-inner">
      <div class="blog-hero-left">
        <div class="page-hero-badge">Construcción · ISO 45001 · Mediciones · Capacitaciones</div>
        <h1>BLOG DE<br><em>H&amp;S LABORAL</em></h1>
      </div>
      <p class="blog-hero-desc">Artículos prácticos escritos por profesionales. Sin tecnicismos innecesarios — lo que necesitás saber para cumplir y proteger a tu equipo.</p>
    </div>
  </section>

  <section class="content-section">
    <div class="content-inner">

      <!-- Buscador + contador -->
      <div class="blog-toolbar">
        <div class="blog-search-wrap">
          <svg class="blog-search-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          <input
            id="blog-search"
            type="search"
            placeholder="Buscar artículos..."
            autocomplete="off"
            spellcheck="false"
          />
        </div>
        <span class="blog-count" id="blog-count">{visiblePosts.length} artículos</span>
      </div>

      <!-- Filtro de secciones (dropdown) -->
      <div class="filter-area">
        <div class="section-wrap" id="section-wrap">
          <button class="section-btn" id="section-btn" aria-expanded="false">
            <span id="section-label">Todas las secciones</span>
            <svg class="section-chevron" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
          </button>
          <div class="section-panel" id="section-panel">
            <button class="section-opt active" data-sec="todos">Todas las secciones</button>
            {sections.map(s => (
              <button class="section-opt" data-sec={s.id}>{s.label}</button>
            ))}
          </div>
        </div>

        <!-- Filtro de subcategorías -->
        <div class="subcat-row" id="subcat-filters">
          <button class="blog-filter active" data-cat="todos">Todos</button>
          {sections.map(s => s.categorias.map(cat => (
            <button class="blog-filter" data-cat={cat} data-sec={s.id}>{cat}</button>
          )))}
        </div>
      </div>

      <!-- Grid -->
      <div class="blog-grid" id="blog-grid">
        {visiblePosts.map(post => (
          <article
            class="blog-card"
            data-cat={post.categoria}
            data-sec={catToSectionId[post.categoria] ?? ''}
            data-text={`${post.titulo} ${post.resumen} ${post.categoria} ${post.tags.join(' ')}`.toLowerCase()}
          >
            <div class="blog-card-meta">
              <span class="blog-cat">{post.categoria}</span>
              <span class="blog-sep">·</span>
              <span class="blog-tiempo">{post.tiempoLectura} lectura</span>
            </div>
            <h2 class="blog-card-title">
              <a href={`/blog/${post.slug}/`}>{post.titulo}</a>
            </h2>
            <p class="blog-card-resumen">{post.resumen}</p>
            <div class="blog-card-footer">
              <div class="blog-tags">
                {post.tags.slice(0, 3).map(tag => (
                  <span class="blog-tag">{tag}</span>
                ))}
              </div>
              <a href={`/blog/${post.slug}/`} class="blog-read-more">Leer →</a>
            </div>
          </article>
        ))}
      </div>

      <!-- Empty state -->
      <div class="blog-empty" id="blog-empty" style="display:none">
        <p>No hay artículos que coincidan con tu búsqueda.</p>
      </div>

    </div>
  </section>
</BaseLayout>

<style>
/* ---- Hero ---- */
.page-hero {
  padding-top: 100px;
  padding-bottom: 28px;
}
.page-hero h1 {
  font-size: clamp(26px, 3.5vw, 46px);
  margin-bottom: 8px;
}
.page-hero-badge { margin-bottom: 10px; }
.blog-hero-inner {
  max-width: 1100px !important;
  display: flex;
  align-items: center;
  gap: 48px;
}
.blog-hero-left { flex-shrink: 0; }
.blog-hero-desc {
  font-size: 14px;
  font-weight: 300;
  color: var(--gris-2);
  line-height: 1.75;
  max-width: 340px;
  margin: 0;
}
@media (max-width: 900px) {
  .page-hero { padding-top: 96px; padding-bottom: 20px; }
  .blog-hero-inner { flex-direction: column; align-items: flex-start; gap: 10px; }
  .blog-hero-desc { max-width: 100%; }
}

/* ---- Toolbar ---- */
.blog-toolbar {
  display: flex;
  align-items: center;
  gap: 16px;
  margin-bottom: 12px;
  flex-wrap: wrap;
}
.blog-search-wrap {
  position: relative;
  flex: 1;
  min-width: 220px;
}
.blog-search-icon {
  position: absolute;
  left: 12px;
  top: 50%;
  transform: translateY(-50%);
  color: var(--gris-3);
  pointer-events: none;
}
#blog-search {
  width: 100%;
  background: var(--blanco);
  border: 1px solid var(--borde);
  border-radius: 6px;
  padding: 10px 14px 10px 36px;
  font-family: 'Montserrat', sans-serif;
  font-size: .8rem;
  color: var(--gris-1);
  outline: none;
  transition: border-color .2s;
  box-sizing: border-box;
}
#blog-search::placeholder { color: var(--gris-3); }
#blog-search:focus { border-color: var(--verde); }
#blog-search::-webkit-search-cancel-button { cursor: pointer; }
.blog-count {
  font-family: 'Montserrat', sans-serif;
  font-size: .56rem;
  font-weight: 600;
  color: var(--gris-3);
  letter-spacing: .5px;
  white-space: nowrap;
  flex-shrink: 0;
}

/* ---- Filter area ---- */
.filter-area {
  display: flex;
  flex-direction: column;
  gap: 8px;
  margin-bottom: 28px;
}

/* Section dropdown */
.section-wrap {
  position: relative;
  width: fit-content;
}
.section-btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-family: 'Montserrat', sans-serif;
  font-size: .62rem;
  font-weight: 600;
  letter-spacing: .5px;
  text-transform: uppercase;
  color: var(--gris-1);
  background: var(--blanco);
  border: 1px solid var(--borde);
  border-radius: 6px;
  padding: 9px 14px;
  cursor: pointer;
  transition: all .18s;
  white-space: nowrap;
}
.section-btn:hover { border-color: var(--verde-borde); color: var(--verde-dark); }
.section-wrap.open .section-btn {
  border-color: var(--verde);
  color: var(--verde-dark);
  background: var(--verde-light);
}
.section-chevron {
  flex-shrink: 0;
  transition: transform .2s;
}
.section-wrap.open .section-chevron { transform: rotate(180deg); }

.section-panel {
  display: none;
  position: absolute;
  top: calc(100% + 5px);
  left: 0;
  flex-direction: column;
  gap: 2px;
  background: var(--blanco);
  border: 1px solid var(--borde);
  border-radius: 8px;
  box-shadow: 0 8px 28px rgba(0,0,0,.1);
  min-width: 240px;
  padding: 6px;
  z-index: 200;
}
.section-wrap.open .section-panel { display: flex; }

.section-opt {
  font-family: 'Montserrat', sans-serif;
  font-size: .58rem;
  font-weight: 600;
  letter-spacing: .4px;
  text-transform: uppercase;
  text-align: left;
  color: var(--gris-2);
  background: transparent;
  border: 1px solid transparent;
  border-radius: 5px;
  padding: 9px 12px;
  cursor: pointer;
  transition: all .15s;
}
.section-opt:hover {
  background: var(--verde-light);
  color: var(--verde-dark);
}
.section-opt.active {
  background: var(--verde-light);
  color: var(--verde-dark);
  border-color: var(--verde-borde);
}

/* Subcat filter buttons */
.subcat-row {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
}
.blog-filter {
  font-family: 'Montserrat', sans-serif;
  font-size: .56rem;
  font-weight: 600;
  letter-spacing: .6px;
  text-transform: uppercase;
  color: var(--gris-2);
  background: var(--blanco);
  border: 1px solid var(--borde);
  border-radius: 4px;
  padding: 5px 12px;
  cursor: pointer;
  transition: all .18s;
  white-space: nowrap;
}
.blog-filter:hover {
  color: var(--verde);
  border-color: var(--verde-borde);
  background: var(--verde-light);
}
.blog-filter.active {
  color: var(--verde-dark);
  background: var(--verde-light);
  border-color: var(--verde);
}

/* ---- Empty state ---- */
.blog-empty {
  text-align: center;
  padding: 60px 20px;
  color: var(--gris-3);
  font-size: 14px;
  font-weight: 300;
}

@media (max-width: 600px) {
  .blog-toolbar { flex-direction: column; align-items: stretch; }
  .blog-count { text-align: right; }
  .section-wrap { width: 100%; }
  .section-btn { width: 100%; justify-content: space-between; }
  .section-panel { width: 100%; }
}
</style>

<script>
const cards       = Array.from(document.querySelectorAll<HTMLElement>('#blog-grid .blog-card'));
const sectionWrap = document.getElementById('section-wrap') as HTMLElement;
const sectionBtn  = document.getElementById('section-btn') as HTMLButtonElement;
const sectionLbl  = document.getElementById('section-label') as HTMLElement;
const sectionPanel= document.getElementById('section-panel') as HTMLElement;
const sectionOpts = Array.from(document.querySelectorAll<HTMLButtonElement>('#section-panel .section-opt'));
const subcatBtns  = Array.from(document.querySelectorAll<HTMLButtonElement>('#subcat-filters .blog-filter'));
const searchInput = document.getElementById('blog-search') as HTMLInputElement;
const count       = document.getElementById('blog-count') as HTMLElement;
const empty       = document.getElementById('blog-empty') as HTMLElement;

let activeSec = 'todos';
let activeCat = 'todos';
let searchVal = '';

function update() {
  let visible = 0;
  cards.forEach(card => {
    const secMatch  = activeSec === 'todos' || card.dataset.sec === activeSec;
    const catMatch  = activeCat === 'todos' || card.dataset.cat === activeCat;
    const textMatch = !searchVal || (card.dataset.text ?? '').includes(searchVal);
    const show = secMatch && catMatch && textMatch;
    card.classList.toggle('hidden', !show);
    if (show) visible++;
  });
  count.textContent = `${visible} artículo${visible !== 1 ? 's' : ''}`;
  empty.style.display = visible === 0 ? 'block' : 'none';
}

function setSection(secId: string) {
  activeSec = secId;
  const opt = sectionOpts.find(o => o.dataset.sec === secId);
  sectionLbl.textContent = opt?.textContent?.trim() ?? 'Todas las secciones';
  sectionOpts.forEach(o => o.classList.toggle('active', o.dataset.sec === secId));

  // Mostrar sólo las subcategorías de la sección seleccionada
  subcatBtns.forEach(btn => {
    if (!btn.dataset.sec) return; // botón "Todos" no tiene data-sec
    btn.style.display = secId === 'todos' || btn.dataset.sec === secId ? '' : 'none';
  });

  // Resetear subcat si ya no pertenece a la nueva sección
  if (activeCat !== 'todos') {
    const catBtn = subcatBtns.find(b => b.dataset.cat === activeCat);
    if (catBtn && secId !== 'todos' && catBtn.dataset.sec !== secId) {
      activeCat = 'todos';
      subcatBtns.forEach(b => b.classList.toggle('active', b.dataset.cat === 'todos'));
    }
  }
  update();
}

function setSubcat(cat: string) {
  activeCat = cat;
  subcatBtns.forEach(b => b.classList.toggle('active', b.dataset.cat === cat));
  update();
}

// Toggle dropdown sección
sectionBtn.addEventListener('click', e => {
  e.stopPropagation();
  const isOpen = sectionWrap.classList.toggle('open');
  sectionBtn.setAttribute('aria-expanded', String(isOpen));
});

// Cerrar al clickear afuera
document.addEventListener('click', () => {
  sectionWrap.classList.remove('open');
  sectionBtn.setAttribute('aria-expanded', 'false');
});
sectionPanel.addEventListener('click', e => e.stopPropagation());

// Opciones de sección
sectionOpts.forEach(opt => {
  opt.addEventListener('click', () => {
    setSection(opt.dataset.sec ?? 'todos');
    sectionWrap.classList.remove('open');
    sectionBtn.setAttribute('aria-expanded', 'false');
  });
});

// Subcategorías
subcatBtns.forEach(btn => {
  btn.addEventListener('click', () => setSubcat(btn.dataset.cat ?? 'todos'));
});

// Búsqueda
searchInput.addEventListener('input', () => {
  searchVal = searchInput.value.toLowerCase().trim();
  update();
});

// Hash routing desde nav (ej: /blog/#mediciones)
const hashMap: Record<string, { cat: string; sec: string }> = {
  'industrias-y-construcciones': { cat: 'Industrias y Construcciones', sec: 'cumplimiento' },
  'mediciones':                  { cat: 'Mediciones',                  sec: 'cumplimiento' },
  'capacitaciones':              { cat: 'Capacitaciones',              sec: 'cumplimiento' },
  'iso-45001':                   { cat: 'ISO 45001',                   sec: 'iso45001'     },
  'auditorias':                  { cat: 'Auditorías',                  sec: 'iso45001'     },
  'plataforma-hys':              { cat: 'Plataforma HyS',              sec: 'plataforma'   },
  'medio-ambiente':              { cat: 'Medio Ambiente',              sec: 'medioambiente'},
};

function activateFromHash() {
  const hash = window.location.hash.replace('#', '');
  const entry = hashMap[hash];
  if (!entry) return;
  setSection(entry.sec);
  setSubcat(entry.cat);
}

activateFromHash();
window.addEventListener('hashchange', activateFromHash);
</script>
