---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { blogPosts } from '../../data/blog-posts';

function formatFecha(iso: string) {
  const [y, m, d] = iso.split('-');
  const meses = ['ene','feb','mar','abr','may','jun','jul','ago','sep','oct','nov','dic'];
  return `${parseInt(d)} ${meses[parseInt(m) - 1]} ${y}`;
}

const categoryGroups = [
  {
    label: '🏗️ Cumplimiento operativo',
    categorias: ['Construcción y Obra', 'Mediciones', 'Capacitaciones'],
  },
  {
    label: '📋 ISO 45001',
    categorias: ['ISO 45001', 'Auditorías'],
  },
  {
    label: '💻 Plataforma y tecnología',
    categorias: ['Plataforma HyS'],
  },
  {
    label: '🌿 Medio Ambiente',
    categorias: ['Medio Ambiente'],
  },
];
---

<BaseLayout
  title="Blog de Higiene y Seguridad Laboral — SIGMETRÍA HyS"
  description="Artículos prácticos sobre normativa SRT, Decreto 351/79, 911/96, EPP y mediciones. Para empresas de CABA y GBA que quieren cumplir y proteger a su equipo."
>
  <section class="page-hero">
    <nav aria-label="Breadcrumb" class="breadcrumb">
      <a href="/">Inicio</a><span>/</span>
      <span>Blog</span>
    </nav>
    <div class="page-hero-inner blog-hero-inner">
      <div class="blog-hero-left">
        <div class="page-hero-badge">Construcción · ISO 45001 · Mediciones · Capacitaciones</div>
        <h1>BLOG DE<br><em>H&amp;S LABORAL</em></h1>
      </div>
      <p class="blog-hero-desc">Artículos prácticos escritos por profesionales. Sin tecnicismos innecesarios — lo que necesitás saber para cumplir y proteger a tu equipo.</p>
    </div>
  </section>

  <section class="content-section">
    <div class="content-inner">

      <!-- Buscador -->
      <div class="blog-toolbar">
        <div class="blog-search-wrap">
          <svg class="blog-search-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          <input
            id="blog-search"
            type="search"
            placeholder="Buscar artículos..."
            autocomplete="off"
            spellcheck="false"
          />
        </div>
        <span class="blog-count" id="blog-count">{blogPosts.length} artículos</span>
      </div>

      <!-- Filtros por categoría de servicio -->
      <div class="blog-filters" id="blog-filters">
        <div class="blog-filters-top">
          <button class="blog-filter active" data-cat="todos">Todos</button>
        </div>
        {categoryGroups.map(group => (
          <div class="filter-group">
            <span class="filter-group-label">{group.label}</span>
            {group.categorias.map(cat => (
              <button class="blog-filter" data-cat={cat}>{cat}</button>
            ))}
          </div>
        ))}
      </div>

      <!-- Grid -->
      <div class="blog-grid" id="blog-grid">
        {blogPosts.map(post => (
          <article
            class="blog-card"
            data-cat={post.categoria}
            data-text={`${post.titulo} ${post.resumen} ${post.categoria} ${post.tags.join(' ')}`.toLowerCase()}
          >
            <div class="blog-card-meta">
              <span class="blog-cat">{post.categoria}</span>
              <span class="blog-sep">·</span>
              <span class="blog-tiempo">{post.tiempoLectura} lectura</span>
            </div>
            <h2 class="blog-card-title">
              <a href={`/blog/${post.slug}/`}>{post.titulo}</a>
            </h2>
            <p class="blog-card-resumen">{post.resumen}</p>
            <div class="blog-card-footer">
              <div class="blog-tags">
                {post.tags.slice(0, 3).map(tag => (
                  <span class="blog-tag">{tag}</span>
                ))}
              </div>
              <a href={`/blog/${post.slug}/`} class="blog-read-more">Leer →</a>
            </div>
          </article>
        ))}
      </div>

      <!-- Empty state -->
      <div class="blog-empty" id="blog-empty" style="display:none">
        <p>No hay artículos que coincidan con tu búsqueda.</p>
      </div>

    </div>
  </section>
</BaseLayout>

<style>
/* ---- Hero compacto ---- */
.page-hero {
  padding-top: 100px;
  padding-bottom: 28px;
}
.page-hero h1 {
  font-size: clamp(26px, 3.5vw, 46px);
  margin-bottom: 8px;
}
.page-hero-badge {
  margin-bottom: 10px;
}
.blog-hero-inner {
  max-width: 1100px !important;
  display: flex;
  align-items: center;
  gap: 48px;
}
.blog-hero-left { flex-shrink: 0; }
.blog-hero-desc {
  font-size: 14px;
  font-weight: 300;
  color: var(--gris-2);
  line-height: 1.75;
  max-width: 340px;
  margin: 0;
}
@media (max-width: 900px) {
  .page-hero { padding-top: 96px; padding-bottom: 20px; }
  .blog-hero-inner { flex-direction: column; align-items: flex-start; gap: 10px; }
  .blog-hero-desc { max-width: 100%; }
}

/* ---- Toolbar ---- */
.blog-toolbar {
  display: flex;
  align-items: center;
  gap: 16px;
  margin-bottom: 16px;
  flex-wrap: wrap;
}
.blog-search-wrap {
  position: relative;
  flex: 1;
  min-width: 220px;
}
.blog-search-icon {
  position: absolute;
  left: 12px;
  top: 50%;
  transform: translateY(-50%);
  color: var(--gris-3);
  pointer-events: none;
}
#blog-search {
  width: 100%;
  background: var(--blanco);
  border: 1px solid var(--borde);
  border-radius: 6px;
  padding: 10px 14px 10px 36px;
  font-family: 'Montserrat', sans-serif;
  font-size: .8rem;
  color: var(--gris-1);
  outline: none;
  transition: border-color .2s;
  box-sizing: border-box;
}
#blog-search::placeholder { color: var(--gris-3); }
#blog-search:focus { border-color: var(--verde); }
#blog-search::-webkit-search-cancel-button { cursor: pointer; }
.blog-count {
  font-family: 'Montserrat', sans-serif;
  font-size: .56rem;
  font-weight: 600;
  color: var(--gris-3);
  letter-spacing: .5px;
  white-space: nowrap;
  flex-shrink: 0;
}

/* ---- Filtros ---- */
.blog-filters {
  display: flex;
  flex-direction: column;
  gap: 8px;
  margin-bottom: 28px;
}
.blog-filters-top {
  display: flex;
  gap: 6px;
}
.filter-group {
  display: flex;
  align-items: center;
  gap: 4px;
  flex-wrap: wrap;
  background: var(--gris-bg);
  border: 1px solid var(--borde);
  border-radius: 6px;
  padding: 6px 10px;
}
.filter-group-label {
  font-family: 'Montserrat', sans-serif;
  font-size: .5rem;
  font-weight: 700;
  letter-spacing: .3px;
  color: var(--gris-2);
  white-space: nowrap;
  margin-right: 6px;
}
.blog-filter {
  font-family: 'Montserrat', sans-serif;
  font-size: .56rem;
  font-weight: 600;
  letter-spacing: .6px;
  text-transform: uppercase;
  color: var(--gris-2);
  background: var(--blanco);
  border: 1px solid var(--borde);
  border-radius: 4px;
  padding: 5px 12px;
  cursor: pointer;
  transition: all .18s;
  white-space: nowrap;
}
.blog-filter:hover {
  color: var(--verde);
  border-color: var(--verde-borde);
  background: var(--verde-light);
}
.blog-filter.active {
  color: var(--verde-dark);
  background: var(--verde-light);
  border-color: var(--verde);
}
@media (max-width: 768px) {
  .filter-group { width: 100%; }
  .filter-group-label { display: block; width: 100%; margin-bottom: 4px; }
}

/* ---- Empty state ---- */
.blog-empty {
  text-align: center;
  padding: 60px 20px;
  color: var(--gris-3);
  font-size: 14px;
  font-weight: 300;
}

@media (max-width: 600px) {
  .blog-toolbar { flex-direction: column; align-items: stretch; }
  .blog-count { text-align: right; }
}
</style>

<script>
const cards   = Array.from(document.querySelectorAll<HTMLElement>('#blog-grid .blog-card'));
const filters = Array.from(document.querySelectorAll<HTMLButtonElement>('#blog-filters .blog-filter'));
const search  = document.getElementById('blog-search') as HTMLInputElement;
const count   = document.getElementById('blog-count') as HTMLElement;
const empty   = document.getElementById('blog-empty') as HTMLElement;

let activeCat = 'todos';
let searchVal = '';

function update() {
  let visible = 0;
  cards.forEach(card => {
    const catMatch  = activeCat === 'todos' || card.dataset.cat === activeCat;
    const textMatch = !searchVal || (card.dataset.text ?? '').includes(searchVal);
    const show = catMatch && textMatch;
    card.classList.toggle('hidden', !show);
    if (show) visible++;
  });
  count.textContent = `${visible} artículo${visible !== 1 ? 's' : ''}`;
  empty.style.display = visible === 0 ? 'block' : 'none';
}

filters.forEach(btn => {
  btn.addEventListener('click', () => {
    filters.forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    activeCat = btn.dataset.cat ?? 'todos';
    update();
  });
});

search.addEventListener('input', () => {
  searchVal = search.value.toLowerCase().trim();
  update();
});

</script>
