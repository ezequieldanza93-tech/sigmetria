---
import { FEATURES } from '../config/site';
import Icon from './Icon.astro';

const servicios = [
  { href: '/servicios/construccion/',   label: 'Industrias y Construcciones' },
  { href: '/servicios/mediciones/',     label: 'Mediciones Técnicas' },
  { href: '/servicios/capacitaciones/', label: 'Capacitaciones' },
  { href: '/servicios/iso-45001/',      label: 'ISO 45001' },
  { href: '/servicios/auditorias/',     label: 'Auditorías' },
];
---

<footer>
  <div class={`footer-inner ${FEATURES.servicios ? '' : 'footer-inner--no-serv'}`}>

    <!-- Logo + descripción -->
    <div class="footer-brand">
      <div class="footer-logo">
        <img src="/logo-sigmetria.svg" alt="SIGMETRÍA HyS" width="36" height="36" style="object-fit:contain;flex-shrink:0;" />
        <div class="footer-brand-text">
          <span class="footer-brand-name">SIGMETRÍA</span>
          <span class="footer-brand-sub">HIGIENE Y SEGURIDAD</span>
        </div>
      </div>
      <p class="footer-desc">La plataforma para ordenar toda tu gestión de Higiene y Seguridad: cargás la recorrida desde el celular, el reporte sale solo y ves toda tu cartera de clientes y establecimientos en una sola vista.</p>

      <div class="footer-ig">
        <a href="https://www.instagram.com/sigmetria" target="_blank" rel="noopener" class="footer-ig-link">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
          @sigmetria
        </a>
        <div class="footer-qr-wrap">
          <img src="/qr-instagram.jpg" alt="QR Instagram @sigmetria" width="88" height="88" loading="lazy" />
          <span class="footer-qr-label">Escaneá para seguirnos</span>
        </div>
      </div>
    </div>

    <!-- Servicios — oculto detrás del flag FEATURES.servicios (reactivable sin tocar código) -->
    {FEATURES.servicios && (
    <div class="footer-col">
      <h3 class="footer-heading">Servicios</h3>
      <ul>
        {servicios.map(s => <li><a href={s.href}>{s.label}</a></li>)}
      </ul>
    </div>
    )}

    <!-- Empresa -->
    <div class="footer-col">
      <h3 class="footer-heading">Empresa</h3>
      <ul>
        <li><a href="/nosotros/">Nosotros</a></li>
        <li><a href="/contacto/">Contacto</a></li>
        <li><a href="/blog/">Blog HyS</a></li>
      </ul>
    </div>

    <!-- Contacto / NAP -->
    <div class="footer-col">
      <h3 class="footer-heading">Contacto</h3>
      <address>
        <p class="nap-item">
          <span class="nap-icon"><Icon name="map-pin" size={16} /></span>
          CABA y provincia de Buenos Aires, Argentina
        </p>
        <p class="nap-item">
          <span class="nap-icon"><Icon name="phone" size={16} /></span>
          <a href="tel:+5491123496789">+54 9 11 2349-6789</a>
        </p>
        <p class="nap-item">
          <span class="nap-icon"><Icon name="message-circle" size={16} /></span>
          <a href="https://wa.me/5491123496789" target="_blank" rel="noopener">WhatsApp</a>
        </p>
        <p class="nap-item">
          <span class="nap-icon"><Icon name="mail" size={16} /></span>
          <a href="mailto:ezequiel@sigmetriahys.com">ezequiel@sigmetriahys.com</a>
        </p>
      </address>
    </div>

  </div>

  <div class="footer-bottom">
    <p>© {new Date().getFullYear()} SIGMETRÍA HyS · Todos los derechos reservados</p>
    <p>Matriculados COPIME · CPSH · Ing. Industrial · ISO 45001:2018</p>
  </div>
</footer>

<style>
footer {
  position: relative;
  z-index: 1;
  background: var(--gris-bg);
  border-top: 1px solid var(--borde);
  padding: 60px 51px 0;
}
.footer-inner {
  max-width: 1200px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 2fr 1fr 1fr 1.4fr;
  gap: 48px;
  padding-bottom: 48px;
}
.footer-inner--no-serv { grid-template-columns: 2fr 1fr 1.4fr; }

/* ---- Logo ---- */
.footer-logo {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 16px;
}
.footer-brand-text {
  display: flex;
  flex-direction: column;
  line-height: 1;
}
.footer-brand-name {
  font-family: 'Montserrat', sans-serif;
  font-size: .9rem;
  font-weight: 800;
  color: var(--gris-1);
  letter-spacing: 1px;
}
.footer-brand-sub {
  font-family: 'Montserrat', sans-serif;
  font-size: .4rem;
  font-weight: 600;
  color: var(--verde);
  letter-spacing: 2px;
  text-transform: uppercase;
  margin-top: 3px;
}

.footer-desc {
  font-size: 13px;
  font-weight: 300;
  color: var(--gris-3);
  line-height: 1.75;
  max-width: 280px;
}
.footer-heading {
  font-family: 'Montserrat', sans-serif;
  font-size: .54rem;
  color: var(--verde-dark);
  letter-spacing: 2px;
  text-transform: uppercase;
  margin-bottom: 16px;
  font-weight: 700;
}
.footer-col ul { list-style: none; display: flex; flex-direction: column; gap: 8px; }
.footer-col a {
  font-size: 13px;
  font-weight: 300;
  color: var(--gris-2);
  text-decoration: none;
  transition: color .2s;
}
.footer-col a:hover { color: var(--verde); }

address { font-style: normal; display: flex; flex-direction: column; gap: 10px; }
.nap-item {
  display: flex;
  align-items: flex-start;
  gap: 8px;
  font-size: 13px;
  font-weight: 300;
  color: var(--gris-2);
  line-height: 1.5;
}
.nap-icon { flex-shrink: 0; display: inline-flex; align-items: center; color: var(--verde-dark); }
.nap-item a { color: var(--gris-2); text-decoration: none; transition: color .2s; }
.nap-item a:hover { color: var(--verde); }

.footer-bottom {
  max-width: 1200px;
  margin: 0 auto;
  padding: 20px 0;
  border-top: 1px solid var(--borde);
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: 8px;
}
.footer-bottom p {
  font-family: 'Montserrat', sans-serif;
  font-size: .52rem;
  color: var(--gris-3);
  letter-spacing: .8px;
  text-transform: uppercase;
}

.footer-ig {
  margin-top: 20px;
  display: flex;
  flex-direction: column;
  gap: 10px;
}
.footer-ig-link {
  display: inline-flex;
  align-items: center;
  gap: 7px;
  font-family: 'Montserrat', sans-serif;
  font-size: .72rem;
  font-weight: 600;
  color: #d6249f;
  text-decoration: none;
  letter-spacing: .4px;
  transition: opacity .2s;
}
.footer-ig-link:hover { opacity: .75; }
.footer-qr-wrap {
  display: flex;
  align-items: center;
  gap: 10px;
}
.footer-qr-wrap img {
  border-radius: 6px;
  border: 1px solid var(--borde);
  display: block;
  flex-shrink: 0;
}
.footer-qr-label {
  font-family: 'Montserrat', sans-serif;
  font-size: .52rem;
  font-weight: 600;
  color: var(--gris-3);
  letter-spacing: .8px;
  text-transform: uppercase;
  line-height: 1.5;
  max-width: 90px;
}

@media (max-width: 1000px) {
  .footer-inner { grid-template-columns: 1fr 1fr; }
  .footer-brand { grid-column: 1 / -1; }
}
@media (max-width: 600px) {
  footer { padding: 48px 24px 0; }
  .footer-inner { grid-template-columns: 1fr; gap: 32px; }
  .footer-bottom { flex-direction: column; text-align: center; }
}
</style>
