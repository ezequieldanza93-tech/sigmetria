---
import { FEATURES, CANALES, TRIAL_URL } from '../config/site';

const currentPath = Astro.url.pathname;

// Canales / redes — URLs centralizadas en config/site.ts. '#' = placeholder pendiente.
const canales = [
  { label: 'LinkedIn',  href: CANALES.linkedin,  icon: 'M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z' },
  { label: 'Instagram', href: CANALES.instagram, icon: 'M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z' },
  { label: 'YouTube',   href: CANALES.youtube,   icon: 'M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z' },
  { label: 'WhatsApp',  href: CANALES.whatsapp,  icon: 'M.057 24l1.687-6.163a11.867 11.867 0 0 1-1.587-5.946C.16 5.335 5.495 0 12.05 0a11.817 11.817 0 0 1 8.413 3.488 11.824 11.824 0 0 1 3.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 0 1-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884a9.86 9.86 0 0 0 1.51 5.26l-.999 3.648 3.978-1.042 1.044.555zm5.404-13.51c.16-.001.346.005.498.04.16.04.394.135.583.385.16.21.422.79.516 1.222.094.43.094.79-.045 1.04-.16.295-.394.59-.78.91-.39.32-.78.64-.66 1.06.12.42 1.06 1.74 2.27 2.81 1.56 1.39 2.88 1.82 3.3 2.04.42.21.66.18.9-.11.24-.29 1.04-1.21 1.32-1.63.28-.42.56-.35.94-.21.38.14 2.42 1.14 2.84 1.35.42.21.7.32.8.49.1.18.1 1.02-.24 2.01-.34.99-1.96 1.89-2.76 2.01-.72.11-1.62.16-2.61-.16-.6-.19-1.37-.44-2.36-.86-4.15-1.79-6.86-5.96-7.07-6.24-.21-.28-1.69-2.25-1.69-4.29 0-2.04 1.07-3.04 1.45-3.46.38-.42.83-.52 1.11-.52z' },
];

const serviceGroups = [
  {
    label: 'Cumplimiento operativo',
    servicios: [
      { label: 'Industrias y Construcciones', href: '/servicios/construccion/' },
      { label: 'Mediciones técnicas',      href: '/servicios/mediciones/' },
      { label: 'Capacitaciones',           href: '/servicios/capacitaciones/' },
    ],
  },
  {
    label: 'ISO 45001',
    servicios: [
      { label: 'Implementación ISO 45001', href: '/servicios/iso-45001/' },
      { label: 'Auditorías de HyS y SIG',  href: '/servicios/auditorias/' },
    ],
  },
  {
    label: 'Plataforma y tecnología',
    servicios: [
      { label: 'Plataforma SaaS HyS', href: '/servicios/' },
    ],
  },
];

const blogGroups = [
  {
    label: 'Gestión HyS',
    categorias: [
      { label: 'Gestión operativa',   hash: 'gestion-operativa' },
      { label: 'Mediciones SRT',      hash: 'mediciones' },
      { label: 'Capacitaciones',      hash: 'capacitaciones' },
    ],
  },
  {
    label: 'ISO 45001',
    categorias: [
      { label: 'Implementación',      hash: 'iso-45001' },
      { label: 'Auditorías',          hash: 'auditorias' },
    ],
  },
  {
    label: 'Prevención 4.0',
    categorias: [
      { label: 'Digitalización HyS',  hash: 'prevencion-40' },
      { label: 'Res SRT 48/2025',     hash: 'res-srt-48-2025' },
      { label: 'Disp SRT 15/2026',    hash: 'disp-srt-15-2026' },
    ],
  },
];
---

<nav id="main-nav">
  <a href="/" class="nav-logo" aria-label="SIGMETRÍA HyS — Inicio">
    <img src="/logo-mark.png" width="44" height="44" alt="" class="nav-triangle" />
    <span class="nav-brand">
      <span class="nav-brand-name">SIGMETRÍA</span>
      <span class="nav-brand-sub">HIGIENE Y SEGURIDAD</span>
    </span>
  </a>

  <div class="nav-right">

    <!-- SERVICIOS — oculto detrás del flag FEATURES.servicios (reactivable sin tocar código) -->
    {FEATURES.servicios && (
    <div class="nav-item nav-has-dropdown">
      <a
        href="/servicios/"
        class={`nav-link ${currentPath.startsWith('/servicios/') ? 'active' : ''}`}
        aria-haspopup="true"
        aria-expanded="false"
      >
        Servicios <span class="nav-arrow">▾</span>
      </a>

      <div class="nav-mega" role="menu">
        {serviceGroups.map(group => (
          <div class="nav-mega-col">
            <span class="nav-mega-label">{group.label}</span>
            {group.servicios.map(s => (
              <a href={s.href} class="nav-mega-link" role="menuitem">{s.label}</a>
            ))}
          </div>
        ))}
      </div>
    </div>
    )}

    <!-- PLATAFORMA — acceso directo a la demo -->
    <div class="nav-item nav-has-dropdown">
      <a
        href="/plataforma/"
        class={`nav-link ${currentPath.startsWith('/plataforma') ? 'active' : ''}`}
        aria-haspopup="true"
        aria-expanded="false"
      >
        Plataforma <span class="nav-arrow">▾</span>
      </a>
      <div class="nav-dropdown nav-plataforma-dropdown" role="menu">
        <a href="/plataforma/" class="nav-dropdown-link" role="menuitem">Conocer la plataforma</a>
        <a href="/precios/" class="nav-dropdown-link" role="menuitem">Planes y precios</a>
        <a href="/fundadores/" class="nav-dropdown-link nav-dropdown-founder" role="menuitem">🔥 Programa Fundadores</a>
        <div class="nav-submenu-divider"></div>
        <a href={TRIAL_URL} class="nav-dropdown-link nav-dropdown-demo" role="menuitem">
          Probar la demo
        </a>
        <a href="/contacto/?s=s4&funnel=demo-nav" class="nav-dropdown-link" role="menuitem">Solicitar presentación</a>
      </div>
    </div>

    <a href="/precios/" class={`nav-link ${currentPath.startsWith('/precios') ? 'active' : ''}`}>Precios</a>

    <!-- BLOG H&S — dropdown agrupado por categoría S0 -->
    <div class="nav-item nav-has-dropdown">
      <a
        href="/blog/"
        class={`nav-link ${currentPath.startsWith('/blog/') ? 'active' : ''}`}
        aria-haspopup="true"
        aria-expanded="false"
      >
        Blog H&S <span class="nav-arrow">▾</span>
      </a>
      <div class="nav-dropdown nav-blog-dropdown" role="menu">
        <a href="/blog/" class="nav-dropdown-link" role="menuitem">Ver todos los artículos</a>
        <div class="nav-submenu-divider"></div>
        {blogGroups.map(group => (
          <div class="nav-blog-group">
            <span class="nav-blog-group-label">{group.label}</span>
            {group.categorias.map(cat => (
              <a href={`/blog/#${cat.hash}`} class="nav-dropdown-link nav-dropdown-cat" role="menuitem">
                {cat.label}
              </a>
            ))}
          </div>
        ))}
      </div>
    </div>

    <a href="/recursos/" class={`nav-link ${currentPath.startsWith('/recursos') ? 'active' : ''}`}>Recursos</a>

    <a href="/nosotros/" class={`nav-link ${currentPath === '/nosotros/' ? 'active' : ''}`}>Nosotros</a>

    <!-- CANALES — redes y contacto directo -->
    <div class="nav-item nav-has-dropdown">
      <span class="nav-link nav-canales-trigger" role="button" tabindex="0" aria-haspopup="true" aria-expanded="false">
        Canales <span class="nav-arrow">▾</span>
      </span>
      <div class="nav-dropdown nav-canales-dropdown" role="menu">
        {canales.map(c => (
          c.href === '#' ? (
            <span class="nav-dropdown-link nav-canal-link nav-canal-disabled" aria-disabled="true" title={`${c.label} — próximamente`}>
              <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d={c.icon} /></svg>
              {c.label}
              <span class="nav-canal-soon">pronto</span>
            </span>
          ) : (
            <a href={c.href} class="nav-dropdown-link nav-canal-link" role="menuitem" target="_blank" rel="noopener">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d={c.icon} /></svg>
              {c.label}
            </a>
          )
        ))}
      </div>
    </div>

    <span id="nav-auth-desktop">
      <a href="/acceso/" class={`nav-link nav-link-acceso ${currentPath.startsWith('/acceso') ? 'active' : ''}`}>Accedé</a>
    </span>
    <span id="nav-user-desktop" style="display:none;position:relative" class="nav-user-wrap">
      <button class="nav-user-btn" id="nav-user-btn" aria-expanded="false" aria-haspopup="true">
        <span class="nav-user-avatar" id="nav-user-avatar">?</span>
      </button>
      <div class="nav-user-dropdown" id="nav-user-dropdown">
        <span class="nav-user-email" id="nav-user-email-display"></span>
        <div class="nav-submenu-divider"></div>
        <a href="/acceso/" class="nav-dropdown-link">Mi cuenta</a>
        <button class="nav-dropdown-link nav-signout-btn" id="nav-signout-btn-desktop" style="width:100%;text-align:left;background:none;border:none;cursor:pointer;color:var(--gris-2)">Cerrar sesión</button>
      </div>
    </span>
    <a href={TRIAL_URL} class="nav-cta">Probá gratis</a>
  </div>

  <button class="nav-hamburger" id="nav-toggle" aria-label="Abrir menú" aria-expanded="false">
    <span></span><span></span><span></span>
  </button>
</nav>

<!-- Mobile menu -->
<div class="nav-mobile" id="nav-mobile" role="navigation" aria-label="Menú mobile">
  {FEATURES.servicios && (
  <div class="nav-mobile-item">
    <button class="nav-mobile-toggle" id="mobile-servicios-toggle" aria-expanded="false">
      Servicios <span class="mobile-arrow">▾</span>
    </button>
    <div class="nav-mobile-sub" id="mobile-servicios-sub">
      {serviceGroups.map((group, gi) => (
        <div class="nav-mobile-sector">
          <button class="nav-mobile-sector-toggle" aria-expanded="false">
            {group.label} <span class="mobile-arrow">›</span>
          </button>
          <div class="nav-mobile-sector-links">
            {group.servicios.map(s => (
              <a href={s.href} class="nav-mobile-link">{s.label}</a>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
  )}
  <div class="nav-mobile-item">
    <button class="nav-mobile-toggle" id="mobile-plataforma-toggle" aria-expanded="false">
      Plataforma <span class="mobile-arrow">▾</span>
    </button>
    <div class="nav-mobile-sub" id="mobile-plataforma-sub">
      <a href="/plataforma/" class="nav-mobile-link">Conocer la plataforma</a>
      <a href="/precios/" class="nav-mobile-link">Planes y precios</a>
      <a href="/fundadores/" class="nav-mobile-link" style="color: #B45309; font-weight: 600;">🔥 Programa Fundadores</a>
      <a href={TRIAL_URL} class="nav-mobile-link" style="color: var(--verde); font-weight: 600;">Probar la demo</a>
      <a href="/contacto/?s=s4&funnel=demo-nav" class="nav-mobile-link">Solicitar presentación</a>
    </div>
  </div>
  <a href="/precios/" class="nav-mobile-link nav-mobile-root">Precios</a>
  <div class="nav-mobile-item">
    <button class="nav-mobile-toggle" id="mobile-blog-toggle" aria-expanded="false">
      Blog H&S <span class="mobile-arrow">▾</span>
    </button>
    <div class="nav-mobile-sub" id="mobile-blog-sub">
      <a href="/blog/" class="nav-mobile-link">Ver todos los artículos</a>
      {blogGroups.map(group => (
        <div class="nav-mobile-sector">
          <button class="nav-mobile-sector-toggle" aria-expanded="false">
            {group.label} <span class="mobile-arrow">›</span>
          </button>
          <div class="nav-mobile-sector-links">
            {group.categorias.map(cat => (
              <a href={`/blog/#${cat.hash}`} class="nav-mobile-link">{cat.label}</a>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
  <a href="/recursos/" class="nav-mobile-link nav-mobile-root">Recursos</a>
  <a href="/nosotros/" class="nav-mobile-link nav-mobile-root">Nosotros</a>
  <div class="nav-mobile-item">
    <button class="nav-mobile-toggle" id="mobile-canales-toggle" aria-expanded="false">
      Canales <span class="mobile-arrow">▾</span>
    </button>
    <div class="nav-mobile-sub" id="mobile-canales-sub">
      {canales.map(c => (
        c.href === '#' ? (
          <span class="nav-mobile-link nav-canal-disabled" aria-disabled="true">{c.label} <span class="nav-canal-soon">pronto</span></span>
        ) : (
          <a href={c.href} class="nav-mobile-link" target="_blank" rel="noopener">{c.label}</a>
        )
      ))}
    </div>
  </div>
  <span id="nav-auth-mobile"><a href="/acceso/" class="nav-mobile-link nav-mobile-root">Accedé</a></span>
  <span id="nav-user-mobile" style="display:none">
    <a href="/acceso/" class="nav-mobile-link nav-mobile-root">Mi cuenta</a>
    <button class="nav-mobile-link nav-mobile-root" id="nav-signout-btn-mobile" style="width:100%;text-align:left;background:none;border:none;cursor:pointer;color:var(--gris-2);font-family:inherit;font-size:.82rem;font-weight:600;letter-spacing:.6px;text-transform:uppercase;padding:12px 0;border-bottom:1px solid var(--borde)">Cerrar sesión</button>
  </span>
  <a href={TRIAL_URL} class="btn-primary" style="margin-top:8px;">Probá gratis</a>
</div>

<style>
/* ---- NAV BASE ---- */
nav {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 200;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 51px;
  height: 68px;
  background: rgba(255,255,255,.97);
  border-bottom: 1px solid var(--borde);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  transition: box-shadow .3s ease;
}
nav.scrolled {
  box-shadow: 0 2px 20px rgba(0,0,0,.08);
}

/* ---- LOGO ---- */
.nav-logo {
  display: flex;
  align-items: center;
  gap: 10px;
  text-decoration: none;
}
.nav-triangle { flex-shrink: 0; display: block; }
.nav-brand { display: flex; flex-direction: column; line-height: 1; }
.nav-brand-name {
  font-family: 'Montserrat', sans-serif;
  font-size: .95rem;
  font-weight: 800;
  color: var(--gris-1);
  letter-spacing: 1px;
}
.nav-brand-sub {
  font-family: 'Montserrat', sans-serif;
  font-size: .42rem;
  font-weight: 600;
  color: var(--verde);
  letter-spacing: 2px;
  text-transform: uppercase;
  margin-top: 3px;
}

.nav-right { display: flex; align-items: center; gap: 2px; }

/* ---- LINKS ---- */
.nav-link {
  font-family: 'Montserrat', sans-serif;
  font-size: .72rem;
  font-weight: 600;
  color: var(--gris-2);
  text-decoration: none;
  letter-spacing: .6px;
  text-transform: uppercase;
  transition: color .2s;
  padding: 8px 12px;
  border-radius: 4px;
  display: flex;
  align-items: center;
  gap: 5px;
  white-space: nowrap;
}
.nav-link:hover, .nav-link.active { color: var(--verde); }
.nav-arrow { font-size: .6rem; opacity: .7; transition: transform .2s; }

.nav-link-acceso {
  border: 1px solid var(--borde);
  border-radius: 4px;
  color: var(--gris-2);
}
.nav-link-acceso:hover { border-color: var(--verde); color: var(--verde); background: transparent; }
.nav-link-acceso.active { border-color: var(--verde); color: var(--verde); }

.nav-cta {
  background: var(--verde);
  color: #fff;
  padding: 9px 22px;
  border-radius: 4px;
  font-family: 'Montserrat', sans-serif;
  font-weight: 700;
  font-size: .72rem;
  letter-spacing: .8px;
  text-transform: uppercase;
  text-decoration: none;
  transition: all .2s;
  margin-left: 8px;
}
.nav-cta:hover { background: var(--verde-dark); }

/* ---- DROPDOWN (Blog) ---- */
.nav-item { position: relative; }

.nav-dropdown {
  position: absolute;
  top: 100%;
  right: 0;
  left: auto;
  min-width: 220px;
  background: #fff;
  border: 1px solid var(--borde);
  border-radius: 8px;
  padding: 8px 0;
  box-shadow: 0 12px 40px rgba(0,0,0,.1);
  opacity: 0;
  pointer-events: none;
  transform: translateY(-4px);
  transition: opacity .18s ease, transform .18s ease;
  z-index: 300;
}
.nav-has-dropdown:hover .nav-dropdown,
.nav-has-dropdown:focus-within .nav-dropdown {
  opacity: 1;
  pointer-events: all;
  transform: translateY(0);
}
.nav-has-dropdown:hover .nav-arrow { transform: rotate(180deg); }

.nav-dropdown-link {
  display: block;
  padding: 9px 16px;
  font-family: 'Montserrat', sans-serif;
  font-size: .75rem;
  font-weight: 500;
  color: var(--gris-2);
  text-decoration: none;
  letter-spacing: .3px;
  transition: all .15s;
  white-space: nowrap;
}
.nav-dropdown-link:hover { color: var(--verde); background: var(--verde-light); }
.nav-dropdown-cat { font-weight: 400; padding-left: 24px; font-size: .72rem; }
.nav-dropdown-cat:hover { padding-left: 28px; }

/* Plataforma dropdown */
.nav-plataforma-dropdown { min-width: 220px; }
.nav-dropdown-demo {
  color: var(--verde) !important;
  font-weight: 600 !important;
}
.nav-dropdown-demo:hover { background: var(--verde-light) !important; }
.nav-dropdown-founder { color: #B45309 !important; font-weight: 600 !important; }
.nav-dropdown-founder:hover { background: #FFF4E5 !important; }

/* Blog dropdown groups */
.nav-blog-dropdown { min-width: 240px; }
.nav-blog-group { margin-top: 4px; }
.nav-blog-group-label {
  display: block;
  padding: 6px 16px 2px;
  font-family: 'Montserrat', sans-serif;
  font-size: .5rem;
  font-weight: 700;
  letter-spacing: .6px;
  text-transform: uppercase;
  color: var(--verde-dark);
}

.nav-submenu-divider {
  height: 1px;
  background: var(--borde);
  margin: 4px 10px;
}

/* Canales dropdown */
.nav-canales-trigger { cursor: pointer; user-select: none; }
.nav-canales-dropdown { min-width: 190px; }
.nav-canal-link { display: flex; align-items: center; gap: 9px; }
.nav-canal-link svg { width: 15px; height: 15px; flex-shrink: 0; color: var(--gris-3); transition: color .15s; }
.nav-canal-link:hover svg { color: var(--verde); }
.nav-canal-disabled { opacity: .5; cursor: not-allowed; pointer-events: none; }
.nav-canal-soon {
  font-family: 'Montserrat', sans-serif;
  font-size: .5rem;
  font-weight: 700;
  letter-spacing: .5px;
  text-transform: uppercase;
  color: var(--gris-3);
  background: var(--gris-bg, #F9FAFB);
  border: 1px solid var(--borde);
  border-radius: 10px;
  padding: 1px 7px;
  margin-left: auto;
}

/* ---- MEGA-MENU (Servicios) ---- */
.nav-mega {
  position: fixed;
  top: 68px;
  right: 51px;
  left: auto;
  background: #fff;
  border: 1px solid var(--borde);
  border-radius: 8px;
  padding: 16px 0;
  box-shadow: 0 12px 40px rgba(0,0,0,.1);
  display: grid;
  grid-template-columns: repeat(3, auto);
  opacity: 0;
  pointer-events: none;
  transform: translateY(-4px);
  transition: opacity .18s ease, transform .18s ease;
  z-index: 300;
  white-space: nowrap;
}
.nav-has-dropdown:hover .nav-mega,
.nav-has-dropdown:focus-within .nav-mega {
  opacity: 1;
  pointer-events: all;
  transform: translateY(0);
}
.nav-mega-col {
  padding: 0 20px;
  border-right: 1px solid var(--borde);
}
.nav-mega-col:last-child { border-right: none; }
.nav-mega-label {
  display: block;
  font-family: 'Montserrat', sans-serif;
  font-size: .52rem;
  font-weight: 700;
  letter-spacing: .5px;
  color: var(--verde-dark);
  padding-bottom: 8px;
  margin-bottom: 6px;
  border-bottom: 1px solid var(--borde);
}
.nav-mega-link {
  display: block;
  padding: 6px 0;
  font-family: 'Montserrat', sans-serif;
  font-size: .74rem;
  font-weight: 400;
  color: var(--gris-2);
  text-decoration: none;
  transition: color .15s, padding-left .15s;
}
.nav-mega-link:hover { color: var(--verde); padding-left: 6px; }

/* ---- HAMBURGER ---- */
.nav-hamburger {
  display: none;
  flex-direction: column;
  gap: 5px;
  background: transparent;
  border: none;
  cursor: pointer;
  padding: 4px;
}
.nav-hamburger span { width: 24px; height: 2px; background: var(--gris-2); border-radius: 2px; transition: all .2s; }
.nav-hamburger.open span:nth-child(1) { transform: rotate(45deg) translate(5px, 5px); }
.nav-hamburger.open span:nth-child(2) { opacity: 0; }
.nav-hamburger.open span:nth-child(3) { transform: rotate(-45deg) translate(5px, -5px); }

/* ---- MOBILE MENU ---- */
.nav-mobile {
  position: fixed;
  top: 68px; left: 0; right: 0;
  z-index: 199;
  background: #fff;
  border-bottom: 1px solid var(--borde);
  padding: 12px 24px 24px;
  display: flex;
  flex-direction: column;
  gap: 2px;
  transform: translateY(-200%);
  transition: transform .3s ease;
  max-height: calc(100vh - 68px);
  overflow-y: auto;
  box-shadow: 0 8px 24px rgba(0,0,0,.08);
}
.nav-mobile.open { transform: translateY(0); }

.nav-mobile-toggle, .nav-mobile-sector-toggle {
  width: 100%;
  background: transparent;
  border: none;
  color: var(--gris-1);
  font-family: 'Montserrat', sans-serif;
  font-size: .82rem;
  font-weight: 600;
  letter-spacing: .6px;
  text-transform: uppercase;
  padding: 12px 0;
  text-align: left;
  cursor: pointer;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 1px solid var(--borde);
}
.nav-mobile-sector-toggle { font-size: .75rem; padding: 9px 12px; color: var(--gris-2); border-bottom: none; }
.mobile-arrow { transition: transform .2s; font-size: .7rem; color: var(--verde); }
.nav-mobile-toggle.open .mobile-arrow,
.nav-mobile-sector-toggle.open .mobile-arrow { transform: rotate(90deg); }

.nav-mobile-sub { display: none; padding-left: 8px; }
.nav-mobile-sub.open { display: block; }
.nav-mobile-sector { border-left: 2px solid var(--verde-borde); margin: 2px 0; padding-left: 4px; }
.nav-mobile-sector-links { display: none; padding-left: 12px; }
.nav-mobile-sector-links.open { display: flex; flex-direction: column; }

.nav-mobile-link {
  font-family: 'Montserrat', sans-serif;
  font-size: .78rem;
  font-weight: 400;
  color: var(--gris-2);
  text-decoration: none;
  padding: 8px 0 8px 4px;
  display: block;
  transition: color .2s;
  border-bottom: 1px solid var(--borde);
}
.nav-mobile-link:hover { color: var(--verde); }
.nav-mobile-root {
  font-weight: 600;
  font-size: .82rem;
  color: var(--gris-1);
  text-transform: uppercase;
  letter-spacing: .6px;
  padding: 12px 0;
  border-bottom: 1px solid var(--borde);
}

@media (max-width: 900px) {
  nav { padding: 0 24px; }
  .nav-right { display: none; }
  .nav-hamburger { display: flex; }
}

/* ---- USER AVATAR (autenticado) ---- */
.nav-user-wrap { display: inline-flex; align-items: center; }
.nav-user-btn {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  background: #2E7D33;
  color: #fff;
  border: none;
  cursor: pointer;
  font-family: 'Montserrat', sans-serif;
  font-size: .75rem;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 8px;
  transition: opacity .2s;
}
.nav-user-btn:hover { opacity: .85; }
.nav-user-dropdown {
  position: absolute;
  top: calc(100% + 8px);
  right: 0;
  min-width: 200px;
  background: #fff;
  border: 1px solid var(--borde);
  border-radius: 8px;
  padding: 8px 0;
  box-shadow: 0 12px 40px rgba(0,0,0,.1);
  opacity: 0;
  pointer-events: none;
  transform: translateY(-4px);
  transition: opacity .18s ease, transform .18s ease;
  z-index: 300;
}
.nav-user-dropdown.open {
  opacity: 1;
  pointer-events: all;
  transform: translateY(0);
}
.nav-user-email {
  display: block;
  padding: 6px 16px 8px;
  font-size: .7rem;
  font-weight: 400;
  color: var(--gris-3);
  word-break: break-all;
}
</style>

<script>
window.addEventListener('scroll', () => {
  document.getElementById('main-nav')?.classList.toggle('scrolled', window.scrollY > 60);
});

const toggle = document.getElementById('nav-toggle');
const mobileMenu = document.getElementById('nav-mobile');
toggle?.addEventListener('click', () => {
  const isOpen = mobileMenu?.classList.toggle('open');
  toggle.classList.toggle('open', isOpen);
  toggle.setAttribute('aria-expanded', String(isOpen));
});

const serviciosToggle = document.getElementById('mobile-servicios-toggle');
const serviciosSub = document.getElementById('mobile-servicios-sub');
serviciosToggle?.addEventListener('click', () => {
  const isOpen = serviciosSub?.classList.toggle('open');
  serviciosToggle.classList.toggle('open', isOpen);
  serviciosToggle.setAttribute('aria-expanded', String(isOpen));
});

const plataformaToggle = document.getElementById('mobile-plataforma-toggle');
const plataformaSub = document.getElementById('mobile-plataforma-sub');
plataformaToggle?.addEventListener('click', () => {
  const isOpen = plataformaSub?.classList.toggle('open');
  plataformaToggle.classList.toggle('open', isOpen);
  plataformaToggle.setAttribute('aria-expanded', String(isOpen));
});

const blogToggle = document.getElementById('mobile-blog-toggle');
const blogSub = document.getElementById('mobile-blog-sub');
blogToggle?.addEventListener('click', () => {
  const isOpen = blogSub?.classList.toggle('open');
  blogToggle.classList.toggle('open', isOpen);
  blogToggle.setAttribute('aria-expanded', String(isOpen));
});

const canalesToggle = document.getElementById('mobile-canales-toggle');
const canalesSub = document.getElementById('mobile-canales-sub');
canalesToggle?.addEventListener('click', () => {
  const isOpen = canalesSub?.classList.toggle('open');
  canalesToggle.classList.toggle('open', isOpen);
  canalesToggle.setAttribute('aria-expanded', String(isOpen));
});

document.querySelectorAll('.nav-mobile-sector-toggle').forEach(btn => {
  btn.addEventListener('click', () => {
    const links = btn.nextElementSibling as HTMLElement;
    const isOpen = links?.classList.toggle('open');
    btn.classList.toggle('open', isOpen);
    btn.setAttribute('aria-expanded', String(isOpen));
  });
});

document.addEventListener('keydown', e => {
  if (e.key === 'Escape') {
    mobileMenu?.classList.remove('open');
    toggle?.classList.remove('open');
    toggle?.setAttribute('aria-expanded', 'false');
  }
});

// ── Auth state en nav ─────────────────────────────────────────────────────
(async () => {
  const { createClient } = await import('@supabase/supabase-js');
  const sb = createClient(
    import.meta.env.PUBLIC_SUPABASE_URL,
    import.meta.env.PUBLIC_SUPABASE_KEY,
    { auth: { flowType: 'implicit' } }
  );

  const authDesktop = document.getElementById('nav-auth-desktop');
  const userDesktop = document.getElementById('nav-user-desktop');
  const authMobile  = document.getElementById('nav-auth-mobile');
  const userMobile  = document.getElementById('nav-user-mobile');
  const avatar      = document.getElementById('nav-user-avatar');
  const emailLabel  = document.getElementById('nav-user-email-display');
  const dropdown    = document.getElementById('nav-user-dropdown');
  const userBtn     = document.getElementById('nav-user-btn');

  function setLoggedIn(email: string) {
    if (authDesktop) authDesktop.style.display = 'none';
    if (userDesktop) userDesktop.style.display = 'inline-flex';
    if (authMobile)  authMobile.style.display  = 'none';
    if (userMobile)  userMobile.style.display  = 'block';
    if (avatar)      avatar.textContent = email.charAt(0).toUpperCase();
    if (emailLabel)  emailLabel.textContent = email;
  }

  function setLoggedOut() {
    if (authDesktop) authDesktop.style.display = 'inline';
    if (userDesktop) userDesktop.style.display = 'none';
    if (authMobile)  authMobile.style.display  = 'block';
    if (userMobile)  userMobile.style.display  = 'none';
  }

  const { data: { session } } = await sb.auth.getSession();
  if (session?.user?.email) {
    setLoggedIn(session.user.email);
  }

  sb.auth.onAuthStateChange((_event, session) => {
    if (session?.user?.email) setLoggedIn(session.user.email);
    else setLoggedOut();
  });

  // Toggle dropdown
  userBtn?.addEventListener('click', () => {
    const isOpen = dropdown?.classList.toggle('open');
    userBtn.setAttribute('aria-expanded', String(isOpen));
  });
  document.addEventListener('click', (e) => {
    if (!userBtn?.contains(e.target as Node)) {
      dropdown?.classList.remove('open');
      userBtn?.setAttribute('aria-expanded', 'false');
    }
  });

  // Sign out buttons
  async function signOut() {
    await sb.auth.signOut();
    localStorage.removeItem('sigm_email');
    window.location.href = '/';
  }
  document.getElementById('nav-signout-btn-desktop')?.addEventListener('click', signOut);
  document.getElementById('nav-signout-btn-mobile')?.addEventListener('click', signOut);
})();
</script>
