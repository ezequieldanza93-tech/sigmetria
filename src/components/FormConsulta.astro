---
/**
 * FormConsulta — formulario inline para consultas y lead magnets.
 *
 * Ambos modos muestran el mismo formulario y envían por la API de captura
 * de la app (POST /api/growth/v1/leads, autenticado con PUBLIC_GROWTH_KEY).
 *
 * Modo lead magnet (leadMagnet prop presente):
 *   El recurso se entrega por email — sin cuenta ni login.
 *
 * Modo consulta (sin leadMagnet):
 *   Consulta comercial clásica; el equipo contacta al lead.
 */
import { RECURSOS } from '../data/recursos';

interface Props {
  servicios: string[];
  funnel?: 'tofu' | 'mofu' | 'bofu';
  leadMagnet?: string;
  titulo?: string;
  subtitulo?: string;
  cta?: string;
  successMsg?: string;
}

const {
  servicios,
  funnel = 'mofu',
  leadMagnet,
  titulo,
  subtitulo,
  cta = 'Enviar consulta',
  successMsg = '¡Listo! En breve te contactamos. Revisá tu email.',
} = Astro.props;

// Normalizamos diacríticos del slug ("…primer-año" → "…primer-ano") para que
// matchee la key real del catálogo de lead magnets.
const lmKey = leadMagnet
  ? leadMagnet.normalize('NFD').replace(/[\u0300-\u036f]/g, '')
  : '';

const recurso = lmKey ? RECURSOS.find((r) => r.slug === lmKey) : undefined;
const successFinal = lmKey
  ? `¡Listo! Te enviamos ${recurso ? `«${recurso.titulo}»` : 'el recurso'} a tu correo. Si no lo ves, revisá spam o promociones.`
  : successMsg;
---

<div
  class="fc-wrap"
  data-servicios={JSON.stringify(servicios)}
  data-funnel={funnel}
  data-lm={lmKey}
>
  <div class="fc-success" style="display:none" role="status" aria-live="polite">
    <span class="fc-success-icon">✅</span>
    <p>{successFinal}</p>
  </div>

  <form class="fc-form" novalidate>
    <input type="text" name="_gotcha" style="display:none" tabindex="-1" autocomplete="off" />

    {titulo    && <h3 class="fc-titulo">{titulo}</h3>}
    {subtitulo && <p  class="fc-sub">{subtitulo}</p>}

    <div class="fc-group">
      <label for="fc-nombre" class="fc-sr-only">Nombre y apellido</label>
      <input id="fc-nombre" type="text" name="nombre" required placeholder="Nombre y apellido *" autocomplete="name" />
    </div>

    <div class="fc-row">
      <label for="fc-telefono" class="fc-sr-only">WhatsApp</label>
      <input id="fc-telefono" type="tel"   name="telefono" required placeholder="WhatsApp +549 11..." autocomplete="tel" />
      <label for="fc-email" class="fc-sr-only">Email</label>
      <input id="fc-email" type="email" name="email"    required placeholder="Email *" autocomplete="email" />
    </div>

    <label class="fc-terms">
      <input type="checkbox" name="acepta" required />
      <span>Acepto la <a href="/politica-de-privacidad/" target="_blank" rel="noopener">política de privacidad</a></span>
    </label>
    <label class="fc-terms">
      <input type="checkbox" name="optin" />
      <span>Quiero recibir novedades por email (opcional)</span>
    </label>

    <p class="fc-error" style="display:none">Completá todos los campos para continuar.</p>

    <button type="submit" class="fc-btn">{cta}</button>
  </form>
</div>

<style>
.fc-wrap {
  background: var(--verde-light);
  border: 1px solid var(--verde-borde);
  border-radius: 12px;
  padding: 28px 32px;
  max-width: 540px;
}
.fc-titulo {
  font-family: 'Montserrat', sans-serif;
  font-size: 1rem;
  font-weight: 800;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  color: var(--gris-1);
  margin-bottom: 6px;
}
.fc-sub {
  font-size: 13px;
  font-weight: 300;
  color: var(--gris-2);
  margin-bottom: 16px;
  line-height: 1.6;
}

.fc-form { display: flex; flex-direction: column; gap: 12px; }
/* A13: label accesible para el placeholder — oculto visualmente, presente para lectores de pantalla */
.fc-sr-only {
  position: absolute;
  width: 1px;
  height: 1px;
  padding: 0;
  margin: -1px;
  overflow: hidden;
  clip: rect(0, 0, 0, 0);
  white-space: nowrap;
  border: 0;
}
.fc-group input,
.fc-row input {
  background: var(--blanco);
  border: 1px solid var(--borde);
  border-radius: 6px;
  padding: 11px 14px;
  font-family: 'Poppins', sans-serif;
  font-size: 14px;
  font-weight: 300;
  color: var(--gris-1);
  outline: none;
  width: 100%;
  box-sizing: border-box;
  transition: border-color .2s;
}
.fc-group input:focus,
.fc-row input:focus { border-color: var(--verde); }
.fc-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
}
.fc-terms {
  display: flex;
  align-items: flex-start;
  gap: 8px;
  font-size: 12px;
  font-weight: 300;
  color: var(--gris-2);
  cursor: pointer;
}
.fc-terms input { width: 14px; height: 14px; min-width: 14px; margin-top: 2px; accent-color: var(--verde); }
.fc-terms a { color: var(--verde); }
.fc-error { font-size: 12px; color: #ef4444; }

/* Botón */
.fc-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  width: 100%;
  padding: 13px 20px;
  background: #2E7D33;
  color: #fff;
  border: none;
  border-radius: 10px;
  font-family: 'Montserrat', sans-serif;
  font-weight: 700;
  font-size: .82rem;
  letter-spacing: .5px;
  text-transform: uppercase;
  cursor: pointer;
  transition: background .2s;
  margin-top: 4px;
}
.fc-btn:hover { background: #1B5E20; }
.fc-btn:focus-visible { outline: 2px solid #2E7D33; outline-offset: 3px; }

/* Éxito */
.fc-success {
  text-align: center;
  padding: 12px 0;
}
.fc-success-icon { font-size: 2rem; display: block; margin-bottom: 10px; }
.fc-success p {
  font-size: 14px;
  font-weight: 300;
  color: var(--gris-2);
  line-height: 1.7;
}

@media (max-width: 520px) {
  .fc-wrap { padding: 22px 18px; }
  .fc-row  { grid-template-columns: 1fr; }
}
</style>

<script>
  // Endpoint público de captura de la app (Ola 1 — Motor de Crecimiento).
  // Ambas vars son PUBLIC_* y se inlinean en build (SSG).
  const APP_URL    = (import.meta.env.PUBLIC_APP_URL ?? '').replace(/\/+$/, '');
  const GROWTH_KEY = import.meta.env.PUBLIC_GROWTH_KEY ?? '';

  // Timestamp de montaje del script → t_fill_ms (anti-bot: forms llenados en <1.2s se descartan server-side)
  const montadoEn = Date.now();

  const p = new URLSearchParams(window.location.search);
  const utm = {
    utm_source:   p.get('utm_source'),
    utm_medium:   p.get('utm_medium'),
    utm_campaign: p.get('utm_campaign'),
    utm_content:  p.get('utm_content'),
  };

  document.querySelectorAll<HTMLElement>('.fc-wrap').forEach(wrap => {
    const servicios  = JSON.parse(wrap.dataset.servicios ?? '[]') as string[];
    const funnel     = wrap.dataset.funnel || null;
    const leadMagnet = wrap.dataset.lm     || null;

    const form    = wrap.querySelector<HTMLFormElement>('.fc-form')!;
    const success = wrap.querySelector<HTMLElement>('.fc-success')!;
    const errMsg  = wrap.querySelector<HTMLElement>('.fc-error')!;

    // Pre-cargar email desde localStorage si está disponible
    const savedEmail = localStorage.getItem('sigm_email');
    const emailInput = form?.querySelector<HTMLInputElement>('[name="email"]');
    if (savedEmail && emailInput) emailInput.value = savedEmail;

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();

      const nombre   = (form.querySelector<HTMLInputElement>('[name="nombre"]')!).value.trim();
      const telefono = (form.querySelector<HTMLInputElement>('[name="telefono"]')!).value.trim();
      const email    = (form.querySelector<HTMLInputElement>('[name="email"]')!).value.trim();
      const acepta   = (form.querySelector<HTMLInputElement>('[name="acepta"]')!).checked;
      const mensaje  = (form.querySelector<HTMLInputElement>('[name="mensaje"]'))?.value.trim() || null;
      const optin    = !!(form.querySelector<HTMLInputElement>('[name="optin"]'))?.checked;
      // El honeypot viaja en el JSON: el server hace silent-drop y responde éxito igual.
      const gotcha   = (form.querySelector<HTMLInputElement>('input[name="_gotcha"]'))?.value ?? '';

      if (!nombre || !telefono || !email || !acepta) {
        errMsg.textContent = 'Completá todos los campos para continuar.';
        errMsg.style.display = 'block';
        return;
      }
      errMsg.style.display = 'none';

      const btn = form.querySelector<HTMLButtonElement>('button[type="submit"]')!;
      const lbl = btn.textContent;
      btn.textContent = 'Enviando...';
      btn.disabled = true;

      const payload: Record<string, unknown> = {
        nombre,
        email,
        telefono,
        pagina_origen:          window.location.href.slice(0, 300),
        primer_canal:           'web',
        canales_visitados:      ['web'],
        acepta_privacidad:      true,
        acepta_email_marketing: optin,
        _gotcha:                gotcha,
        t_fill_ms:              Date.now() - montadoEn,
        ...Object.fromEntries(
          Object.entries(utm)
            .filter(([, v]) => v)
            .map(([k, v]) => [k, (v as string).slice(0, 150)]),
        ),
      };
      if (mensaje)           payload.mensaje           = mensaje;
      if (servicios.length)  payload.servicios_interes = servicios;
      if (leadMagnet)        payload.lead_magnet       = leadMagnet;
      if (funnel)            payload.etapa_funnel      = funnel;

      let ok = false;
      let status = 0;
      let magnetEntregado: string | null = null;
      try {
        const res = await fetch(`${APP_URL}/api/growth/v1/leads`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'X-Growth-Key': GROWTH_KEY,
          },
          body: JSON.stringify(payload),
        });
        ok = res.ok;
        status = res.status;
        try {
          const data = await res.json();
          magnetEntregado = data?.magnet ?? null;
        } catch (_) { /* respuesta sin body: se asume sin entrega */ }
      } catch (_) {
        ok = false;
      }

      if (!ok) {
        btn.textContent = lbl;
        btn.disabled = false;
        errMsg.textContent = status === 429
          ? 'Demasiados envíos seguidos. Esperá unos minutos y probá de nuevo — no se pierde lo que escribiste.'
          : 'Hubo un error al enviar. Intentá de nuevo en unos segundos o escribinos por WhatsApp — no se pierde lo que escribiste.';
        errMsg.style.display = 'block';
        return;
      }

      // Copy HONESTO: solo prometemos "te lo enviamos" si el server confirmó
      // la entrega (magnet: 'email'). Si el recurso no estaba disponible, el
      // equipo ya recibió el aviso y lo manda a mano — sin mentirle al lead.
      if (leadMagnet && magnetEntregado !== 'email') {
        const successP = success.querySelector('p');
        if (successP) {
          successP.textContent =
            '¡Listo! Recibimos tu pedido del recurso. Te lo enviamos a tu correo a la brevedad.';
        }
      }

      localStorage.setItem('sigm_email', email);
      form.style.display    = 'none';
      success.style.display = 'block';
    });
  });
</script>
