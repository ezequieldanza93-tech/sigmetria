---
/**
 * FormLeadMagnetPDF — gate de descarga autenticado.
 *
 * Estados:
 *   1. Loading     → verificando sesión via INITIAL_SESSION
 *   2. Autenticado → descarga automática + botón manual
 *   3. No auth     → CTA para iniciar sesión / crear cuenta
 *   4. Éxito       → descarga empezó
 */

interface Props {
  titulo?: string;
  subtitulo?: string;
  cta?: string;
  leadMagnetKey?: string;
}

const {
  titulo        = 'Descargá la plantilla profesional de recorrida',
  subtitulo     = 'Accedé gratis con tu cuenta a esta plantilla profesional de recorrida de seguridad.',
  cta           = 'Descargar (PDF)',
  leadMagnetKey = 'plantilla-recorrida',
} = Astro.props;
---

<div class="lm-wrap" data-lm-key={leadMagnetKey}>

  <!-- Estado 0: cargando -->
  <div class="lm-loading">
    <div class="lm-spinner" aria-hidden="true"></div>
    <p style="margin:0;font-size:13px;color:var(--gris-3)">Verificando acceso…</p>
  </div>

  <!-- Estado 1: sesión activa — descarga directa -->
  <div class="lm-authenticated" style="display:none">
    <h3 class="lm-titulo">{titulo}</h3>
    <p class="lm-welcome-msg lm-sub"></p>
    <button class="lm-btn lm-auth-download-btn" type="button">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
        <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4M7 10l5 5 5-5M12 15V3"/>
      </svg>
      {cta}
    </button>
    <p class="lm-signout-hint">
      ¿No sos vos? <button class="lm-link-btn lm-signout-btn" type="button">Cerrar sesión</button>
    </p>
  </div>

  <!-- Estado 2: no autenticado — CTA para acceder -->
  <div class="lm-cta" style="display:none">
    <div class="lm-cta-lock" aria-hidden="true">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#2E7D33" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
        <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
      </svg>
    </div>
    <h3 class="lm-titulo">{titulo}</h3>
    <p class="lm-sub">{subtitulo}</p>
    <p class="lm-cta-note">📥 Es gratis — solo necesitás una cuenta.</p>
    <button class="lm-btn lm-cta-btn" type="button">Acceder y descargar →</button>
    <p class="lm-cta-hint">¿Ya tenés cuenta? El mismo botón te lleva al login.</p>
  </div>

  <!-- Estado 3: descarga disparada (éxito) -->
  <div class="lm-success" style="display:none" role="status" aria-live="polite">
    <span class="lm-success-icon" aria-hidden="true">✅</span>
    <p class="lm-success-msg">
      ¡Tu descarga ya empezó! Si no, <a href="#" class="lm-dl-link">tocá acá</a>.
    </p>
  </div>

</div>

<style>
.lm-wrap {
  background: var(--verde-light);
  border: 2px solid var(--verde-borde);
  border-left: 4px solid var(--verde);
  border-radius: 12px;
  padding: 32px 36px;
  max-width: 560px;
}

/* Loading */
.lm-loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12px;
  padding: 24px 0 16px;
}
.lm-spinner {
  width: 22px;
  height: 22px;
  border: 2px solid rgba(46,125,51,.2);
  border-top-color: #2E7D33;
  border-radius: 50%;
  animation: spin .7s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }

/* Títulos */
.lm-titulo {
  font-family: 'Montserrat', sans-serif;
  font-size: .95rem;
  font-weight: 800;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  color: var(--gris-1);
  margin-bottom: 8px;
}
.lm-sub {
  font-size: 14px;
  font-weight: 300;
  color: var(--gris-2);
  line-height: 1.65;
  margin-bottom: 20px;
}

/* CTA (no autenticado) */
.lm-cta { display: flex; flex-direction: column; }
.lm-cta-lock {
  width: 48px;
  height: 48px;
  background: #fff;
  border: 1.5px solid var(--verde-borde);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16px;
}
.lm-cta-note {
  font-size: 13px;
  font-weight: 500;
  color: var(--verde, #2E7D33);
  margin-bottom: 14px;
}
.lm-cta-hint {
  text-align: center;
  font-size: 12px;
  font-weight: 300;
  color: var(--gris-3);
  margin-top: 10px;
}

/* Botón principal */
.lm-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  width: 100%;
  padding: 13px 28px;
  background: #2E7D33;
  color: #fff;
  border: none;
  border-radius: 12px;
  font-family: 'Montserrat', sans-serif;
  font-weight: 700;
  font-size: .82rem;
  letter-spacing: .6px;
  text-transform: uppercase;
  cursor: pointer;
  transition: background .2s, opacity .2s;
  margin-top: 4px;
}
.lm-btn:not([disabled]):hover  { background: #1B5E20; }
.lm-btn:focus-visible           { outline: 2px solid #2E7D33; outline-offset: 3px; }
.lm-btn[disabled],
.lm-btn[aria-disabled="true"]   { background: #B0BEC5; color: #78909C; cursor: not-allowed; opacity: .75; }

/* Botón-link */
.lm-link-btn {
  background: none;
  border: none;
  color: #2E7D33;
  font-size: 12px;
  font-weight: 500;
  text-decoration: underline;
  text-underline-offset: 2px;
  cursor: pointer;
  padding: 0;
  font-family: inherit;
}
.lm-link-btn:hover { color: #1B5E20; }

.lm-signout-hint {
  text-align: center;
  font-size: 12px;
  font-weight: 300;
  color: var(--gris-3);
  margin-top: 12px;
}

/* Éxito */
.lm-success { text-align: center; padding: 16px 0 8px; }
.lm-success-icon { font-size: 2.2rem; display: block; margin-bottom: 12px; }
.lm-success-msg {
  font-size: 15px;
  font-weight: 400;
  color: var(--gris-2);
  line-height: 1.7;
}
.lm-success-msg a { color: #2E7D33; font-weight: 600; text-decoration: underline; }

@media (max-width: 520px) {
  .lm-wrap { padding: 24px 20px; }
}
</style>

<script>
  import { createClient } from '@supabase/supabase-js';

  const supabase = createClient(
    import.meta.env.PUBLIC_SUPABASE_URL,
    import.meta.env.PUBLIC_SUPABASE_KEY,
    { auth: { detectSessionInUrl: true, persistSession: true } }
  );

  document.querySelectorAll<HTMLElement>('.lm-wrap').forEach(wrap => {
    const leadMagnetKey = wrap.dataset.lmKey ?? 'plantilla-recorrida';

    const elLoading = wrap.querySelector<HTMLElement>('.lm-loading')!;
    const elAuth    = wrap.querySelector<HTMLElement>('.lm-authenticated')!;
    const elCta     = wrap.querySelector<HTMLElement>('.lm-cta')!;
    const elSuccess = wrap.querySelector<HTMLElement>('.lm-success')!;
    const dlLink    = wrap.querySelector<HTMLAnchorElement>('.lm-dl-link')!;
    const welcomeMsg = wrap.querySelector<HTMLElement>('.lm-welcome-msg')!;

    const ALL = [elLoading, elAuth, elCta, elSuccess];
    function show(el: HTMLElement) {
      ALL.forEach(s => { if (s) s.style.display = 'none'; });
      el.style.display = 'block';
    }

    // ── Storage ─────────────────────────────────────────────────────────────
    async function getSignedUrl(): Promise<string | null> {
      try {
        const { data, error } = await supabase.storage
          .from('lead-magnets')
          .createSignedUrl(`${leadMagnetKey}.pdf`, 300);
        if (!error && data?.signedUrl) return data.signedUrl;
      } catch (_) {}
      return null;
    }

    function triggerDownload(url: string) {
      const a = document.createElement('a');
      a.href = url;
      a.download = `Sigmetria-${leadMagnetKey}.pdf`;
      a.style.display = 'none';
      document.body.appendChild(a);
      a.click();
      document.body.removeChild(a);
    }

    function trackDownload(email: string, userId?: string | null) {
      const slug = window.location.pathname.replace(/\/+$/, '').split('/').pop() || null;
      supabase.from('lead_magnet_descargas').insert({
        email,
        lead_magnet_key: leadMagnetKey,
        auth_user_id: userId ?? null,
        origen_pagina: window.location.href,
        origen_slug: slug,
        canal: 'web',
        etapa_funnel: 'tofu',
      });
    }

    // ── Sesión activa ────────────────────────────────────────────────────────
    async function handleSession(session: any) {
      const email = session.user.email as string;
      await supabase.rpc('link_lead_to_auth_user', { p_email: email });
      localStorage.setItem('sigm_email', email);

      const url = await getSignedUrl();
      if (url) {
        if (dlLink) dlLink.href = url;
        show(elSuccess);
        triggerDownload(url);
        trackDownload(email, session.user.id);
      } else {
        if (welcomeMsg) welcomeMsg.textContent = '¡Ya tenés acceso! Tocá para descargar.';
        show(elAuth);
        const authBtn = wrap.querySelector<HTMLButtonElement>('.lm-auth-download-btn')!;
        authBtn.onclick = async () => {
          const u = await getSignedUrl();
          if (u) { triggerDownload(u); trackDownload(email, session.user.id); }
        };
      }
    }

    // ── INITIAL_SESSION resuelve el estado inicial ──────────────────────────
    show(elLoading);

    supabase.auth.onAuthStateChange(async (event, session) => {
      if (event === 'INITIAL_SESSION') {
        if (session) {
          await handleSession(session);
        } else {
          show(elCta);
        }
      } else if ((event === 'SIGNED_IN' || event === 'TOKEN_REFRESHED') && session) {
        await handleSession(session);
      }
    });

    // ── CTA: ir a login ──────────────────────────────────────────────────────
    const ctaBtn = wrap.querySelector<HTMLButtonElement>('.lm-cta-btn');
    if (ctaBtn) {
      ctaBtn.addEventListener('click', () => {
        const next = encodeURIComponent(window.location.href);
        window.location.href = `/acceso/?next=${next}`;
      });
    }

    // ── Cerrar sesión ─────────────────────────────────────────────────────────
    const signOutBtn = wrap.querySelector<HTMLButtonElement>('.lm-signout-btn');
    if (signOutBtn) {
      signOutBtn.addEventListener('click', async () => {
        localStorage.removeItem('sigm_email');
        await supabase.auth.signOut();
        show(elCta);
      });
    }
  });
</script>
