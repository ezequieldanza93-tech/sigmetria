---
/**
 * Icon.astro — iconos SVG estilo Lucide (line icons), coherentes con la app.
 * Reemplazan a los emoji. Heredan el color del padre (currentColor) y el tamaño por prop.
 *
 * Uso:  <Icon name="camera" size={28} />
 *       <Icon name="target" class="mv-svg" />
 *
 * Color: se setea con `color` en el CSS del contenedor (ej: color: var(--verde-dark)).
 */
interface Props {
  name: string;
  size?: number;
  strokeWidth?: number;
  class?: string;
}
const { name, size = 24, strokeWidth = 2, class: className = '' } = Astro.props;

const icons: Record<string, string> = {
